{
  "compilerOptions": {
    "types": [
      "astro/client",
      "./worker-configuration.d.ts",
      "node"
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@components/*": ["src/components/*"],
      "@lib/*": ["src/lib/*"],
      "@layouts/*": ["src/layouts/*"],
      "@pages/*": ["src/pages/*"],
      "@server/*": ["src/server/*"],
      "@styles/*": ["src/styles/*"],
      "@types/*": ["src/types/*"],
      "@db/*": ["src/db/*"]
    }
  },
  "extends": "astro/tsconfigs/strict",
  "include": [
    ".astro/types.d.ts",
    "**/*"
  ],
  "exclude": [
    "dist"
  ]
}