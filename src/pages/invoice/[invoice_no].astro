---
import { initDb, getDb } from "../../lib/db";
import { requireAdmin } from "../../lib/auth";
import "../../styles/global.css";

await initDb(Astro);
const invoiceNo = Astro.params.invoice_no;
const db = getDb(Astro);
const result = await db.execute({
    sql: `SELECT i.*, o.order_no, o.customer_name, o.customer_phone, o.total, o.items_json, o.shipping_address_json
          FROM invoices i JOIN orders o ON o.id = i.order_id
          WHERE i.invoice_no = ?`,
    args: [invoiceNo ?? ""],
});
const invoice = result.rows[0] as any;
if (!invoice) {
    return Astro.redirect("/");
}

const admin = await requireAdmin(Astro);
if (!admin) {
    const phone = Astro.url.searchParams.get("phone") || "";
    const normalizePhone = (value: string) => value.replace(/[^\d]/g, "");
    const allowed =
        normalizePhone(phone) ===
        normalizePhone(String(invoice.customer_phone || ""));
    if (!allowed) {
        return Astro.redirect("/");
    }
}

const items = JSON.parse(String(invoice.items_json || "[]"));
const address = JSON.parse(String(invoice.shipping_address_json || "{}"));
---

<!doctype html>
<html lang="id">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <title>Invoice {invoice.invoice_no}</title>
    </head>
    <body class="m-6 text-[#1f1b16]">
        <div class="flex items-center justify-between">
            <div>
                <h2>Roti Sholawat</h2>
                <div class="muted text-[#6b625a]">Semesta Bersholawat</div>
            </div>
            <div>
                <div>Invoice: {invoice.invoice_no}</div>
                <div class="muted text-[#6b625a]">Order: {invoice.order_no}</div>
                <div class="muted text-[#6b625a]">
                    Tanggal: {String(invoice.issued_at).split("T")[0]}
                </div>
            </div>
        </div>

        <div class="mt-4">
            <strong>Pelanggan</strong>
            <div>{invoice.customer_name}</div>
            <div class="muted text-[#6b625a]">{invoice.customer_phone}</div>
        </div>

        <div class="mt-3">
            <strong>Alamat</strong>
            <div>{address.province} - {address.city} - {address.district}</div>
            <div class="muted text-[#6b625a]">{address.street || ""}</div>
        </div>

        <table class="mt-4 w-full border-collapse">
            <thead>
                <tr>
                    <th class="border-b border-[#e6dfd3] py-2 text-left">Produk</th>
                    <th class="border-b border-[#e6dfd3] py-2 text-left">Qty</th>
                    <th class="border-b border-[#e6dfd3] py-2 text-left">Harga</th>
                    <th class="border-b border-[#e6dfd3] py-2 text-left">Total</th>
                </tr>
            </thead>
            <tbody>
                {
                    items.map((item: any) => (
                        <tr>
                            <td class="border-b border-[#e6dfd3] py-2">{item.name}</td>
                            <td class="border-b border-[#e6dfd3] py-2">{item.qty}</td>
                            <td class="border-b border-[#e6dfd3] py-2">
                                Rp {Number(item.price).toLocaleString("id-ID")}
                            </td>
                            <td class="border-b border-[#e6dfd3] py-2">
                                Rp {Number(item.total).toLocaleString("id-ID")}
                            </td>
                        </tr>
                    ))
                }
            </tbody>
        </table>

        <div class="mt-3 text-right font-semibold">
            Total: Rp {Number(invoice.total).toLocaleString("id-ID")}
        </div>

        <button
            class="mt-4 print:hidden"
            onclick="window.print()"
        >
            Print
        </button>
    </body>
</html>
