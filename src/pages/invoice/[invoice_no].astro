---
import { requireAdmin } from "../../lib/auth";
import { getDb, initDb } from "../../lib/db";
import "../../styles/global.css";
import { getLang, tServer, fServer } from "../../lib/i18n/server";

await initDb(Astro);
const invoiceNo = Astro.params.invoice_no;
const db = getDb(Astro);
const result = await db.execute({
  sql: `SELECT i.*, o.order_no, o.customer_name, o.customer_phone, o.total, o.items_json, o.shipping_address_json
          FROM invoices i JOIN orders o ON o.id = i.order_id
          WHERE i.invoice_no = ?`,
  args: [invoiceNo ?? ""],
});
const invoice = result.rows[0] as any;
if (!invoice) {
  return Astro.redirect("/");
}

const admin = await requireAdmin(Astro);
if (!admin) {
  const phone = Astro.url.searchParams.get("phone") || "";
  const normalizePhone = (value: string) => value.replace(/[^\d]/g, "");
  const allowed = normalizePhone(phone) === normalizePhone(String(invoice.customer_phone || ""));
  if (!allowed) {
    return Astro.redirect("/");
  }
}

const items = JSON.parse(String(invoice.items_json || "[]"));
const address = JSON.parse(String(invoice.shipping_address_json || "{}"));
const lang = getLang(Astro.cookies);
const f = fServer(lang);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{tServer(lang, "invoice.title")} {invoice.invoice_no}</title>
  </head>
  <body class="m-6 text-[#1f1b16]">
    <div class="flex items-center justify-between">
      <div>
        <h2>Roti Sholawat</h2>
        <div class="muted text-[#6b625a]">Semesta Bersholawat</div>
      </div>
      <div>
        <div>{tServer(lang, "invoice.title")}: {invoice.invoice_no}</div>
        <div class="muted text-[#6b625a]">{tServer(lang, "orders.order_no")}: {invoice.order_no}</div>
        <div class="muted text-[#6b625a]">
          {tServer(lang, "orders.date")}: {f.date(invoice.issued_at)}
        </div>
      </div>
    </div>

    <div class="mt-4">
      <strong>{tServer(lang, "orders.customer")}</strong>
      <div>{invoice.customer_name}</div>
      <div class="muted text-[#6b625a]">{invoice.customer_phone}</div>
    </div>

    <div class="mt-3">
      <strong>{tServer(lang, "orders.shipping_info")}</strong>
      <div>{address.province} - {address.city} - {address.district}</div>
      <div class="muted text-[#6b625a]">{address.street || ""}</div>
    </div>

    <table class="mt-4 w-full border-collapse">
      <thead>
        <tr>
          <th class="border-b border-[#e6dfd3] py-2 text-left">{tServer(lang, "orders.product")}</th>
          <th class="border-b border-[#e6dfd3] py-2 text-left">{tServer(lang, "orders.qty")}</th>
          <th class="border-b border-[#e6dfd3] py-2 text-left">{tServer(lang, "orders.price")}</th>
          <th class="border-b border-[#e6dfd3] py-2 text-left">{tServer(lang, "orders.total")}</th>
        </tr>
      </thead>
      <tbody>
        {
          items.map((item: any) => (
            <tr>
              <td class="border-b border-[#e6dfd3] py-2">{item.name}</td>
              <td class="border-b border-[#e6dfd3] py-2">{item.qty}</td>
              <td class="border-b border-[#e6dfd3] py-2">{f.currency(item.price)}</td>
              <td class="border-b border-[#e6dfd3] py-2">{f.currency(item.total)}</td>
            </tr>
          ))
        }
      </tbody>
    </table>

    <div class="mt-3 text-right font-semibold">
      {tServer(lang, "orders.total_label")}: {f.currency(invoice.total)}
    </div>

    <button class="mt-4 print:hidden" onclick="window.print()"> {tServer(lang, "common.print")} </button>
  </body>
</html>
