---
import Layout from "@/layouts/Layout.astro";
import { getDb, initDb } from "@/lib/db";
import { getLang, tServer, fServer } from "@/lib/i18n/server";

await initDb(Astro);
const db = getDb(Astro);
const products = await db.execute(
  "SELECT name, price, images_json, description FROM products WHERE is_active = 1 ORDER BY created_at DESC",
);
const lang = getLang(Astro.cookies);
const f = fServer(lang);
---

<Layout title={tServer(lang, "catalog.title") + " — Roti Sholawat"} description={tServer(lang, "catalog.description")}>
  <main class="bg-surface pb-24">
    <!-- Products Hero -->
    <section class="bg-primary/5 relative overflow-hidden pt-16 pb-16 lg:pt-20">
      <div class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_top_right,rgba(37,190,196,0.1),transparent_50%)]">
      </div>
      <div class="relative z-10 container mx-auto max-w-3xl text-center">
        <span class="sub-title">{tServer(lang, "catalog.hero_subtitle")}</span>
        <h1 class="mb-6">
          {tServer(lang, "catalog.hero_title_1")}
          <span class="text-primary italic">{tServer(lang, "catalog.hero_title_2")}</span>
        </h1>
        <p class="text-text-muted text-lg leading-relaxed">
          {tServer(lang, "catalog.hero_desc")}
        </p>
      </div>
    </section>

    <section class="section py-20">
      <div class="container">
        <div class="mb-12 flex flex-wrap items-center justify-between gap-4">
          <h2 class="text-2xl md:text-3xl">{tServer(lang, "catalog.title_all")}</h2>
          <div class="bg-primary/5 flex gap-2 rounded-xl p-1">
            <button class="text-primary rounded-lg bg-white px-4 py-2 text-sm font-bold shadow-sm"
              >{tServer(lang, "common.all")}</button
            >
            <button
              class="text-text-muted hover:text-primary rounded-lg px-4 py-2 text-sm font-semibold transition-colors"
              >Roti</button
            >
            <button
              class="text-text-muted hover:text-primary rounded-lg px-4 py-2 text-sm font-semibold transition-colors"
              >Snack Box</button
            >
          </div>
        </div>

        <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
          {
            products.rows.map((product: any) => {
              let image = "";
              try {
                const urls = JSON.parse(String(product.images_json || "[]"));
                image = Array.isArray(urls) ? urls[0] : "";
              } catch {
                image = "";
              }
              return (
                <div class="group border-primary/10 rounded-3xl border bg-white p-4 shadow-[0_10px_30px_rgba(0,0,0,0.03)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_30px_60px_rgba(0,0,0,0.08)]">
                  <div class="relative mb-5 aspect-square overflow-hidden rounded-2xl">
                    {image ? (
                      <img
                        src={image}
                        alt={product.name}
                        class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-110"
                      />
                    ) : (
                      <div class="bg-primary/5 text-primary/20 flex h-full w-full items-center justify-center">
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="48"
                          height="48"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="1"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <rect width="18" height="18" x="3" y="3" rx="2" ry="2" />
                          <circle cx="9" cy="9" r="2" />
                          <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
                        </svg>
                      </div>
                    )}
                    <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 transition-opacity group-hover:opacity-100" />
                  </div>
                  <div class="px-2">
                    <h3 class="text-primary-dark group-hover:text-primary text-xl font-bold transition-colors">
                      {product.name}
                    </h3>
                    <p class="text-text-muted my-3 line-clamp-2 min-h-[40px] text-sm">{product.description}</p>
                    <div class="border-primary/5 mt-6 flex items-center justify-between border-t pt-4">
                      <strong class="text-primary font-fraunces text-xl">{f.currency(Number(product.price))}</strong>
                      <a
                        href="/order"
                        class="bg-primary/10 text-primary hover:bg-primary flex h-10 w-10 items-center justify-center rounded-full transition-all hover:text-white"
                        aria-label={tServer(lang, "common.order")}
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          width="20"
                          height="20"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <>
                            <path d="M5 12h14" />
                            <path d="m12 5 7 7-7 7" />
                          </>
                        </svg>
                      </a>
                    </div>
                  </div>
                </div>
              );
            })
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
