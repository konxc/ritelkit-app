---
import Layout from "../layouts/Layout.astro";
import { getDb, initDb } from "../lib/db";

await initDb(Astro);
const db = getDb(Astro);
const products = await db.execute(
  "SELECT name, price, images_json, description FROM products WHERE is_active = 1 ORDER BY created_at DESC",
);
---

<Layout
    title="Katalog Produk — Roti Sholawat"
    description="Pilihan roti manis, cake, dan paket snack box premium dari Roti Sholawat Yogyakarta."
>
    <main class="bg-surface pb-24">
        <!-- Products Hero -->
        <section
            class="relative pt-16 lg:pt-20 pb-16 overflow-hidden bg-primary/5"
        >
            <div
                class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_top_right,rgba(37,190,196,0.1),transparent_50%)]"
            >
            </div>
            <div class="container relative z-10 text-center max-w-3xl mx-auto">
                <span class="sub-title">Katalog Lengkap</span>
                <h1 class="mb-6">
                    Pilihan Terbaik untuk <span class="text-primary italic"
                        >Setiap Acara</span
                    >
                </h1>
                <p class="text-lg text-text-muted leading-relaxed">
                    Dari roti harian yang lembut hingga paket snack box premium
                    untuk momen spesial Anda. Kami memastikan setiap produk
                    dibuat dengan bahan pilihan dan penuh keberkahan.
                </p>
            </div>
        </section>

        <section class="section py-20">
            <div class="container">
                <div
                    class="flex items-center justify-between mb-12 flex-wrap gap-4"
                >
                    <h2 class="text-2xl md:text-3xl">Semua Produk</h2>
                    <div class="flex gap-2 bg-primary/5 p-1 rounded-xl">
                        <button
                            class="px-4 py-2 rounded-lg text-sm font-bold bg-white text-primary shadow-sm"
                            >Semua</button
                        >
                        <button
                            class="px-4 py-2 rounded-lg text-sm font-semibold text-text-muted hover:text-primary transition-colors"
                            >Roti</button
                        >
                        <button
                            class="px-4 py-2 rounded-lg text-sm font-semibold text-text-muted hover:text-primary transition-colors"
                            >Snack Box</button
                        >
                    </div>
                </div>

                <div
                    class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8"
                >
                    {
                        products.rows.map((product: any) => {
                            let image = "";
                            try {
                                const urls = JSON.parse(
                                    String(product.images_json || "[]"),
                                );
                                image = Array.isArray(urls) ? urls[0] : "";
                            } catch {
                                image = "";
                            }
                            return (
                                <div class="group bg-white rounded-3xl p-4 border border-primary/10 shadow-[0_10px_30px_rgba(0,0,0,0.03)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_30px_60px_rgba(0,0,0,0.08)]">
                                    <div class="relative aspect-square overflow-hidden rounded-2xl mb-5">
                                        {image ? (
                                            <img
                                                src={image}
                                                alt={product.name}
                                                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                                            />
                                        ) : (
                                            <div class="w-full h-full bg-primary/5 flex items-center justify-center text-primary/20">
                                                <svg
                                                    xmlns="http://www.w3.org/2000/svg"
                                                    width="48"
                                                    height="48"
                                                    viewBox="0 0 24 24"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    stroke-width="1"
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                >
                                                    <rect
                                                        width="18"
                                                        height="18"
                                                        x="3"
                                                        y="3"
                                                        rx="2"
                                                        ry="2"
                                                    />
                                                    <circle
                                                        cx="9"
                                                        cy="9"
                                                        r="2"
                                                    />
                                                    <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21" />
                                                </svg>
                                            </div>
                                        )}
                                        <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity" />
                                    </div>
                                    <div class="px-2">
                                        <h3 class="text-xl font-bold text-primary-dark group-hover:text-primary transition-colors">
                                            {product.name}
                                        </h3>
                                        <p class="text-text-muted text-sm my-3 line-clamp-2 min-h-[40px]">
                                            {product.description}
                                        </p>
                                        <div class="flex items-center justify-between mt-6 pt-4 border-t border-primary/5">
                                            <strong class="text-primary text-xl font-fraunces">
                                                Rp{" "}
                                                {Number(
                                                    product.price,
                                                ).toLocaleString("id-ID")}
                                            </strong>
                                            <a
                                                href="/order"
                                                class="w-10 h-10 rounded-full bg-primary/10 text-primary flex items-center justify-center transition-all hover:bg-primary hover:text-white"
                                                aria-label="Order"
                                            >
                                                <svg
                                                    xmlns="http://www.w3.org/2000/svg"
                                                    width="20"
                                                    height="20"
                                                    viewBox="0 0 24 24"
                                                    fill="none"
                                                    stroke="currentColor"
                                                    stroke-width="2.5"
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                >
                                                    <>
                                                        <path d="M5 12h14" />
                                                        <path d="m12 5 7 7-7 7" />
                                                    </>
                                                </svg>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            );
                        })
                    }
                </div>
            </div>
        </section>
    </main>
</Layout>
