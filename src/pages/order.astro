---
import { desc, eq } from "drizzle-orm";
import OrderApp from "@components/storefront/OrderApp.svelte";
import { products as productsTable } from "@db/schema";
import AppLayout from "@layouts/AppLayout.astro";
import { getDrizzle } from "@lib/db";
import { getEnv } from "@lib/env";

const db = getDrizzle(Astro);
const rows = await db
  .select({
    id: productsTable.id,
    name: productsTable.name,
    price: productsTable.price,
    imagesJson: productsTable.imagesJson,
    description: productsTable.description,
    stock: productsTable.stock,
  })
  .from(productsTable)
  .where(eq(productsTable.isActive, 1))
  .orderBy(desc(productsTable.createdAt));

const products = rows.map((row) => {
  let image = "";
  try {
    const urls = JSON.parse(String(row.imagesJson || "[]"));
    image = Array.isArray(urls) ? urls[0] : "";
  } catch {
    image = "";
  }
  return {
    id: row.id,
    name: row.name,
    price: row.price,
    description: row.description || "",
    image,
    stock: row.stock ?? 0,
  };
});

const env = getEnv(Astro);
---

<AppLayout title="Pesan Roti Sholawat" description="Pesan online Roti Sholawat cepat dan mudah">
  <OrderApp products={products} env={env} client:load />
</AppLayout>
