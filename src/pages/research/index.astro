---
import "../../styles/global.css";
import VersionNav from "../../components/research/VersionNav.astro";
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Research Hub - Versions</title>
  </head>
  <body class="text-text min-h-screen bg-[var(--color-bg)]">
    <main class="container py-10">
      <div class="mb-6">
        <p class="text-text-muted text-sm tracking-[0.3em] uppercase">Research Versions</p>
        <h1 class="font-fraunces text-primary-dark text-3xl">Versioning Playground</h1>
        <p class="text-text-muted mt-2 max-w-2xl">
          Kumpulan variasi desain admin PWA untuk dibandingkan. Silakan buka tiap versi dan pilih yang paling cocok.
        </p>
      </div>

      <VersionNav active="index" />

      <section class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <a
          class="border-primary/10 rounded-2xl border bg-white/80 p-5 shadow-sm transition hover:shadow-md"
          href="/research/v0"
        >
          <h2 class="text-lg font-semibold">V0 Minimal Flow</h2>
          <p class="text-text-muted mt-2 text-sm">Struktur dasar, ringan, dan fokus konten.</p>
        </a>
        <a
          class="border-primary/10 rounded-2xl border bg-white/80 p-5 shadow-sm transition hover:shadow-md"
          href="/research/v1"
        >
          <h2 class="text-lg font-semibold">V1 Premium Warm</h2>
          <p class="text-text-muted mt-2 text-sm">Nuansa hangat premium, PWA card feel.</p>
        </a>
        <a
          class="border-primary/10 rounded-2xl border bg-white/80 p-5 shadow-sm transition hover:shadow-md"
          href="/research/v2"
        >
          <h2 class="text-lg font-semibold">V2 Editorial Lab</h2>
          <p class="text-text-muted mt-2 text-sm">Editorial modern untuk insight dan eksperimen.</p>
        </a>
        <a
          class="border-primary/10 rounded-2xl border bg-white/80 p-5 shadow-sm transition hover:shadow-md"
          href="/research/v3"
        >
          <h2 class="text-lg font-semibold">V3 Native App</h2>
          <p class="text-text-muted mt-2 text-sm">Native feel dengan nav bawah dan motion.</p>
        </a>
      </section>
    </main>
  </body>
</html>
