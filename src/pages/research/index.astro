---
import "../../styles/global.css";
import VersionNav from "../../components/research/VersionNav.astro";
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Research Hub - Versions</title>
  </head>
  <body class="min-h-screen bg-[var(--color-bg)] text-text">
    <main class="container py-10">
      <div class="mb-6">
        <p class="text-sm uppercase tracking-[0.3em] text-text-muted">Research Versions</p>
        <h1 class="text-3xl font-fraunces text-primary-dark">Versioning Playground</h1>
        <p class="mt-2 text-text-muted max-w-2xl">
          Kumpulan variasi desain admin PWA untuk dibandingkan. Silakan buka tiap versi dan pilih
          yang paling cocok.
        </p>
      </div>

      <VersionNav active="index" />

      <section class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <a class="rounded-2xl border border-primary/10 bg-white/80 p-5 shadow-sm hover:shadow-md transition" href="/research/v0">
          <h2 class="text-lg font-semibold">V0 Minimal Flow</h2>
          <p class="text-sm text-text-muted mt-2">Struktur dasar, ringan, dan fokus konten.</p>
        </a>
        <a class="rounded-2xl border border-primary/10 bg-white/80 p-5 shadow-sm hover:shadow-md transition" href="/research/v1">
          <h2 class="text-lg font-semibold">V1 Premium Warm</h2>
          <p class="text-sm text-text-muted mt-2">Nuansa hangat premium, PWA card feel.</p>
        </a>
        <a class="rounded-2xl border border-primary/10 bg-white/80 p-5 shadow-sm hover:shadow-md transition" href="/research/v2">
          <h2 class="text-lg font-semibold">V2 Editorial Lab</h2>
          <p class="text-sm text-text-muted mt-2">Editorial modern untuk insight dan eksperimen.</p>
        </a>
        <a class="rounded-2xl border border-primary/10 bg-white/80 p-5 shadow-sm hover:shadow-md transition" href="/research/v3">
          <h2 class="text-lg font-semibold">V3 Native App</h2>
          <p class="text-sm text-text-muted mt-2">Native feel dengan nav bawah dan motion.</p>
        </a>
      </section>
    </main>
  </body>
</html>
