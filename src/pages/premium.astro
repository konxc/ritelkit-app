---
import Layout from "../layouts/Layout.astro";

const gofoodLink =
  "https://gofood.co.id/yogyakarta/restaurant/sholawat-premium-tajem-9b9eac23-7814-4106-bc37-fc18644a6289";
const waPrimary =
  "https://wa.me/6281314537475?text=Halo%20Roti%20Sholawat%20Premium%2C%20saya%20ingin%20konsultasi%20paket%20premium.";
const waSecondary =
  "https://wa.me/6285100292711?text=Halo%20Roti%20Sholawat%20Premium%2C%20saya%20ingin%20informasi%20menu%20dan%20promo.";
const igLink = "https://www.instagram.com/rotisholawat/";
const tiktokLink = "https://www.tiktok.com/@rotisholawat/video/7330461279418584326";
---

<Layout
    title="Roti Sholawat Premium — Tajem"
    description="Roti Sholawat Premium Tajem di GoFood. Roti premium untuk momen spesial."
>
    <main class="text-[#3a2416] bg-[#fff9f2]">
        <section
            class="relative overflow-hidden pt-[120px] pb-20 bg-[radial-gradient(circle_at_top,#fff6e8,40%,#f7efe6)]"
        >
            <div
                class="absolute w-[260px] h-[260px] rounded-full right-[-80px] top-10 bg-[radial-gradient(circle,rgba(242,178,77,0.4),transparent_70%)] opacity-60 animate-premium-float-slow pointer-events-none"
            >
            </div>
            <div
                class="container grid grid-cols-[repeat(auto-fit,minmax(260px,1fr))] gap-8 items-center relative z-1"
            >
                <div>
                    <div
                        class="inline-flex px-3.5 py-1.5 rounded-full bg-[#f2b24d]/20 font-semibold mb-4 shadow-[0_10px_20px_rgba(156,107,67,0.12)]"
                    >
                        Sholawat Premium • Tajem
                    </div>
                    <h1
                        class="text-4xl md:text-5xl font-fraunces text-[#5f3b1c] mb-4"
                    >
                        Roti Sholawat Premium
                    </h1>
                    <p
                        class="text-[1.1rem] text-text-muted mb-6 leading-relaxed"
                    >
                        Roti premium untuk momen spesial. Rasa lebih kaya,
                        kemasan lebih rapi, cocok untuk hadiah, acara keluarga,
                        dan kebersamaan komunitas.
                    </p>
                    <div class="flex flex-wrap gap-3 mb-4">
                        <a
                            class="btn bg-[#9c6b43] text-white rounded-full px-6 py-3 font-semibold shadow-[0_12px_26px_rgba(156,107,67,0.22)] transition-all hover:-translate-y-0.5"
                            href={gofoodLink}
                            target="_blank">Pesan di GoFood</a
                        >
                        <a
                            class="btn bg-transparent border-2 border-[#9c6b43] text-[#9c6b43] rounded-full px-6 py-3 font-bold transition-all hover:-translate-y-0.5 hover:bg-[#9c6b43] hover:text-white hover:shadow-lg"
                            href={waPrimary}
                            target="_blank">Chat Premium</a
                        >
                    </div>
                    <div class="flex gap-4 mt-3 font-semibold">
                        <a
                            href={igLink}
                            target="_blank"
                            class="text-[#5f3b1c] underline underline-offset-4"
                            >Instagram</a
                        >
                        <a
                            href={tiktokLink}
                            target="_blank"
                            class="text-[#5f3b1c] underline underline-offset-4"
                            >TikTok</a
                        >
                    </div>
                </div>
                <div
                    class="bg-white rounded-[22px] shadow-[0_24px_50px_rgba(0,0,0,0.12)] overflow-hidden -rotate-1 animate-premium-float transition-all hover:-translate-y-1.5 hover:-rotate-1 hover:shadow-[0_30px_64px_rgba(0,0,0,0.18)]"
                >
                    <div class="hero-photo">
                        <img
                            src="/images/bakery/sholawat bakery (10).jpeg"
                            alt="Roti Sholawat Premium"
                            class="w-full h-[260px] object-cover"
                        />
                    </div>
                    <div class="p-4">
                        <strong class="text-[#5f3b1c]">Signature Premium</strong
                        >
                        <p class="text-text-muted text-sm mt-1">
                            Varian terbaik dengan kualitas lebih tinggi.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <section class="section reveal">
            <div class="container">
                <div class="section-head text-center mx-auto max-w-[640px]">
                    <h2>Kenapa Premium?</h2>
                    <p>
                        Didesain untuk pelanggan yang ingin rasa lebih kaya,
                        presentasi lebih elegan, dan pengalaman yang lebih
                        berkesan.
                    </p>
                </div>
                <div
                    class="grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-[18px]"
                >
                    <div
                        class="bg-white rounded-[18px] p-[18px] border border-[#eadfd3] transition-all hover:-translate-y-1.5 hover:shadow-[0_16px_30px_rgba(0,0,0,0.08)]"
                    >
                        <h3 class="text-[#5f3b1c]">Rasa Lebih Kaya</h3>
                        <p class="text-text-muted mt-2">
                            Komposisi bahan lebih premium dan konsisten.
                        </p>
                    </div>
                    <div
                        class="bg-white rounded-[18px] p-[18px] border border-[#eadfd3] transition-all hover:-translate-y-1.5 hover:shadow-[0_16px_30px_rgba(0,0,0,0.08)]"
                    >
                        <h3 class="text-[#5f3b1c]">Packaging Lebih Rapi</h3>
                        <p class="text-text-muted mt-2">
                            Cocok untuk hadiah dan acara resmi.
                        </p>
                    </div>
                    <div
                        class="bg-white rounded-[18px] p-[18px] border border-[#eadfd3] transition-all hover:-translate-y-1.5 hover:shadow-[0_16px_30px_rgba(0,0,0,0.08)]"
                    >
                        <h3 class="text-[#5f3b1c]">Siap Acara Spesial</h3>
                        <p class="text-text-muted mt-2">
                            Ideal untuk momen silaturahmi dan kebersamaan.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <section class="section section-alt reveal">
            <div class="container">
                <div class="section-head text-center mx-auto max-w-[640px]">
                    <h2>Menu Premium (GoFood)</h2>
                    <p>
                        Menu lengkap tersedia di GoFood. Klik tombol di bawah
                        untuk melihat detail varian dan harga.
                    </p>
                </div>
                <div
                    class="grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-[18px]"
                >
                    <div
                        class="bg-white rounded-[18px] p-5 border border-[#eadfd3] transition-all hover:-translate-y-1.5 hover:shadow-[0_18px_34px_rgba(0,0,0,0.08)]"
                    >
                        <strong class="text-[#5f3b1c]">Varian Premium</strong>
                        <p class="text-text-muted text-sm mt-1">
                            Daftar varian roti premium pilihan.
                        </p>
                    </div>
                    <div
                        class="bg-white rounded-[18px] p-5 border border-[#eadfd3] transition-all hover:-translate-y-1.5 hover:shadow-[0_18px_34px_rgba(0,0,0,0.08)]"
                    >
                        <strong class="text-[#5f3b1c]">Paket Spesial</strong>
                        <p class="text-text-muted text-sm mt-1">
                            Paket untuk hadiah dan acara keluarga.
                        </p>
                    </div>
                    <div
                        class="bg-white rounded-[18px] p-5 border border-[#eadfd3] transition-all hover:-translate-y-1.5 hover:shadow-[0_18px_34px_rgba(0,0,0,0.08)]"
                    >
                        <strong class="text-[#5f3b1c]">Signature Series</strong>
                        <p class="text-text-muted text-sm mt-1">
                            Produk signature dengan rasa khas.
                        </p>
                    </div>
                </div>
                <div class="flex justify-center mt-10">
                    <a
                        class="btn bg-[#9c6b43] text-white rounded-full px-8 py-3.5 font-bold shadow-[0_12px_26px_rgba(156,107,67,0.22)] transition-all hover:-translate-y-0.5"
                        href={gofoodLink}
                        target="_blank">Lihat Menu di GoFood</a
                    >
                </div>
            </div>
        </section>

        <section class="section reveal">
            <div
                class="container grid grid-cols-[repeat(auto-fit,minmax(260px,1fr))] gap-5 items-center"
            >
                <div>
                    <h2>Lokasi & Layanan</h2>
                    <p
                        class="text-[1.1rem] text-text-muted mt-4 mb-6 leading-relaxed"
                    >
                        Roti Sholawat Premium Tajem melayani area Yogyakarta.
                        Untuk informasi jam operasional dan promo terbaru,
                        silakan cek GoFood.
                    </p>
                    <div class="flex flex-wrap gap-3">
                        <a
                            class="btn bg-[#f2b24d] text-[#5f3b1c] rounded-full px-6 py-3 font-semibold transition-all hover:-translate-y-0.5 shadow-md"
                            href={gofoodLink}
                            target="_blank">Buka GoFood</a
                        >
                        <a
                            class="btn bg-transparent border-2 border-[#9c6b43] text-[#9c6b43] rounded-full px-6 py-3 font-bold transition-all hover:-translate-y-0.5 hover:bg-[#9c6b43] hover:text-white hover:shadow-lg"
                            href={waSecondary}
                            target="_blank">Tanya Promo</a
                        >
                    </div>
                </div>
                <div
                    class="bg-white rounded-[18px] p-5 border border-[#eadfd3] shadow-[0_12px_24px_rgba(0,0,0,0.06)]"
                >
                    <h3 class="text-[#5f3b1c] mb-3">Kontak & Info</h3>
                    <ul class="list-disc pl-5 text-text-muted space-y-2">
                        <li>WA 1: 0813-1453-7475</li>
                        <li>WA 2: 0851-0029-2711</li>
                        <li>Menu & promo terbaru tersedia di GoFood.</li>
                    </ul>
                </div>
            </div>
        </section>

        <section class="section pb-[120px] reveal">
            <div
                class="container bg-gradient-to-br from-[#9c6b43] to-[#5f3b1c] text-white p-8 rounded-3xl text-center shadow-[0_24px_50px_rgba(0,0,0,0.22)]"
            >
                <h2 class="text-white">Siap mencicipi Premium?</h2>
                <p class="text-white/85 mb-8">
                    Pesan langsung lewat GoFood atau konsultasi paket spesial.
                </p>
                <div class="flex flex-wrap justify-center gap-4">
                    <a
                        class="btn bg-white text-[#5f3b1c] rounded-full px-6 py-3 font-bold transition-all hover:-translate-y-0.5 shadow-lg"
                        href={gofoodLink}
                        target="_blank">Pesan di GoFood</a
                    >
                    <a
                        class="btn border-white/40 text-white rounded-full px-6 py-3 font-semibold transition-all hover:-translate-y-0.5 bg-white/10"
                        href={waPrimary}
                        target="_blank">Konsultasi Premium</a
                    >
                </div>
            </div>
        </section>
    </main>
</Layout>
