---
import Layout from "@/layouts/Layout.astro";

const gofoodLink =
  "https://gofood.co.id/yogyakarta/restaurant/sholawat-premium-tajem-9b9eac23-7814-4106-bc37-fc18644a6289";
const waPrimary =
  "https://wa.me/6281314537475?text=Halo%20Roti%20Sholawat%20Premium%2C%20saya%20ingin%20konsultasi%20paket%20premium.";
const waSecondary =
  "https://wa.me/6285100292711?text=Halo%20Roti%20Sholawat%20Premium%2C%20saya%20ingin%20informasi%20menu%20dan%20promo.";
const igLink = "https://www.instagram.com/rotisholawat/";
const tiktokLink = "https://www.tiktok.com/@rotisholawat/video/7330461279418584326";
---

<Layout
  title="Roti Sholawat Premium — Tajem"
  description="Roti Sholawat Premium Tajem di GoFood. Roti premium untuk momen spesial."
>
  <main class="bg-[#fff9f2] text-[#3a2416]">
    <section class="relative overflow-hidden bg-[radial-gradient(circle_at_top,#fff6e8,40%,#f7efe6)] pt-[120px] pb-20">
      <div
        class="animate-premium-float-slow pointer-events-none absolute top-10 right-[-80px] h-[260px] w-[260px] rounded-full bg-[radial-gradient(circle,rgba(242,178,77,0.4),transparent_70%)] opacity-60"
      >
      </div>
      <div class="relative z-1 container grid grid-cols-[repeat(auto-fit,minmax(260px,1fr))] items-center gap-8">
        <div>
          <div
            class="mb-4 inline-flex rounded-full bg-[#f2b24d]/20 px-3.5 py-1.5 font-semibold shadow-[0_10px_20px_rgba(156,107,67,0.12)]"
          >
            Sholawat Premium • Tajem
          </div>
          <h1 class="font-fraunces mb-4 text-4xl text-[#5f3b1c] md:text-5xl">Roti Sholawat Premium</h1>
          <p class="text-text-muted mb-6 text-[1.1rem] leading-relaxed">
            Roti premium untuk momen spesial. Rasa lebih kaya, kemasan lebih rapi, cocok untuk hadiah, acara keluarga,
            dan kebersamaan komunitas.
          </p>
          <div class="mb-4 flex flex-wrap gap-3">
            <a
              class="btn rounded-full bg-[#9c6b43] px-6 py-3 font-semibold text-white shadow-[0_12px_26px_rgba(156,107,67,0.22)] transition-all hover:-translate-y-0.5"
              href={gofoodLink}
              target="_blank">Pesan di GoFood</a
            >
            <a
              class="btn rounded-full border-2 border-[#9c6b43] bg-transparent px-6 py-3 font-bold text-[#9c6b43] transition-all hover:-translate-y-0.5 hover:bg-[#9c6b43] hover:text-white hover:shadow-lg"
              href={waPrimary}
              target="_blank">Chat Khusus</a
            >
          </div>
          <div class="mt-3 flex gap-4 font-semibold">
            <a href={igLink} target="_blank" class="text-[#5f3b1c] underline underline-offset-4">Instagram</a>
            <a href={tiktokLink} target="_blank" class="text-[#5f3b1c] underline underline-offset-4">TikTok</a>
          </div>
        </div>
        <div
          class="animate-premium-float -rotate-1 overflow-hidden rounded-[22px] bg-white shadow-[0_24px_50px_rgba(0,0,0,0.12)] transition-all hover:-translate-y-1.5 hover:-rotate-1 hover:shadow-[0_30px_64px_rgba(0,0,0,0.18)]"
        >
          <div class="hero-photo">
            <img
              src="/images/bakery/sholawat bakery (10).jpeg"
              alt="Roti Sholawat Premium"
              class="h-[260px] w-full object-cover"
            />
          </div>
          <div class="p-4">
            <strong class="text-[#5f3b1c]">Signature Unggulan</strong>
            <p class="text-text-muted mt-1 text-sm">Varian terbaik dengan kualitas lebih tinggi.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section reveal">
      <div class="container">
        <div class="section-head mx-auto max-w-[640px] text-center">
          <h2>Kenapa Premium?</h2>
          <p>
            Didesain untuk pelanggan yang ingin rasa lebih kaya, presentasi lebih elegan, dan pengalaman yang lebih
            berkesan.
          </p>
        </div>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-[18px]">
          <div
            class="rounded-[18px] border border-[#eadfd3] bg-white p-[18px] transition-all hover:-translate-y-1.5 hover:shadow-[0_16px_30px_rgba(0,0,0,0.08)]"
          >
            <h3 class="text-[#5f3b1c]">Rasa Lebih Kaya</h3>
            <p class="text-text-muted mt-2">Komposisi bahan lebih premium dan konsisten.</p>
          </div>
          <div
            class="rounded-[18px] border border-[#eadfd3] bg-white p-[18px] transition-all hover:-translate-y-1.5 hover:shadow-[0_16px_30px_rgba(0,0,0,0.08)]"
          >
            <h3 class="text-[#5f3b1c]">Packaging Lebih Rapi</h3>
            <p class="text-text-muted mt-2">Cocok untuk hadiah dan acara resmi.</p>
          </div>
          <div
            class="rounded-[18px] border border-[#eadfd3] bg-white p-[18px] transition-all hover:-translate-y-1.5 hover:shadow-[0_16px_30px_rgba(0,0,0,0.08)]"
          >
            <h3 class="text-[#5f3b1c]">Siap Acara Spesial</h3>
            <p class="text-text-muted mt-2">Ideal untuk momen silaturahmi dan kebersamaan.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-alt reveal">
      <div class="container">
        <div class="section-head mx-auto max-w-[640px] text-center">
          <h2>Menu Premium (GoFood)</h2>
          <p>Menu lengkap tersedia di GoFood. Klik tombol di bawah untuk melihat detail varian dan harga.</p>
        </div>
        <div class="grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-[18px]">
          <div
            class="rounded-[18px] border border-[#eadfd3] bg-white p-5 transition-all hover:-translate-y-1.5 hover:shadow-[0_18px_34px_rgba(0,0,0,0.08)]"
          >
            <strong class="text-[#5f3b1c]">Varian Premium</strong>
            <p class="text-text-muted mt-1 text-sm">Daftar varian roti premium pilihan.</p>
          </div>
          <div
            class="rounded-[18px] border border-[#eadfd3] bg-white p-5 transition-all hover:-translate-y-1.5 hover:shadow-[0_18px_34px_rgba(0,0,0,0.08)]"
          >
            <strong class="text-[#5f3b1c]">Paket Spesial</strong>
            <p class="text-text-muted mt-1 text-sm">Paket untuk hadiah dan acara keluarga.</p>
          </div>
          <div
            class="rounded-[18px] border border-[#eadfd3] bg-white p-5 transition-all hover:-translate-y-1.5 hover:shadow-[0_18px_34px_rgba(0,0,0,0.08)]"
          >
            <strong class="text-[#5f3b1c]">Seri Unggulan</strong>
            <p class="text-text-muted mt-1 text-sm">Produk signature dengan rasa khas.</p>
          </div>
        </div>
        <div class="mt-10 flex justify-center">
          <a
            class="btn rounded-full bg-[#9c6b43] px-8 py-3.5 font-bold text-white shadow-[0_12px_26px_rgba(156,107,67,0.22)] transition-all hover:-translate-y-0.5"
            href={gofoodLink}
            target="_blank">Lihat Menu di GoFood</a
          >
        </div>
      </div>
    </section>

    <section class="section reveal">
      <div class="container grid grid-cols-[repeat(auto-fit,minmax(260px,1fr))] items-center gap-5">
        <div>
          <h2>Lokasi & Layanan</h2>
          <p class="text-text-muted mt-4 mb-6 text-[1.1rem] leading-relaxed">
            Roti Sholawat Premium Tajem melayani area Yogyakarta. Untuk informasi jam operasional dan promo terbaru,
            silakan cek GoFood.
          </p>
          <div class="flex flex-wrap gap-3">
            <a
              class="btn rounded-full bg-[#f2b24d] px-6 py-3 font-semibold text-[#5f3b1c] shadow-md transition-all hover:-translate-y-0.5"
              href={gofoodLink}
              target="_blank">Buka GoFood</a
            >
            <a
              class="btn rounded-full border-2 border-[#9c6b43] bg-transparent px-6 py-3 font-bold text-[#9c6b43] transition-all hover:-translate-y-0.5 hover:bg-[#9c6b43] hover:text-white hover:shadow-lg"
              href={waSecondary}
              target="_blank">Tanya Promo</a
            >
          </div>
        </div>
        <div class="rounded-[18px] border border-[#eadfd3] bg-white p-5 shadow-[0_12px_24px_rgba(0,0,0,0.06)]">
          <h3 class="mb-3 text-[#5f3b1c]">Kontak & Informasi</h3>
          <ul class="text-text-muted list-disc space-y-2 pl-5">
            <li>WA 1: 0813-1453-7475</li>
            <li>WA 2: 0851-0029-2711</li>
            <li>Menu & promo terbaru tersedia di GoFood.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="section reveal pb-[120px]">
      <div
        class="container rounded-3xl bg-gradient-to-br from-[#9c6b43] to-[#5f3b1c] p-8 text-center text-white shadow-[0_24px_50px_rgba(0,0,0,0.22)]"
      >
        <h2 class="text-white">Siap mencicipi Premium?</h2>
        <p class="mb-8 text-white/85">Pesan langsung lewat GoFood atau konsultasi paket spesial.</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            class="btn rounded-full bg-white px-6 py-3 font-bold text-[#5f3b1c] shadow-lg transition-all hover:-translate-y-0.5"
            href={gofoodLink}
            target="_blank">Pesan di GoFood</a
          >
          <a
            class="btn rounded-full border-white/40 bg-white/10 px-6 py-3 font-semibold text-white transition-all hover:-translate-y-0.5"
            href={waPrimary}
            target="_blank">Konsultasi Premium</a
          >
        </div>
      </div>
    </section>
  </main>
</Layout>
