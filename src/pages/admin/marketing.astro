---
import { actions } from "astro:actions";
import AdminTabs from "../../components/admin/AdminTabs.astro";
import PemasaranTabContent from "../../components/admin/pages/PemasaranTabContent.svelte";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { normalizeTab, parsePage } from "../../lib/admin";
import { requireAdmin } from "../../lib/auth";
import { initDb } from "../../lib/db";
import { appRouter } from "../../server/router";
import { createContext } from "../../server/context";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
  return Astro.redirect("/admin/login");
}

const TAB_IDS = ["customers", "coupons", "ads"] as const;

const rawTab = Astro.url.searchParams.get("tab");

const tab = normalizeTab(rawTab, {
  allowed: TAB_IDS,
  defaultTab: "customers",
  aliases: {
    customer: "customers",
    coupon: "coupons",
    ad: "ads",
  },
});

if (rawTab && rawTab !== tab) {
  const canonicalUrl = new URL(Astro.url);
  canonicalUrl.searchParams.set("tab", tab);
  return Astro.redirect(canonicalUrl.pathname + canonicalUrl.search);
}
const { page, q, offset, limit } = parsePage(Astro.url, 20);

const trpc = appRouter.createCaller(await createContext(Astro as any));

// Data for Tabs
let initialData: any = null;

if (tab === "customers") {
  const result = await Astro.callAction(actions.listCustomers, {
    q,
    limit,
    offset,
  });
  if (result.data) {
    initialData = result.data;
  }
} else if (tab === "coupons") {
  const result = await trpc.coupons.list({ q, limit, offset });
  if (result) {
    initialData = result;
  }
} else if (tab === "ads") {
  const result = await trpc.ads.list({ q, limit, offset });
  if (result) {
    initialData = result;
  }
}

const tabs = [
  {
    id: "customers",
    label: "customers.title_list",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>',
  },
  {
    id: "coupons",
    label: "coupons.title_list",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 20a4 4 0 0 0 4-4V8a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v8a4 4 0 0 0 4 4h12Z"/><path d="M2 12h20"/><path d="M6 12v.01"/><path d="M10 12v.01"/><path d="M14 12v.01"/><path d="M18 12v.01"/></svg>',
  },
  {
    id: "ads",
    label: "ads.title_list",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="12" x="3" y="6" rx="2" ry="2"/><path d="M3 10h18"/><path d="M7 6v12"/><path d="M15 13h.01"/></svg>',
  },
];
const statusFilter = Astro.url.searchParams.get("status");
import { getLang, type LanguageCode, tServer } from "../../lib/i18n/server";
import AdminToolbar from "../../components/admin/AdminToolbar.svelte";
import AdminHeaderFilters from "../../components/admin/AdminHeaderFilters.svelte";
const lang: LanguageCode = getLang(Astro.cookies);
---

<AdminLayout title={tServer(lang, "nav.marketing")}>
  <div slot="header-tabs">
    <AdminTabs tabs={tabs} activeTab={tab} {lang} />
  </div>

  <AdminToolbar
    title={tServer(lang, "common.filter")}
    class="sticky top-0 z-20 sm:top-2 md:top-4 lg:hidden"
    showMobileFloat={true}
    client:load
  >
    <AdminHeaderFilters tab={tab} q={q} status={statusFilter || ""} lang={lang} client:load />
  </AdminToolbar>

  <PemasaranTabContent {tab} {q} status={statusFilter || ""} {page} {limit} {initialData} {lang} client:load />
</AdminLayout>
