---
import "../../styles/global.css";
import { actions } from "astro:actions";
import { ensureCsrfToken, getAdminSession } from "@lib/auth";
import { getDb, initDb } from "@lib/db";
import { getEnv } from "@lib/env";

await initDb(Astro);
const db = getDb(Astro);
const result = await db.execute("SELECT COUNT(*) as count FROM admin_users");
const adminCount = Number(result.rows[0]?.count || 0);
if (adminCount === 0) {
  return Astro.redirect("/admin/setup");
}
const session = await getAdminSession(Astro);
if (session) {
  return Astro.redirect("/admin");
}

const call = Astro.getActionResult(actions.adminLogin);
if (call?.data) {
  return Astro.redirect("/admin");
}

const env = getEnv(Astro);
const csrfToken = ensureCsrfToken(Astro);
const info = Astro.url.searchParams.get("info");
const error = call?.error?.message || Astro.url.searchParams.get("error");
const success = Astro.url.searchParams.get("success");
import { getLang, tServer } from "@lib/i18n/server";
const lang = getLang(Astro.cookies);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{tServer(lang, "auth.login_title")}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Syne:wght@700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      body { min-height: 100dvh; background: none; font-family: 'Outfit', sans-serif; }
      /* Reset global styles bleeding from global.css */
      h1, h2, h3, h4 { font-family: 'Syne', sans-serif; color: inherit; font-size: inherit; line-height: inherit; }
      a { text-decoration: none; color: inherit; }
      input:-webkit-autofill,
      input:-webkit-autofill:hover,
      input:-webkit-autofill:focus {
        -webkit-box-shadow: 0 0 0 30px #faf9f6 inset !important;
        -webkit-text-fill-color: #292524 !important;
      }
    </style>
  </head>
  <body class="flex min-h-[100dvh] items-center justify-center bg-[#f5f3ef] px-4 font-['Outfit',sans-serif]">

    <!-- Background decoration -->
    <div class="pointer-events-none fixed inset-0 overflow-hidden">
      <div class="absolute -top-32 -right-32 h-[420px] w-[420px] rounded-full bg-[#c48a3a]/6 blur-3xl"></div>
      <div class="absolute -bottom-32 -left-32 h-[380px] w-[380px] rounded-full bg-[#c48a3a]/4 blur-3xl"></div>
    </div>

    <div class="relative w-full max-w-[400px]">

      <!-- Logo / Brand -->
      <div class="mb-8 flex flex-col items-center gap-3 text-center">
        <a
          href="/"
          class="inline-flex items-center gap-2.5 font-['Syne',sans-serif] text-[1.15rem] font-extrabold tracking-tight text-stone-900 no-underline before:block before:h-[16px] before:w-[16px] before:shrink-0 before:rotate-45 before:rounded-[4px] before:bg-[#c48a3a] before:content-['']"
        >
          SHOLAWAT<span class="text-[#c48a3a]">.ENT</span>
        </a>
        <p class="text-[0.78rem] font-semibold tracking-widest text-stone-400 uppercase">
          Admin Portal
        </p>
      </div>

      <!-- Card -->
      <div class="rounded-3xl border border-stone-200/70 bg-white/90 p-8 shadow-[0_20px_50px_rgba(0,0,0,0.07)] backdrop-blur-sm">

        <div class="mb-7">
          <h1 class="mb-1 font-['Syne',sans-serif] text-[1.5rem] font-extrabold tracking-tight text-stone-900">
            {tServer(lang, "auth.login_title")}
          </h1>
          <p class="text-[0.82rem] text-stone-400">
            {tServer(lang, "auth.email_label")} &amp; {tServer(lang, "auth.password_label").toLowerCase()}
          </p>
        </div>

        <!-- Alerts -->
        {success === "1" && (
          <div class="mb-5 flex items-center gap-2.5 rounded-xl bg-emerald-50 px-4 py-3 text-[0.85rem] text-emerald-700 border border-emerald-100">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <span>{tServer(lang, "auth.login_success")}</span>
          </div>
        )}
        {info === "exists" && (
          <div class="mb-5 flex items-center gap-2.5 rounded-xl bg-blue-50 px-4 py-3 text-[0.85rem] text-blue-700 border border-blue-100">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span>{tServer(lang, "auth.login_exists")}</span>
          </div>
        )}
        {error && (
          <div class="mb-5 flex items-center gap-2.5 rounded-xl bg-red-50 px-4 py-3 text-[0.85rem] text-red-600 border border-red-100">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            <span>
              {error === "invalid"
                ? tServer(lang, "auth.error_invalid")
                : error === "rate"
                  ? tServer(lang, "auth.error_rate")
                  : error === "csrf"
                    ? tServer(lang, "auth.error_csrf")
                    : error}
            </span>
          </div>
        )}

        <!-- Form -->
        <form method="post" action={actions.adminLogin} class="flex flex-col gap-4">
          <input type="hidden" name="csrf_token" value={csrfToken} />

          <div class="flex flex-col gap-1.5">
            <label class="text-[0.8rem] font-semibold tracking-wide text-stone-600" for="email">
              {tServer(lang, "auth.email_label")}
            </label>
            <input
              class="w-full rounded-xl border border-stone-200 bg-[#faf9f6] px-4 py-3 text-[0.9rem] text-stone-900 outline-none ring-0 transition-all placeholder:text-stone-300 focus:border-[#c48a3a]/60 focus:ring-2 focus:ring-[#c48a3a]/15"
              name="email"
              id="email"
              type="email"
              required
              placeholder="admin@sholawat.com"
            />
          </div>

          <div class="flex flex-col gap-1.5">
            <label class="text-[0.8rem] font-semibold tracking-wide text-stone-600" for="password">
              {tServer(lang, "auth.password_label")}
            </label>
            <input
              class="w-full rounded-xl border border-stone-200 bg-[#faf9f6] px-4 py-3 text-[0.9rem] text-stone-900 outline-none ring-0 transition-all placeholder:text-stone-300 focus:border-[#c48a3a]/60 focus:ring-2 focus:ring-[#c48a3a]/15"
              name="password"
              id="password"
              type="password"
              required
              placeholder="••••••••••"
            />
          </div>

          <button
            class="mt-2 w-full cursor-pointer rounded-xl border-none bg-gradient-to-r from-[#c48a3a] to-[#a6722d] py-3.5 text-[0.93rem] font-semibold text-white shadow-[0_8px_20px_rgba(196,138,58,0.3)] transition-all hover:-translate-y-[1px] hover:shadow-[0_12px_24px_rgba(196,138,58,0.35)] active:translate-y-0"
            type="submit"
          >
            {tServer(lang, "auth.login_button")}
          </button>
        </form>

        <!-- Setup token info -->
        {env.SETUP_TOKEN && (
          <p class="mt-5 text-center text-[0.75rem] text-stone-400">
            {tServer(lang, "auth.token_label")} {tServer(lang, "auth.token_available")}.
          </p>
        )}
      </div>

      <!-- Footer -->
      <p class="mt-6 text-center text-[0.73rem] text-stone-400">
        &copy; {new Date().getFullYear()} Sholawat.ENT — Admin Portal
      </p>
    </div>
  </body>
</html>
