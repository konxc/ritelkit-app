---
import "../../styles/global.css";
import { initDb, getDb } from "../../lib/db";
import { getEnv } from "../../lib/env";
import { ensureCsrfToken, getAdminSession } from "../../lib/auth";
await initDb(Astro);
const db = getDb(Astro);
const result = await db.execute("SELECT COUNT(*) as count FROM admin_users");
const adminCount = Number(result.rows[0]?.count || 0);
if (adminCount === 0) {
    return Astro.redirect("/admin/setup");
}
const session = await getAdminSession(Astro);
if (session) {
    return Astro.redirect("/admin/overview");
}
const env = getEnv(Astro);
const csrfToken = ensureCsrfToken(Astro);
const info = Astro.url.searchParams.get("info");
const error = Astro.url.searchParams.get("error");
const success = Astro.url.searchParams.get("success");
---

<!doctype html>
<html lang="id">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <title>Login Admin</title>
    </head>
    <body class="m-0 bg-[#f6f4ef] font-['Outfit',sans-serif]">
        <div
            class="mx-auto mt-[8vh] max-w-[420px] rounded-2xl bg-white p-8 shadow-[0_20px_40px_rgba(0,0,0,0.08)]"
        >
            <h1>Login Admin</h1>
            {
                success === "1" && (
                    <p class="mt-4 text-[0.9rem] text-[#6b625a]">
                        Admin berhasil dibuat. Silakan login.
                    </p>
                )
            }
            {
                info === "exists" && (
                    <p class="mt-4 text-[0.9rem] text-[#6b625a]">
                        Admin sudah tersedia. Silakan login.
                    </p>
                )
            }
            {
                error === "invalid" && (
                    <p class="mt-4 text-[0.9rem] text-[#6b625a]">
                        Email atau password salah.
                    </p>
                )
            }
            {
                error === "rate" && (
                    <p class="mt-4 text-[0.9rem] text-[#6b625a]">
                        Terlalu banyak percobaan, coba lagi nanti.
                    </p>
                )
            }
            {
                error === "csrf" && (
                    <p class="mt-4 text-[0.9rem] text-[#6b625a]">
                        Sesi form kadaluarsa, refresh halaman.
                    </p>
                )
            }
            <form method="post" action="/api/admin/login">
                <input type="hidden" name="csrf_token" value={csrfToken} />
                <label>Email</label>
                <input
                    class="my-2 mb-4 w-full rounded-[10px] border border-[#e6dfd3] p-3"
                    name="email"
                    type="email"
                    required
                />
                <label>Password</label>
                <input
                    class="my-2 mb-4 w-full rounded-[10px] border border-[#e6dfd3] p-3"
                    name="password"
                    type="password"
                    required
                />
                <button
                    class="w-full cursor-pointer rounded-[10px] border-none bg-[#c48a3a] p-3 font-semibold text-white"
                    type="submit">Masuk</button
                >
            </form>
            <div class="mt-4 text-[0.9rem] text-[#6b625a]">
                Token setup: {env.SETUP_TOKEN ? "tersedia" : "belum diset"}.
            </div>
        </div>
    </body>
</html>
