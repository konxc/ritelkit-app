---
import { sql } from "drizzle-orm";
import OverviewApp from "../../components/admin/pages/OverviewApp.svelte";
import { adminUsers } from "../../db/schema";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/auth";
import { getDrizzle, initDb } from "../../lib/db";
import { getDashboardStats, getRecentOrders } from "../../lib/reports";

await initDb(Astro);
const admin = await requireAdmin(Astro);
const db = getDrizzle(Astro);

if (!admin) {
	const userCountResult = await db
		.select({ count: sql<number>`count(*)` })
		.from(adminUsers)
		.get();

	return Astro.redirect(
		Number(userCountResult?.count || 0) === 0 ? "/admin/setup" : "/admin/login",
	);
}

const stats = await getDashboardStats(db);
const recentOrders = await getRecentOrders(db, 5);
---

<AdminLayout title="Overview">
    <OverviewApp {stats} {recentOrders} client:load />
</AdminLayout>
