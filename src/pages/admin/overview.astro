---
import AdminLayout from "../../layouts/AdminLayout.astro";
import StatCard from "../../components/admin/StatCard.svelte";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect(
        Number(
            (await getDb(Astro).execute("SELECT COUNT(*) as count FROM admin_users"))
                .rows[0]?.count || 0,
        ) === 0
            ? "/admin/setup"
            : "/admin/login",
    );
}
const db = getDb(Astro);
const ordersToday = await db.execute(
    "SELECT COUNT(*) as count FROM orders WHERE date(created_at) = date('now')",
);
const revenueToday = await db.execute(
    "SELECT COALESCE(SUM(total),0) as total FROM orders WHERE date(created_at) = date('now')",
);
const activeCoupons = await db.execute(
    "SELECT COUNT(*) as count FROM coupons WHERE is_active = 1",
);
const activeProducts = await db.execute(
    "SELECT COUNT(*) as count FROM products WHERE is_active = 1",
);
const pendingShipments = await db.execute(
    "SELECT COUNT(*) as count FROM shipments WHERE status IN ('packing','shipped')",
);
const pendingRefunds = await db.execute(
    "SELECT COUNT(*) as count FROM refunds WHERE status = 'requested'",
);
---

<AdminLayout title="Overview">
    <div class="grid grid-2">
        <StatCard
            label="Order Hari Ini"
            value={(ordersToday.rows[0] as any)?.count || 0}
        />
        <StatCard
            label="Revenue Hari Ini"
            value={`Rp ${Number((revenueToday.rows[0] as any)?.total || 0).toLocaleString("id-ID")}`}
        />
        <StatCard
            label="Produk Aktif"
            value={(activeProducts.rows[0] as any)?.count || 0}
        />
        <StatCard
            label="Pengiriman Aktif"
            value={(pendingShipments.rows[0] as any)?.count || 0}
        />
        <StatCard
            label="Kupon Aktif"
            value={(activeCoupons.rows[0] as any)?.count || 0}
        />
        <StatCard
            label="Refund Pending"
            value={(pendingRefunds.rows[0] as any)?.count || 0}
        />
    </div>
</AdminLayout>
