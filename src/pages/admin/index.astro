---
import "../../styles/global.css";
import { requireAdmin } from "../../lib/auth";
import { getDb, initDb } from "../../lib/db";
import { getLang, tServer } from "../../lib/i18n/server";

await initDb(Astro);
const db = getDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
  const adminCountResult = await db.execute("SELECT COUNT(*) as count FROM admin_users");
  const shouldRedirectToSetup = Number(adminCountResult.rows[0]?.count || 0) === 0;
  if (shouldRedirectToSetup) {
    return Astro.redirect("/admin/setup");
  }
  return Astro.redirect("/admin/login");
}

const lang = getLang(Astro.cookies);
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{tServer(lang, "auth.loading_workspace")} - {tServer(lang, "auth.brand_name")}</title>
    <meta http-equiv="refresh" content="1.5;url=/admin/overview" />
    <style>
      @keyframes pulse-ring {
        0% {
          transform: scale(0.8);
          box-shadow: 0 0 0 0 rgba(196, 138, 58, 0.7);
        }
        70% {
          transform: scale(1);
          box-shadow: 0 0 0 20px rgba(196, 138, 58, 0);
        }
        100% {
          transform: scale(0.8);
          box-shadow: 0 0 0 0 rgba(196, 138, 58, 0);
        }
      }
    </style>
  </head>
  <body
    class="m-0 flex h-screen w-screen flex-col items-center justify-center overflow-hidden bg-[#f6f4ef] font-['Outfit',sans-serif]"
  >
    <div
      class="relative mb-6 flex h-24 w-24 items-center justify-center rounded-full bg-white shadow-xl"
      style="animation: pulse-ring 2s infinite;"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="36"
        height="36"
        viewBox="0 0 24 24"
        fill="none"
        stroke="#c48a3a"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        ><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path
          d="M16 10a4 4 0 0 1-8 0"></path></svg
      >
    </div>
    <h1 class="text-center text-2xl font-bold tracking-tight text-[#4a443e]">{tServer(lang, "auth.brand_name")}</h1>
    <p class="mt-1 text-[10px] font-bold tracking-[0.2em] text-[#c48a3a]/60 uppercase">
      {tServer(lang, "auth.supported_by")} Satria Bakery
    </p>
    <p class="mt-2 animate-pulse text-sm font-medium tracking-widest text-[#8c8277] uppercase">
      {tServer(lang, "auth.loading_workspace")}
    </p>

    <script>
      setTimeout(() => {
        window.location.href = "/admin/overview";
      }, 1500);
    </script>
  </body>
</html>
