---
import OrderDetailPageContent from "../../../components/admin/pages/OrderDetailPageContent.svelte";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../../lib/auth";
import { getDb, initDb } from "../../../lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
	return Astro.redirect("/admin/login");
}
const orderNo = Astro.params.order_no;
const db = getDb(Astro);
const result = await db.execute({
	sql: "SELECT * FROM orders WHERE order_no = ?",
	args: [orderNo ?? ""],
});
const order = result.rows[0] as unknown as
	| {
			id: string;
			order_no: string;
			status: string;
			payment_status: string;
			customer_name: string;
			customer_phone: string;
			customer_email?: string | null;
			shipping_address_json: string;
			items_json: string;
			total: number;
			notes?: string | null;
			parsedItems?: unknown[];
	  }
	| undefined;
if (!order) {
	return Astro.redirect("/admin/orders");
}
const items = JSON.parse(String(order.items_json || "[]"));
const address = JSON.parse(String(order.shipping_address_json || "{}"));
order.parsedItems = items;
order.shipping_address_json = address;
---

<AdminLayout title={`Order ${order.order_no}`}>
    <OrderDetailPageContent order={order} client:load />
</AdminLayout>
