---
import OrderDetailPageContent from "@components/admin/pages/OrderDetailPageContent.svelte";
import AdminLayout from "@layouts/AdminLayout.astro";
import { requireAdmin } from "@lib/auth";
import { getDrizzle, initDb } from "@lib/db";
import { orders } from "@db/schema";
import { eq } from "drizzle-orm";
import { getLang, tServer } from "@lib/i18n/server";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
  return Astro.redirect("/admin/login");
}
const orderNo = Astro.params.order_no;
const db = getDrizzle(Astro);
const order = await db.query.orders.findFirst({
  where: eq(orders.orderNo, orderNo ?? ""),
  with: {
    statusHistory: {
      orderBy: (history, { desc }) => [desc(history.createdAt)],
    },
  },
});

if (!order) {
  return Astro.redirect("/admin/orders");
}

// Map and parse JSON fields for the Svelte component
const rawItems = JSON.parse(String(order.itemsJson || "[]")) as any[];
const productIds = rawItems.map((i) => i.product_id).filter(Boolean);

// Fetch product names to enrich the items
const productsData =
  productIds.length > 0
    ? await db.query.products.findMany({
        where: (products, { inArray }) => inArray(products.id, productIds),
        columns: { id: true, name: true },
      })
    : [];

const productMap = Object.fromEntries(productsData.map((p) => [p.id, p.name]));

const lang = getLang(Astro.cookies);

const parsedItems = rawItems.map((item) => ({
  ...item,
  name: item.name || productMap[item.product_id] || tServer(lang, "orders.product_deleted"),
  total: item.qty * item.price,
}));

const parsedOrder = {
  ...order,
  parsedItems,
  shippingAddress: JSON.parse(String(order.shippingAddressJson || "{}")),
};
---

<AdminLayout title={`${tServer(lang, "orders.order_label")} ${order.orderNo}`}>
  <OrderDetailPageContent order={parsedOrder as any} client:load />
</AdminLayout>
