---
import ReportsApp from "../../components/admin/pages/ReportsApp.svelte";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/auth";
import { getDrizzle, initDb } from "../../lib/db";
import { getReportData } from "../../lib/reports";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
	return Astro.redirect("/admin/login");
}
const db = getDrizzle(Astro);
const reportData = await getReportData(db);
---

<AdminLayout title="Laporan">
    <ReportsApp {reportData} client:load />
</AdminLayout>
