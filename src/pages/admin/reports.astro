---
import AdminLayout from "../../layouts/AdminLayout.astro";
import SectionHeader from "../../components/admin/SectionHeader.svelte";
import StatCard from "../../components/admin/StatCard.svelte";
import AdminDataTable from "../../components/admin/AdminDataTable.svelte";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const ordersRes = await db.execute(
    "SELECT order_no, total, discount_total, items_json, payment_status, customer_phone, created_at FROM orders WHERE date(created_at) >= date('now','-30 day')",
);
const orders90Res = await db.execute(
    "SELECT customer_phone, total, payment_status, created_at FROM orders WHERE date(created_at) >= date('now','-90 day')",
);
const refundsRes = await db.execute(
    "SELECT amount FROM refunds WHERE status = 'approved' AND date(created_at) >= date('now','-30 day')",
);
const productsRes = await db.execute("SELECT id, cost, name FROM products");
const productCost: Record<string, { cost: number; name: string }> = {};
for (const row of productsRes.rows as any[]) {
    productCost[String(row.id)] = {
        cost: Number(row.cost || 0),
        name: String(row.name || ""),
    };
}

let totalOrders = 0;
let paidOrders = 0;
let revenue = 0;
let discountTotal = 0;
let cogs = 0;
const productQty: Record<string, number> = {};

for (const order of ordersRes.rows as any[]) {
    totalOrders += 1;
    revenue += Number(order.total || 0);
    discountTotal += Number(order.discount_total || 0);
    if (order.payment_status === "paid") paidOrders += 1;
    try {
        const items = JSON.parse(String(order.items_json || "[]"));
        if (Array.isArray(items)) {
            for (const item of items) {
                const pid = String(item.product_id || "");
                const qty = Number(item.qty || 0);
                const cost = productCost[pid]?.cost || 0;
                cogs += cost * qty;
                productQty[pid] = (productQty[pid] || 0) + qty;
            }
        }
    } catch {
        // ignore parse errors
    }
}
const refundTotal = refundsRes.rows.reduce(
    (sum: number, row: any) => sum + Number(row.amount || 0),
    0,
);
const grossProfit = revenue - cogs - refundTotal;

// LTV sederhana: revenue paid / unique customers (90 hari)
const paidOrders90 = orders90Res.rows.filter(
    (row: any) => row.payment_status === "paid",
);
const uniqueCustomers = new Set(
    paidOrders90.map((row: any) => String(row.customer_phone || "")),
);
const revenue90 = paidOrders90.reduce(
    (sum: number, row: any) => sum + Number(row.total || 0),
    0,
);
const ltv = uniqueCustomers.size
    ? Math.round(revenue90 / uniqueCustomers.size)
    : 0;

// Cohort sederhana: jumlah customer baru per bulan (30 hari)
const cohortMap: Record<string, Set<string>> = {};
for (const row of ordersRes.rows as any[]) {
    const phone = String(row.customer_phone || "");
    const month = String(row.created_at).slice(0, 7);
    if (!cohortMap[month]) cohortMap[month] = new Set();
    cohortMap[month].add(phone);
}
const cohorts = Object.entries(cohortMap)
    .map(([month, set]) => ({ month, count: set.size }))
    .sort((a, b) => (a.month < b.month ? -1 : 1));

// ROAS sederhana: revenue 30 hari / spend campaign aktif
const adsRes = await db.execute(
    "SELECT spend FROM ads_campaigns WHERE status IN ('active','completed')",
);
const totalSpend = adsRes.rows.reduce(
    (sum: number, row: any) => sum + Number(row.spend || 0),
    0,
);
const roas = totalSpend > 0 ? (revenue / totalSpend).toFixed(2) : "-";

const topProducts = Object.entries(productQty)
    .map(([id, qty]) => ({
        id,
        qty,
        name: productCost[id]?.name || id,
    }))
    .sort((a, b) => b.qty - a.qty)
    .slice(0, 5);
---

<AdminLayout title="Laporan">
    <div class="animate-fade-in-up">
        <div class="mb-4">
            <SectionHeader title="Ringkasan 30 Hari" badge="Keuangan" />
        </div>
        <div
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-8"
        >
            <StatCard
                label="Total Order"
                value={totalOrders}
                icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>'
            />
            <StatCard
                label="Order Paid"
                value={paidOrders}
                icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><path d="m9 15 2 2 4-4"></path></svg>'
            />
            <StatCard
                label="Revenue"
                value={`Rp ${revenue.toLocaleString("id-ID")}`}
                icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"></line><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>'
            />
            <StatCard
                label="Diskon"
                value={`Rp ${discountTotal.toLocaleString("id-ID")}`}
                icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="5" x2="5" y2="19"></line><circle cx="6.5" cy="6.5" r="2.5"></circle><circle cx="17.5" cy="17.5" r="2.5"></circle></svg>'
            />
            <StatCard
                label="COGS (estimasi)"
                value={`Rp ${cogs.toLocaleString("id-ID")}`}
                icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>'
            />
            <StatCard
                label="Refund"
                value={`Rp ${refundTotal.toLocaleString("id-ID")}`}
                icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v6h6"/><path d="M21 17v-6h-6"/><path d="M18.5 4.5A10 10 0 0 0 4 11"/><path d="M5.5 19.5A10 10 0 0 0 20 13"/></svg>'
            />
            <StatCard
                label="Gross Profit"
                value={`Rp ${grossProfit.toLocaleString("id-ID")}`}
                icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg>'
            />
        </div>

        <div class="mb-4">
            <SectionHeader title="Top Produk" muted="Berdasarkan qty terjual" />
        </div>
        <AdminDataTable>
            <thead>
                <tr>
                    <th>Produk</th>
                    <th>Qty</th>
                </tr>
            </thead>
            <tbody>
                {
                    topProducts.length === 0 && (
                        <tr>
                            <td
                                colspan="2"
                                class="text-center py-8 text-stone-400 text-sm italic"
                            >
                                Belum ada data produk terjual 30 hari terakhir.
                            </td>
                        </tr>
                    )
                }
                {
                    topProducts.map((item) => (
                        <tr class="group hover:bg-stone-50/50 transition-colors">
                            <td class="font-medium text-stone-900">
                                {item.name}
                            </td>
                            <td class="tabular-nums font-medium text-stone-700">
                                {item.qty}
                            </td>
                        </tr>
                    ))
                }
            </tbody>
        </AdminDataTable>
        <div class="mb-12"></div>

        <div class="mb-4">
            <SectionHeader title="Analitik Dasar" badge="LTV • Cohort • ROAS" />
        </div>
        <div
            class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6 mb-8"
        >
            <StatCard
                label="LTV (90 hari)"
                value={`Rp ${ltv.toLocaleString("id-ID")}`}
                icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>'
            />
            <StatCard
                label="ROAS (30 hari)"
                value={roas}
                icon='<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"></polygon><path d="M15.54 8.46a5 5 0 0 1 0 7.07"></path><path d="M19.07 4.93a10 10 0 0 1 0 14.14"></path></svg>'
            />
        </div>
        <div class="mb-4">
            <SectionHeader
                title="Cohort (customer baru/bulan)"
                muted="30 hari terakhir"
            />
        </div>
        <AdminDataTable>
            <thead>
                <tr>
                    <th>Bulan</th>
                    <th>Customer Baru</th>
                </tr>
            </thead>
            <tbody>
                {
                    cohorts.length === 0 && (
                        <tr>
                            <td
                                colspan="2"
                                class="text-center py-8 text-stone-400 text-sm italic"
                            >
                                Belum ada data cohort customer baru 30 hari
                                terakhir.
                            </td>
                        </tr>
                    )
                }
                {
                    cohorts.map((c) => (
                        <tr class="group hover:bg-stone-50/50 transition-colors">
                            <td class="font-medium text-stone-900">
                                {c.month}
                            </td>
                            <td class="tabular-nums font-medium text-stone-700">
                                {c.count}
                            </td>
                        </tr>
                    ))
                }
            </tbody>
        </AdminDataTable>
    </div>
</AdminLayout>
