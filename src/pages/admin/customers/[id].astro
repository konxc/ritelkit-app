---
import Table from "../../../components/admin/ui/Table.svelte";
import TableRow from "../../../components/admin/ui/TableRow.svelte";
import TableCell from "../../../components/admin/ui/TableCell.svelte";
import Badge from "../../../components/admin/ui/Badge.svelte";
import PanelCard from "../../../components/admin/PanelCard.svelte";
import SectionHeader from "../../../components/admin/SectionHeader.svelte";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../../lib/auth";
import { getDb, initDb } from "../../../lib/db";
import { getLang, tServer, fServer } from "../../../lib/i18n/server";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
  return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const id = Astro.params.id || "";
const customerRes = await db.execute({
  sql: "SELECT id, name, email, phone, notes, created_at FROM customers WHERE id = ?",
  args: [id],
});
const customer = customerRes.rows[0] as unknown as
  | {
      id: string;
      name: string;
      email?: string | null;
      phone: string;
      notes?: string | null;
      created_at: string;
    }
  | undefined;
if (!customer) {
  return Astro.redirect("/admin/customers");
}
const ordersRes = await db.execute({
  sql: `SELECT order_no, total, status, payment_status, created_at
          FROM orders
          WHERE customer_phone = ? OR (customer_email IS NOT NULL AND customer_email = ?)
          ORDER BY created_at DESC`,
  args: [customer.phone, customer.email || ""],
});

const lang = getLang(Astro.cookies);
const f = fServer(lang);
---

<AdminLayout title={tServer(lang, "customers.detail_title")}>
  <PanelCard>
    <strong>{customer.name}</strong>
    <p class="muted">
      {customer.phone}
      {customer.email ? `• ${customer.email}` : ""}
    </p>
    <p>{customer.notes || "-"}</p>
  </PanelCard>

  <div class="mt-6">
    <SectionHeader title={tServer(lang, "customers.order_history")} muted={tServer(lang, "customers.history_desc")} />
  </div>
  <div class="mt-4">
    <Table
      headers={[
        tServer(lang, "orders.order_no"),
        tServer(lang, "orders.total"),
        tServer(lang, "orders.status"),
        tServer(lang, "orders.payment"),
        tServer(lang, "orders.date"),
      ]}
    >
      {
        ordersRes.rows.map((order) => (
          <TableRow>
            <TableCell>
              <a
                href={`/admin/orders/${String((order as { order_no?: string }).order_no || "")}`}
                class="font-bold text-[#c48a3a] hover:underline"
              >
                {String((order as { order_no?: string }).order_no || "")}
              </a>
            </TableCell>
            <TableCell>{f.currency(Number((order as { total?: number }).total || 0))}</TableCell>
            <TableCell>
              <Badge
                variant={String((order as { status?: string }).status || "") === "processing" ? "success" : "default"}
              >
                {String((order as { status?: string }).status || "")}
              </Badge>
            </TableCell>
            <TableCell>
              <Badge
                variant={
                  String((order as { payment_status?: string }).payment_status || "") === "paid"
                    ? "success"
                    : String((order as { payment_status?: string }).payment_status || "") === "failed"
                      ? "danger"
                      : "default"
                }
              >
                {String((order as { payment_status?: string }).payment_status || "")}
              </Badge>
            </TableCell>
            <TableCell>{f.date(String((order as { created_at?: string }).created_at || ""))}</TableCell>
          </TableRow>
        ))
      }
    </Table>
  </div>
</AdminLayout>
