---
import AdminDataTable from "../../../components/admin/AdminDataTable.svelte";
import PanelCard from "../../../components/admin/PanelCard.svelte";
import SectionHeader from "../../../components/admin/SectionHeader.svelte";
import StatusBadge from "../../../components/admin/StatusBadge.svelte";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../../lib/auth";
import { getDb, initDb } from "../../../lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
  return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const id = Astro.params.id || "";
const customerRes = await db.execute({
  sql: "SELECT id, name, email, phone, notes, created_at FROM customers WHERE id = ?",
  args: [id],
});
const customer = customerRes.rows[0] as unknown as
  | {
      id: string;
      name: string;
      email?: string | null;
      phone: string;
      notes?: string | null;
      created_at: string;
    }
  | undefined;
if (!customer) {
  return Astro.redirect("/admin/customers");
}
const ordersRes = await db.execute({
  sql: `SELECT order_no, total, status, payment_status, created_at
          FROM orders
          WHERE customer_phone = ? OR (customer_email IS NOT NULL AND customer_email = ?)
          ORDER BY created_at DESC`,
  args: [customer.phone, customer.email || ""],
});
---

<AdminLayout title="Detail Pelanggan">
    <PanelCard>
        <strong>{customer.name}</strong>
        <p class="muted">{customer.phone} {customer.email ? `• ${customer.email}` : ""}</p>
        <p>{customer.notes || "-"}</p>
    </PanelCard>

    <div class="mt-6">
        <SectionHeader title="Riwayat Order" muted="Berdasarkan telepon/email" />
    </div>
    <AdminDataTable>
        <thead>
            <tr>
                <th>Order</th>
                <th>Total</th>
                <th>Status</th>
                <th>Pembayaran</th>
                <th>Tanggal</th>
            </tr>
        </thead>
        <tbody>
            {ordersRes.rows.map((order) => (
                <tr>
                    <td>
                        <a href={`/admin/orders/${String((order as { order_no?: string }).order_no || "")}`}>{String((order as { order_no?: string }).order_no || "")}</a>
                    </td>
                    <td>Rp {Number((order as { total?: number }).total || 0).toLocaleString("id-ID")}</td>
                    <td>
                        <StatusBadge
                            label={String((order as { status?: string }).status || "")}
                            tone={String((order as { status?: string }).status || "") === "processing" ? "success" : "default"}
                        />
                    </td>
                    <td>
                        <StatusBadge
                            label={String((order as { payment_status?: string }).payment_status || "")}
                            tone={String((order as { payment_status?: string }).payment_status || "") === "paid"
                                ? "success"
                                : String((order as { payment_status?: string }).payment_status || "") === "failed"
                                  ? "danger"
                                  : "default"}
                        />
                    </td>
                    <td>{String((order as { created_at?: string }).created_at || "").split("T")[0]}</td>
                </tr>
            ))}
        </tbody>
    </AdminDataTable>
</AdminLayout>
