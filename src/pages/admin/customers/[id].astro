---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import SectionHeader from "../../../components/admin/SectionHeader.svelte";
import StatusBadge from "../../../components/admin/StatusBadge.svelte";
import AdminDataTable from "../../../components/admin/AdminDataTable.svelte";
import PanelCard from "../../../components/admin/PanelCard.svelte";
import { requireAdmin } from "../../../lib/auth";
import { initDb, getDb } from "../../../lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const id = Astro.params.id || "";
const customerRes = await db.execute({
    sql: "SELECT id, name, email, phone, notes, created_at FROM customers WHERE id = ?",
    args: [id],
});
const customer = customerRes.rows[0] as any;
if (!customer) {
    return Astro.redirect("/admin/customers");
}
const ordersRes = await db.execute({
    sql: `SELECT order_no, total, status, payment_status, created_at
          FROM orders
          WHERE customer_phone = ? OR (customer_email IS NOT NULL AND customer_email = ?)
          ORDER BY created_at DESC`,
    args: [customer.phone, customer.email || ""],
});
---

<AdminLayout title="Detail Pelanggan">
    <PanelCard>
        <strong>{customer.name}</strong>
        <p class="muted">{customer.phone} {customer.email ? `• ${customer.email}` : ""}</p>
        <p>{customer.notes || "-"}</p>
    </PanelCard>

    <div class="mt-6">
        <SectionHeader title="Riwayat Order" muted="Berdasarkan telepon/email" />
    </div>
    <AdminDataTable>
        <thead>
            <tr>
                <th>Order</th>
                <th>Total</th>
                <th>Status</th>
                <th>Pembayaran</th>
                <th>Tanggal</th>
            </tr>
        </thead>
        <tbody>
            {ordersRes.rows.map((order: any) => (
                <tr>
                    <td>
                        <a href={`/admin/orders/${order.order_no}`}>{order.order_no}</a>
                    </td>
                    <td>Rp {Number(order.total).toLocaleString("id-ID")}</td>
                    <td>
                        <StatusBadge
                            label={order.status}
                            tone={order.status === "processing" ? "success" : "default"}
                        />
                    </td>
                    <td>
                        <StatusBadge
                            label={order.payment_status}
                            tone={order.payment_status === "paid"
                                ? "success"
                                : order.payment_status === "failed"
                                  ? "danger"
                                  : "default"}
                        />
                    </td>
                    <td>{String(order.created_at).split("T")[0]}</td>
                </tr>
            ))}
        </tbody>
    </AdminDataTable>
</AdminLayout>
