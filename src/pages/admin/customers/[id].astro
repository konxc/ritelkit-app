---
import Table from "../../../components/admin/ui/Table.svelte";
import TableRow from "../../../components/admin/ui/TableRow.svelte";
import TableCell from "../../../components/admin/ui/TableCell.svelte";
import Badge from "../../../components/admin/ui/Badge.svelte";
import PanelCard from "../../../components/admin/PanelCard.svelte";
import SectionHeader from "../../../components/admin/SectionHeader.svelte";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import TableEmptyState from "../../../components/admin/ui/TableEmptyState.svelte";
import { requireAdmin } from "../../../lib/auth";
import { getDb, initDb } from "../../../lib/db";
import { getLang, tServer, fServer } from "../../../lib/i18n/server";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
  return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const id = Astro.params.id || "";
const customerRes = await db.execute({
  sql: "SELECT id, name, email, phone, notes, created_at FROM customers WHERE id = ?",
  args: [id],
});

const customer = customerRes.rows[0] as unknown as
  | {
      id: string;
      name: string;
      email?: string | null;
      phone: string;
      notes?: string | null;
      created_at: string;
    }
  | undefined;

if (!customer) {
  return Astro.redirect("/admin/customers");
}

const ordersRes = await db.execute({
  sql: `SELECT order_no, total, status, payment_status, created_at
          FROM orders
          WHERE customer_phone = ? OR (customer_email IS NOT NULL AND customer_email = ?)
          ORDER BY created_at DESC`,
  args: [customer.phone, customer.email || ""],
});

const lang = getLang(Astro.cookies);
const f = fServer(lang);
---

<AdminLayout title={tServer(lang, "customers.detail_title")}>
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Left: Customer Info -->
    <div class="lg:col-span-1 space-y-6">
       <PanelCard class="overflow-hidden border-stone-200/60 shadow-sm">
        <div class="mb-4 flex items-center gap-3 border-b border-stone-100 pb-4">
          <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-[#c48a3a]/10 text-[#c48a3a]">
             <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <div>
            <h2 class="text-lg font-black text-stone-900 leading-tight">{customer.name}</h2>
            <p class="text-[0.65rem] font-bold tracking-widest text-stone-400 uppercase">{tServer(lang, "customers.badge_crm")}</p>
          </div>
        </div>

        <div class="space-y-4">
          <div class="flex items-center gap-3">
             <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-stone-50 text-stone-400">
               <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l2.27-2.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
             </div>
             <div>
               <p class="text-[0.65rem] font-bold text-stone-400 uppercase leading-none mb-1">{tServer(lang, "common.phone")}</p>
               <p class="text-sm font-bold text-stone-700">{customer.phone}</p>
             </div>
          </div>

          <div class="flex items-center gap-3">
             <div class="flex h-8 w-8 items-center justify-center rounded-xl bg-stone-50 text-stone-400">
               <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
             </div>
             <div>
               <p class="text-[0.65rem] font-bold text-stone-400 uppercase leading-none mb-1">{tServer(lang, "common.email")}</p>
               <p class="text-sm font-bold text-stone-700">{customer.email || "-"}</p>
             </div>
          </div>

          <div class="border-t border-stone-100 pt-4">
             <p class="text-[0.65rem] font-bold text-stone-400 uppercase leading-none mb-2">{tServer(lang, "customers.notes")}</p>
             <p class="text-sm font-medium text-stone-600 leading-relaxed italic">
               "{customer.notes || tServer(lang, "common.no_data")}"
             </p>
          </div>
        </div>
      </PanelCard>
    </div>

    <!-- Right: History -->
    <div class="lg:col-span-2">
      <SectionHeader title={tServer(lang, "customers.order_history")} muted={tServer(lang, "customers.history_desc")} />
      
      <div class="mt-4">
        <Table
          headers={[
            tServer(lang, "orders.order_no"),
            tServer(lang, "orders.total"),
            tServer(lang, "orders.status"),
            tServer(lang, "orders.payment"),
            tServer(lang, "orders.date"),
          ]}
        >
          {ordersRes.rows.length === 0 ? (
            <TableEmptyState 
              title={tServer(lang, "common.no_data")} 
              subtitle={tServer(lang, "orders.empty")} 
              colspan={5} 
            />
          ) : (
            ordersRes.rows.map((order) => (
              <TableRow>
                <TableCell>
                  <a
                    href={`/admin/orders/${String((order as { order_no?: string }).order_no || "")}`}
                    class="font-extrabold text-[#c48a3a] hover:underline"
                  >
                    {String((order as { order_no?: string }).order_no || "")}
                  </a>
                </TableCell>
                <TableCell class="font-bold text-stone-800">{f.currency(Number((order as { total?: number }).total || 0))}</TableCell>
                <TableCell>
                  <Badge
                    variant={String((order as { status?: string }).status || "") === "completed" ? "success" : String((order as { status?: string }).status || "") === "cancelled" ? "danger" : "default"}
                    class="uppercase text-[0.6rem] tracking-tighter"
                  >
                    {tServer(lang, `orders.statuses.${String((order as { status?: string }).status || "")}`) || String((order as { status?: string }).status || "")}
                  </Badge>
                </TableCell>
                <TableCell>
                  <Badge
                    variant={
                      String((order as { payment_status?: string }).payment_status || "") === "paid"
                        ? "success"
                        : String((order as { payment_status?: string }).payment_status || "") === "failed"
                          ? "danger"
                          : "default"
                    }
                    class="uppercase text-[0.6rem] tracking-tighter"
                  >
                    {tServer(lang, `orders.payments.${String((order as { payment_status?: string }).payment_status || "")}`) || String((order as { payment_status?: string }).payment_status || "")}
                  </Badge>
                </TableCell>
                <TableCell class="text-stone-400 font-medium text-[0.7rem]">{f.date(String((order as { created_at?: string }).created_at || ""))}</TableCell>
              </TableRow>
            ))
          )}
        </Table>
      </div>
    </div>
  </div>
</AdminLayout>

