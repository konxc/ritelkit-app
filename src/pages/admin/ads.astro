---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";
import { parsePage } from "../../lib/admin";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const { page, q, offset, limit } = parsePage(Astro.url, 20);
const where = q ? "WHERE name LIKE ? OR channel LIKE ?" : "";
const args = q ? [`%${q}%`, `%${q}%`] : [];

const campaignsRes = await db.execute({
    sql: `SELECT id, name, channel, budget, spend, status, start_at, end_at
          FROM ads_campaigns
          ${where}
          ORDER BY created_at DESC
          LIMIT ? OFFSET ?`,
    args: [...args, limit, offset],
});
const countRes = await db.execute({
    sql: `SELECT COUNT(*) as count FROM ads_campaigns ${where}`,
    args,
});
const total = Number((countRes.rows[0] as any)?.count || 0);
const totalPages = Math.max(1, Math.ceil(total / limit));
---

<AdminLayout title="Iklan">
    <div class="section-header">
        <h2>Buat Campaign</h2>
        <span class="badge">Ads</span>
    </div>
    <form class="form-row" id="ads-form">
        <div>
            <label>Nama Campaign</label>
            <input name="name" required />
        </div>
        <div>
            <label>Channel</label>
            <input name="channel" placeholder="IG / FB / WA / Google" required />
        </div>
        <div>
            <label>Budget (Rp)</label>
            <input name="budget" type="number" required />
        </div>
        <div>
            <label>Status</label>
            <select name="status">
                <option value="draft">Draft</option>
                <option value="active">Active</option>
                <option value="paused">Paused</option>
                <option value="completed">Completed</option>
            </select>
        </div>
        <div>
            <label>Tanggal Mulai</label>
            <input name="start_at" type="date" />
        </div>
        <div>
            <label>Tanggal Selesai</label>
            <input name="end_at" type="date" />
        </div>
        <div>
            <label>Catatan</label>
            <input name="notes" />
        </div>
        <button class="primary" type="submit">Simpan</button>
    </form>

    <div class="toolbar">
        <strong>Daftar Campaign</strong>
        <form method="get">
            <input name="q" placeholder="Cari campaign" value={q} />
            <button class="btn-ghost" type="submit">Cari</button>
        </form>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Nama</th>
                <th>Channel</th>
                <th>Budget</th>
                <th>Spend</th>
                <th>Status</th>
                <th>Aksi</th>
            </tr>
        </thead>
        <tbody>
            {campaignsRes.rows.map((c: any) => (
                <tr data-id={c.id}>
                    <td contenteditable="true" data-field="name">{c.name}</td>
                    <td contenteditable="true" data-field="channel">{c.channel}</td>
                    <td contenteditable="true" data-field="budget">{c.budget}</td>
                    <td contenteditable="true" data-field="spend">{c.spend}</td>
                    <td contenteditable="true" data-field="status">{c.status}</td>
                    <td>
                        <div class="table-actions">
                            <button class="btn-ghost" data-action="save">Simpan</button>
                            <button class="btn-ghost" data-action="delete">Hapus</button>
                        </div>
                    </td>
                </tr>
            ))}
        </tbody>
    </table>

    <div class="pagination">
        {page > 1 && (
            <a href={`?q=${encodeURIComponent(q)}&page=${page - 1}`}>Prev</a>
        )}
        <span class="muted">Hal {page} / {totalPages}</span>
        {page < totalPages && (
            <a href={`?q=${encodeURIComponent(q)}&page=${page + 1}`}>Next</a>
        )}
    </div>

    <script>
        const form = document.querySelector("#ads-form") as HTMLFormElement | null;
        const csrf = document
            .querySelector("meta[name='csrf-token']")
            ?.getAttribute("content") || "";

        form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            if (!form) return;
            const data = new FormData(form);
            const res = await fetch("/api/admin/ads", {
                method: "POST",
                headers: { "X-CSRF-Token": csrf },
                body: data,
            });
            if (res.ok) location.reload();
            else alert(await res.text());
        });

        document.querySelectorAll("tr[data-id]").forEach((row) => {
            row.addEventListener("click", async (e) => {
                const target = e.target as HTMLElement;
                const action = target.getAttribute("data-action");
                if (!action) return;
                const id = row.getAttribute("data-id");
                if (!id) return;
                if (action === "delete") {
                    if (!confirm("Hapus campaign ini?")) return;
                    const res = await fetch(`/api/admin/ads/${id}`, {
                        method: "DELETE",
                        headers: { "X-CSRF-Token": csrf },
                    });
                    if (res.ok) location.reload();
                    else alert(await res.text());
                    return;
                }
                if (action === "save") {
                    const fields: Record<string, string> = {};
                    row.querySelectorAll("[data-field]").forEach((cell) => {
                        const field = cell.getAttribute("data-field");
                        if (!field) return;
                        fields[field] = String(cell.textContent?.trim() || "");
                    });
                    const res = await fetch(`/api/admin/ads/${id}`, {
                        method: "PUT",
                        headers: {
                            "Content-Type": "application/json",
                            "X-CSRF-Token": csrf,
                        },
                        body: JSON.stringify(fields),
                    });
                    if (!res.ok) alert(await res.text());
                }
            });
        });
    </script>
</AdminLayout>
