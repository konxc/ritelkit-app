---
import { asc } from "drizzle-orm";
import AdminTabs from "../../components/admin/AdminTabs.astro";
import AdminToolbar from "../../components/admin/AdminToolbar.svelte";
import PaginationNav from "../../components/admin/PaginationNav.svelte";
import KatalogTabContent from "../../components/admin/pages/KatalogTabContent.svelte";
import { categories } from "../../db/schema";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { normalizeTab, parsePage } from "../../lib/admin";
import { requireAdmin } from "../../lib/auth";
import { getDrizzle, initDb } from "../../lib/db";
import CatalogHeaderFilters from "../../components/admin/CatalogHeaderFilters.svelte";
import { appRouter } from "../../server/router";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
  return Astro.redirect("/admin/login");
}

const TAB_IDS = ["products", "categories", "inventory"] as const;
const SUBTAB_IDS = ["stock", "log"] as const;

const rawTab = Astro.url.searchParams.get("tab");
const rawSubtab = Astro.url.searchParams.get("subtab");

const tab = normalizeTab(rawTab, {
  allowed: TAB_IDS,
  defaultTab: "products",
});

const subtab = normalizeTab(rawSubtab, {
  allowed: SUBTAB_IDS,
  defaultTab: "stock",
});

if ((rawTab && rawTab !== tab) || (rawSubtab && rawSubtab !== subtab)) {
  const canonicalUrl = new URL(Astro.url);
  if (rawTab && rawTab !== tab) canonicalUrl.searchParams.set("tab", tab);
  if (rawSubtab && rawSubtab !== subtab) canonicalUrl.searchParams.set("subtab", subtab);
  return Astro.redirect(canonicalUrl.pathname + canonicalUrl.search);
}
const categoryId = Astro.url.searchParams.get("category");
const statusFilter = Astro.url.searchParams.get("status"); // 'active', 'inactive'

const { page, q, limit } = parsePage(Astro.url, 20);
const db = getDrizzle(Astro);

let totalPages = 1;
const initialData = {
  categories: [] as any[],
  categoriesTotal: 0,
  products: [] as any[],
  productsTotal: 0,
  inventoryProducts: [] as any[],
  inventoryProductsTotal: 0,
  inventoryMovements: [] as any[],
  inventoryMovementsTotal: 0,
};

// Common: Always fetch ALL categories for dropdowns in other tabs
const categoryOptions = await db.select().from(categories).orderBy(asc(categories.sortOrder), asc(categories.name));

const caller = appRouter.createCaller({ db, admin, ctx: Astro as any });

if (tab === "categories") {
  const result = await caller.categories.list({ limit, page, q: q || undefined });
  initialData.categories = result.data;
  initialData.categoriesTotal = result.total;
  totalPages = Math.max(1, Math.ceil(result.total / limit));
} else if (tab === "products") {
  const result = await caller.products.list({
    limit,
    page,
    q: q || undefined,
    categoryId: categoryId || undefined,
    status: statusFilter || undefined,
  });

  initialData.products = result.data;
  initialData.productsTotal = result.total;
  totalPages = Math.max(1, Math.ceil(result.total / limit));

  // Use all categories for options
  initialData.categories = categoryOptions;
  initialData.categoriesTotal = categoryOptions.length;
} else if (tab === "inventory") {
  // Always fetch products (for stok tab)
  const productsResult = await caller.inventory.listProducts({
    limit,
    page,
    q: q || undefined,
    categoryId: categoryId || undefined,
  });
  initialData.inventoryProducts = productsResult.data;
  initialData.inventoryProductsTotal = productsResult.total;

  // Always fetch movements (for log tab)
  const movementsResult = await caller.inventory.listMovements({
    limit,
    page,
    q: q || undefined,
  });
  initialData.inventoryMovements = movementsResult.data;
  initialData.inventoryMovementsTotal = movementsResult.total;

  if (subtab === "stock") {
    totalPages = Math.max(1, Math.ceil(productsResult.total / limit));
  } else {
    totalPages = Math.max(1, Math.ceil(movementsResult.total / limit));
  }

  // Use all categories for options
  initialData.categories = categoryOptions;
  initialData.categoriesTotal = categoryOptions.length;
}

const tabs = [
  {
    id: "products",
    label: "catalog.products.title",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>',
  },
  {
    id: "categories",
    label: "catalog.categories.title",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>',
  },
  {
    id: "inventory",
    label: "catalog.inventory.title",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.29 7 12 12 20.71 7"/><line x1="12" y1="22" x2="12" y2="12"/></svg>',
  },
];
import { getLang, type LanguageCode, tServer } from "../../lib/i18n/server";
const lang: LanguageCode = getLang(Astro.cookies);
---

<AdminLayout title={tServer(lang, "nav.catalog")}>
  <div slot="header-tabs">
    <AdminTabs tabs={tabs} activeTab={tab} {lang} />
  </div>

  {
    tab === "categories" && (
      <>
        <AdminToolbar
          title={tServer(lang, "catalog.categories.title")}
          class="sticky top-0 z-20 sm:top-2 md:top-4 lg:hidden"
          showMobileFloat={true}
          client:load
        >
          <CatalogHeaderFilters tab="categories" q={q} lang={lang} client:load />
        </AdminToolbar>
      </>
    )
  }

  {
    tab === "products" && (
      <>
        <AdminToolbar
          title={tServer(lang, "common.filter")}
          class="sticky top-0 z-20 sm:top-2 md:top-4 lg:hidden"
          showMobileFloat={true}
          client:load
        >
          <CatalogHeaderFilters
            tab="products"
            q={q}
            categoryId={categoryId || ""}
            status={statusFilter || ""}
            categoryOptions={categoryOptions}
            lang={lang}
            client:load
          />
        </AdminToolbar>
      </>
    )
  }

  {
    tab === "inventory" && (
      <>
        <AdminToolbar
          title={tServer(lang, "catalog.inventory.stock_title")}
          class="sticky top-0 z-20 sm:top-2 md:top-4 lg:hidden"
          showMobileFloat={true}
          client:load
        >
          <CatalogHeaderFilters
            tab="inventory"
            q={q}
            categoryId={categoryId || ""}
            categoryOptions={categoryOptions}
            lang={lang}
            client:load
          />
        </AdminToolbar>
      </>
    )
  }

  <KatalogTabContent {tab} {q} {page} {limit} {initialData} {lang} client:load />

  <PaginationNav
    page={page}
    totalPages={totalPages}
    prevHref={page > 1
      ? `?tab=${tab}&q=${encodeURIComponent(q)}&category=${categoryId || ""}&status=${statusFilter || ""}&subtab=${subtab}&page=${page - 1}`
      : undefined}
    nextHref={page < totalPages
      ? `?tab=${tab}&q=${encodeURIComponent(q)}&category=${categoryId || ""}&status=${statusFilter || ""}&subtab=${subtab}&page=${page + 1}`
      : undefined}
    client:load
  />
</AdminLayout>
