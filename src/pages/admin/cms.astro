---
import AdminLayout from "../../layouts/AdminLayout.astro";
import SectionHeader from "../../components/admin/SectionHeader.svelte";
import PaginationNav from "../../components/admin/PaginationNav.svelte";
import AdminDataTable from "../../components/admin/AdminDataTable.svelte";
import AdminToolbar from "../../components/admin/AdminToolbar.svelte";
import RowActions from "../../components/admin/RowActions.svelte";
import AdminFilterForm from "../../components/admin/AdminFilterForm.svelte";
import ActionGroup from "../../components/admin/ActionGroup.svelte";
import CrudInlineForm from "../../components/admin/CrudInlineForm.svelte";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";
import { parsePage } from "../../lib/admin";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const { page, q, offset, limit } = parsePage(Astro.url, 20);
const where = q ? "WHERE title LIKE ? OR slug LIKE ?" : "";
const args = q ? [`%${q}%`, `%${q}%`] : [];

const pagesRes = await db.execute({
    sql: `SELECT id, slug, title, is_active, updated_at
          FROM cms_pages
          ${where}
          ORDER BY updated_at DESC
          LIMIT ? OFFSET ?`,
    args: [...args, limit, offset],
});
const countRes = await db.execute({
    sql: `SELECT COUNT(*) as count FROM cms_pages ${where}`,
    args,
});
const total = Number((countRes.rows[0] as any)?.count || 0);
const totalPages = Math.max(1, Math.ceil(total / limit));
---

<AdminLayout title="Konten">
    <SectionHeader title="Buat Halaman" badge="Brand Awareness" />
    <CrudInlineForm id="cms-form">
        <input type="hidden" name="page_id" />
        <div>
            <label>Judul</label>
            <input name="title" required />
        </div>
        <div>
            <label>Slug</label>
            <input name="slug" placeholder="contoh: semesta-bersholawat" required />
        </div>
        <div>
            <label>Konten (Markdown)</label>
            <textarea name="content_md" rows="6" required></textarea>
        </div>
        <div>
            <label>Status</label>
            <select name="is_active">
                <option value="true">Aktif</option>
                <option value="false">Draft</option>
            </select>
        </div>
        <ActionGroup>
            <button class="primary" type="submit">Simpan</button>
            <button class="btn-ghost" type="button" id="cms-clear">Clear</button>
        </ActionGroup>
    </CrudInlineForm>

    <AdminToolbar title="Daftar Halaman">
        <AdminFilterForm>
            <input name="q" placeholder="Cari judul/slug" value={q} />
            <button class="btn-ghost" type="submit">Cari</button>
        </AdminFilterForm>
    </AdminToolbar>

    <AdminDataTable>
        <thead>
            <tr>
                <th>Judul</th>
                <th>Slug</th>
                <th>Status</th>
                <th>Update</th>
                <th>Aksi</th>
            </tr>
        </thead>
        <tbody>
            {pagesRes.rows.map((p: any) => (
                <tr data-id={p.id}>
                    <td contenteditable="true" data-field="title">{p.title}</td>
                    <td contenteditable="true" data-field="slug">{p.slug}</td>
                    <td contenteditable="true" data-field="is_active">{p.is_active ? "true" : "false"}</td>
                    <td>{String(p.updated_at).split("T")[0]}</td>
                    <td>
                        <RowActions
                            viewHref={`/content/${p.slug}`}
                            showEdit={true}
                        />
                    </td>
                </tr>
            ))}
        </tbody>
    </AdminDataTable>

    <PaginationNav
        page={page}
        totalPages={totalPages}
        prevHref={page > 1 ? `?q=${encodeURIComponent(q)}&page=${page - 1}` : undefined}
        nextHref={page < totalPages ? `?q=${encodeURIComponent(q)}&page=${page + 1}` : undefined}
    />

    <script>
        import { bindCrudTable, getCsrfToken } from "../../lib/admin-client";

        const form = document.querySelector("#cms-form") as HTMLFormElement | null;
        const clearBtn = document.querySelector("#cms-clear");
        const csrf = getCsrfToken();

        form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            if (!form) return;
            const data = new FormData(form);
            const pageId = String(data.get("page_id") || "");
            const payload = {
                title: data.get("title"),
                slug: data.get("slug"),
                content_md: data.get("content_md"),
                is_active: data.get("is_active"),
            };
            const res = await fetch(
                pageId ? `/api/admin/cms-pages/${pageId}` : "/api/admin/cms-pages",
                {
                    method: pageId ? "PUT" : "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "X-CSRF-Token": csrf,
                    },
                    body: JSON.stringify(payload),
                },
            );
            if (res.ok) location.reload();
            else alert(await res.text());
        });

        clearBtn?.addEventListener("click", () => {
            if (!form) return;
            (form.querySelector("input[name='page_id']") as HTMLInputElement).value = "";
            (form.querySelector("input[name='title']") as HTMLInputElement).value = "";
            (form.querySelector("input[name='slug']") as HTMLInputElement).value = "";
            (form.querySelector("textarea[name='content_md']") as HTMLTextAreaElement).value = "";
        });

        bindCrudTable({
            basePath: "/api/admin/cms-pages",
            deleteConfirm: "Hapus halaman ini?",
            extraActions: {
                edit: async ({ id, row }) => {
                    const contentRes = await fetch(`/api/admin/cms-pages/${id}`);
                    if (!contentRes.ok) {
                        alert(await contentRes.text());
                        return;
                    }
                    const data = (await contentRes.json()) as { content_md?: string };
                    const content = form?.querySelector(
                        "textarea[name='content_md']",
                    ) as HTMLTextAreaElement | null;
                    const title = row.querySelector("[data-field='title']")?.textContent || "";
                    const slug = row.querySelector("[data-field='slug']")?.textContent || "";
                    const isActive = row.querySelector("[data-field='is_active']")?.textContent || "true";
                    if (form) {
                        (form.querySelector("input[name='page_id']") as HTMLInputElement).value = id;
                        (form.querySelector("input[name='title']") as HTMLInputElement).value = title.trim();
                        (form.querySelector("input[name='slug']") as HTMLInputElement).value = slug.trim();
                        const selectEl = form.querySelector(
                            "select[name='is_active']",
                        ) as HTMLSelectElement | null;
                        if (selectEl) {
                            selectEl.value = isActive.trim() || "true";
                        }
                    }
                    if (content) content.value = data.content_md || "";
                },
            },
            mapFields: (fields) => {
                const content = form?.querySelector(
                    "textarea[name='content_md']",
                ) as HTMLTextAreaElement | null;
                return {
                    ...fields,
                    content_md: content?.value || "",
                };
            },
        });
    </script>
</AdminLayout>
