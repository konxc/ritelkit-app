---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const invoices = await db.execute(
    `SELECT i.invoice_no, i.status, i.issued_at, o.order_no, o.total
     FROM invoices i JOIN orders o ON o.id = i.order_id
     ORDER BY i.created_at DESC`,
);
---

<AdminLayout title="Invoice">
    <div class="section-header">
        <h2>Buat Invoice</h2>
        <span class="badge">Manual</span>
    </div>
    <form class="form-row" id="invoice-form">
        <div>
            <label>Order No</label>
            <input name="order_no" required />
        </div>
        <button class="primary" type="submit">Buat Invoice</button>
    </form>

    <div class="section-header mt-6">
        <h2>Daftar Invoice</h2>
        <span class="muted">Auto update status di tahap berikutnya</span>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>Invoice</th>
                <th>Order</th>
                <th>Total</th>
                <th>Status</th>
                <th>Tanggal</th>
            </tr>
        </thead>
        <tbody>
            {
                invoices.rows.map((inv: any) => (
                    <tr>
                        <td>
                            <a href={`/admin/invoices/${inv.invoice_no}`}>
                                {inv.invoice_no}
                            </a>
                        </td>
                        <td>{inv.order_no}</td>
                        <td>Rp {Number(inv.total).toLocaleString("id-ID")}</td>
                        <td>
                            <span
                                class={`badge ${inv.status === "paid" ? "success" : inv.status === "void" ? "danger" : ""}`}
                            >
                                {inv.status}
                            </span>
                        </td>
                        <td>{String(inv.issued_at).split("T")[0]}</td>
                    </tr>
                ))
            }
        </tbody>
    </table>

    <script>
        const form = document.querySelector<HTMLFormElement>("#invoice-form");
        const csrf = document
            .querySelector("meta[name='csrf-token']")
            ?.getAttribute("content") || "";
        form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            if (!form) return;
            const data = new FormData(form);
            const response = await fetch("/api/admin/invoices", {
                method: "POST",
                headers: { "X-CSRF-Token": csrf },
                body: data,
            });
            if (response.ok) {
                location.reload();
            } else {
                alert(await response.text());
            }
        });
    </script>
</AdminLayout>
