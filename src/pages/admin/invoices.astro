---
import AdminLayout from "../../layouts/AdminLayout.astro";
import SectionHeader from "../../components/admin/SectionHeader.svelte";
import StatusBadge from "../../components/admin/StatusBadge.svelte";
import AdminDataTable from "../../components/admin/AdminDataTable.svelte";
import CrudInlineForm from "../../components/admin/CrudInlineForm.svelte";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const invoices = await db.execute(
    `SELECT i.invoice_no, i.status, i.issued_at, o.order_no, o.total
     FROM invoices i JOIN orders o ON o.id = i.order_id
     ORDER BY i.created_at DESC`,
);
---

<AdminLayout title="Invoice">
    <SectionHeader title="Buat Invoice" badge="Manual" />
    <CrudInlineForm id="invoice-form">
        <div>
            <label>Order No</label>
            <input name="order_no" required />
        </div>
        <button class="primary" type="submit">Buat Invoice</button>
    </CrudInlineForm>

    <div class="mt-6">
        <SectionHeader
            title="Daftar Invoice"
            muted="Auto update status di tahap berikutnya"
        />
    </div>
    <AdminDataTable>
            <thead>
                <tr>
                    <th>Invoice</th>
                    <th>Order</th>
                    <th>Total</th>
                    <th>Status</th>
                    <th>Tanggal</th>
                </tr>
            </thead>
            <tbody>
                {
                    invoices.rows.map((inv: any) => (
                        <tr>
                            <td>
                                <a href={`/admin/invoices/${inv.invoice_no}`}>
                                    {inv.invoice_no}
                                </a>
                            </td>
                            <td>{inv.order_no}</td>
                            <td>
                                Rp {Number(inv.total).toLocaleString("id-ID")}
                            </td>
                            <td>
                                <StatusBadge
                                    label={inv.status}
                                    tone={inv.status === "paid"
                                        ? "success"
                                        : inv.status === "void"
                                          ? "danger"
                                          : "default"}
                                />
                            </td>
                            <td>{String(inv.issued_at).split("T")[0]}</td>
                        </tr>
                    ))
                }
            </tbody>
    </AdminDataTable>

    <script>
        import { bindCreateForm } from "../../lib/admin-client";

        bindCreateForm({
            formSelector: "#invoice-form",
            endpoint: "/api/admin/invoices",
        });
    </script>
</AdminLayout>
