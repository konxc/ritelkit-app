---
import AdminLayout from "../../layouts/AdminLayout.astro";
import SectionHeader from "../../components/admin/SectionHeader.svelte";
import PaginationNav from "../../components/admin/PaginationNav.svelte";
import AdminDataTable from "../../components/admin/AdminDataTable.svelte";
import AdminToolbar from "../../components/admin/AdminToolbar.svelte";
import RowActions from "../../components/admin/RowActions.svelte";
import AdminFilterForm from "../../components/admin/AdminFilterForm.svelte";
import CrudInlineForm from "../../components/admin/CrudInlineForm.svelte";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";
import { parsePage } from "../../lib/admin";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const { page, q, offset, limit } = parsePage(Astro.url, 20);
const where = q ? "WHERE order_no LIKE ? OR tracking_no LIKE ?" : "";
const args = q ? [`%${q}%`, `%${q}%`] : [];

const shipmentsRes = await db.execute({
    sql: `SELECT id, order_no, status, carrier, tracking_no, shipped_at, delivered_at, notes
          FROM shipments
          ${where}
          ORDER BY created_at DESC
          LIMIT ? OFFSET ?`,
    args: [...args, limit, offset],
});
const countRes = await db.execute({
    sql: `SELECT COUNT(*) as count FROM shipments ${where}`,
    args,
});
const total = Number((countRes.rows[0] as any)?.count || 0);
const totalPages = Math.max(1, Math.ceil(total / limit));
---

<AdminLayout title="Fulfillment">
    <SectionHeader title="Buat Pengiriman" badge="Tracking" />
    <CrudInlineForm id="shipment-form">
        <div>
            <label>Order No</label>
            <input name="order_no" required />
        </div>
        <div>
            <label>Kurir</label>
            <input name="carrier" />
        </div>
        <div>
            <label>Resi</label>
            <input name="tracking_no" />
        </div>
        <div>
            <label>Status</label>
            <select name="status">
                <option value="packing">Packing</option>
                <option value="shipped">Dikirim</option>
                <option value="delivered">Terkirim</option>
                <option value="cancelled">Batal</option>
            </select>
        </div>
        <div>
            <label>Catatan</label>
            <input name="notes" />
        </div>
        <button class="primary" type="submit">Simpan</button>
    </CrudInlineForm>

    <AdminToolbar title="Daftar Pengiriman">
        <AdminFilterForm>
            <input name="q" placeholder="Cari order/resi" value={q} />
            <button class="btn-ghost" type="submit">Cari</button>
        </AdminFilterForm>
    </AdminToolbar>

    <AdminDataTable>
        <thead>
            <tr>
                <th>Order</th>
                <th>Status</th>
                <th>Kurir</th>
                <th>Resi</th>
                <th>Catatan</th>
                <th>Aksi</th>
            </tr>
        </thead>
        <tbody>
            {shipmentsRes.rows.map((s: any) => (
                <tr data-id={s.id}>
                    <td contenteditable="true" data-field="order_no">{s.order_no}</td>
                    <td contenteditable="true" data-field="status">{s.status}</td>
                    <td contenteditable="true" data-field="carrier">{s.carrier || ""}</td>
                    <td contenteditable="true" data-field="tracking_no">{s.tracking_no || ""}</td>
                    <td contenteditable="true" data-field="notes">{s.notes || ""}</td>
                    <td>
                        <RowActions />
                    </td>
                </tr>
            ))}
        </tbody>
    </AdminDataTable>

    <PaginationNav
        page={page}
        totalPages={totalPages}
        prevHref={page > 1 ? `?q=${encodeURIComponent(q)}&page=${page - 1}` : undefined}
        nextHref={page < totalPages ? `?q=${encodeURIComponent(q)}&page=${page + 1}` : undefined}
    />

    <script>
        import { bindCreateForm, bindCrudTable } from "../../lib/admin-client";

        bindCreateForm({
            formSelector: "#shipment-form",
            endpoint: "/api/admin/shipments",
        });

        bindCrudTable({
            basePath: "/api/admin/shipments",
            deleteConfirm: "Hapus pengiriman ini?",
        });
    </script>
</AdminLayout>
