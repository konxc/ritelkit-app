---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/auth";
import { getDb, initDb } from "../../lib/db";

await initDb(Astro);
const db = getDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
  const adminCountResult = await db.execute("SELECT COUNT(*) as count FROM admin_users");
  const shouldRedirectToSetup = Number(adminCountResult.rows[0]?.count || 0) === 0;
  if (shouldRedirectToSetup) {
    return Astro.redirect("/admin/setup");
  }
  return Astro.redirect("/admin/login");
}

const title = "Design System";
---

<AdminLayout title={title}>
    <div class="flex flex-col xl:flex-row gap-8 lg:gap-12 items-start animate-fade-in-up pb-12 relative">
    <!-- Desktop TOC Sidebar -->
    <aside class="hidden xl:flex flex-col w-[240px] shrink-0 sticky top-0 bg-white/50 backdrop-blur-2xl rounded-3xl p-6 border border-stone-200/60 shadow-[0_4px_24px_rgba(0,0,0,0.02)] z-10 h-auto">
        <h3 class="font-['Syne',sans-serif] font-bold text-stone-900 mb-4 text-sm tracking-wider uppercase">Daftar Komponen</h3>
        
        <nav class="flex flex-col gap-1.5 flex-1" id="design-system-toc-desktop">
            <a href="#typography" class="toc-link px-3 py-2 rounded-xl text-sm font-semibold transition-all data-[active=true]:bg-stone-900 data-[active=true]:text-white text-stone-500 hover:text-stone-900 hover:bg-stone-100">Typography</a>
            <a href="#colors" class="toc-link px-3 py-2 rounded-xl text-sm font-semibold transition-all data-[active=true]:bg-stone-900 data-[active=true]:text-white text-stone-500 hover:text-stone-900 hover:bg-stone-100">Colors Palette</a>
            <a href="#buttons" class="toc-link px-3 py-2 rounded-xl text-sm font-semibold transition-all data-[active=true]:bg-stone-900 data-[active=true]:text-white text-stone-500 hover:text-stone-900 hover:bg-stone-100">Buttons</a>
            <a href="#forms" class="toc-link px-3 py-2 rounded-xl text-sm font-semibold transition-all data-[active=true]:bg-stone-900 data-[active=true]:text-white text-stone-500 hover:text-stone-900 hover:bg-stone-100">Form Elements</a>
            <a href="#cards" class="toc-link px-3 py-2 rounded-xl text-sm font-semibold transition-all data-[active=true]:bg-stone-900 data-[active=true]:text-white text-stone-500 hover:text-stone-900 hover:bg-stone-100">Cards & States</a>
            <a href="#badges" class="toc-link px-3 py-2 rounded-xl text-sm font-semibold transition-all data-[active=true]:bg-stone-900 data-[active=true]:text-white text-stone-500 hover:text-stone-900 hover:bg-stone-100">Badges & Tags</a>
            <a href="#tables" class="toc-link px-3 py-2 rounded-xl text-sm font-semibold transition-all data-[active=true]:bg-stone-900 data-[active=true]:text-white text-stone-500 hover:text-stone-900 hover:bg-stone-100">Tables</a>
            <a href="#alerts" class="toc-link px-3 py-2 rounded-xl text-sm font-semibold transition-all data-[active=true]:bg-stone-900 data-[active=true]:text-white text-stone-500 hover:text-stone-900 hover:bg-stone-100">Alerts & Callouts</a>
            <a href="#navigation" class="toc-link px-3 py-2 rounded-xl text-sm font-semibold transition-all data-[active=true]:bg-stone-900 data-[active=true]:text-white text-stone-500 hover:text-stone-900 hover:bg-stone-100">Navigation & Pagination</a>
            <a href="#modals" class="toc-link px-3 py-2 rounded-xl text-sm font-semibold transition-all data-[active=true]:bg-stone-900 data-[active=true]:text-white text-stone-500 hover:text-stone-900 hover:bg-stone-100">Modals / Dialogs</a>
            <a href="#skeletons" class="toc-link px-3 py-2 rounded-xl text-sm font-semibold transition-all data-[active=true]:bg-stone-900 data-[active=true]:text-white text-stone-500 hover:text-stone-900 hover:bg-stone-100">Skeletons (Loading)</a>
            <a href="#tooltips" class="toc-link px-3 py-2 rounded-xl text-sm font-semibold transition-all data-[active=true]:bg-stone-900 data-[active=true]:text-white text-stone-500 hover:text-stone-900 hover:bg-stone-100">Tooltips & Popovers</a>
            <a href="#avatars" class="toc-link px-3 py-2 rounded-xl text-sm font-semibold transition-all data-[active=true]:bg-stone-900 data-[active=true]:text-white text-stone-500 hover:text-stone-900 hover:bg-stone-100">Avatars & Media</a>
        </nav>
    </aside>

    <div class="flex-1 space-y-16 w-full min-w-0 ds-content">

        <!-- Typography -->
        <section id="typography" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Typography
                </h2>
            </div>
            <div
                class="bg-white p-8 rounded-3xl border border-stone-200/60 shadow-[0_4px_20px_rgba(0,0,0,0.02)] grid gap-8"
            >
                <div>
                    <p
                        class="text-sm font-semibold tracking-wider text-stone-400 uppercase mb-3"
                    >
                        Headings (Syne)
                    </p>
                    <div class="space-y-4">
                        <h1
                            class="font-['Syne',sans-serif] text-4xl font-extrabold text-stone-900 tracking-tight"
                        >
                            Heading 1
                        </h1>
                        <h2
                            class="font-['Syne',sans-serif] text-3xl font-extrabold text-stone-900 tracking-tight"
                        >
                            Heading 2
                        </h2>
                        <h3
                            class="font-['Syne',sans-serif] text-2xl font-bold text-stone-900 tracking-tight"
                        >
                            Heading 3
                        </h3>
                        <h4
                            class="font-['Syne',sans-serif] text-xl font-bold text-stone-900 tracking-tight"
                        >
                            Heading 4
                        </h4>
                    </div>
                </div>
                <div class="w-full h-[1px] bg-stone-100"></div>
                <div>
                    <p
                        class="text-sm font-semibold tracking-wider text-stone-400 uppercase mb-3"
                    >
                        Body (Plus Jakarta Sans)
                    </p>
                    <div class="space-y-4 max-w-2xl text-stone-600">
                        <p class="text-lg">
                            <strong>Text Large:</strong> Roti Sholawat menghadirkan
                            rasa otentik dengan resep rahasia keluarga. Berdiri sejak
                            bertahun-tahun yang lalu.
                        </p>
                        <p class="text-base">
                            <strong>Text Base:</strong> Roti Sholawat menghadirkan
                            rasa otentik dengan resep rahasia keluarga. Berdiri sejak
                            bertahun-tahun yang lalu.
                        </p>
                        <p class="text-sm">
                            <strong>Text Small:</strong> Roti Sholawat menghadirkan
                            rasa otentik dengan resep rahasia keluarga. Berdiri sejak
                            bertahun-tahun yang lalu.
                        </p>
                        <p class="text-xs">
                            <strong>Text Extra Small:</strong> Roti Sholawat menghadirkan
                            rasa otentik dengan resep rahasia keluarga. Berdiri sejak
                            bertahun-tahun yang lalu.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Colors -->
        <section id="colors" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Colors Palette
                </h2>
            </div>
            <div
                class="bg-white p-8 rounded-3xl border border-stone-200/60 shadow-[0_4px_20px_rgba(0,0,0,0.02)]"
            >
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    <!-- Brand Colors -->
                    <div class="space-y-2">
                        <div
                            class="w-full h-20 rounded-2xl bg-[#c48a3a] shadow-sm"
                        >
                        </div>
                        <div class="font-semibold text-stone-900">
                            Brand Gold
                        </div>
                        <div class="text-xs text-stone-500 font-mono">
                            #c48a3a
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div
                            class="w-full h-20 rounded-2xl bg-[#a6722d] shadow-sm"
                        >
                        </div>
                        <div class="font-semibold text-stone-900">
                            Brand Dark
                        </div>
                        <div class="text-xs text-stone-500 font-mono">
                            #a6722d
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div
                            class="w-full h-20 rounded-2xl bg-gradient-to-br from-stone-900 to-stone-600 shadow-sm"
                        >
                        </div>
                        <div class="font-semibold text-stone-900">
                            Dark Gradient
                        </div>
                        <div class="text-xs text-stone-500 font-mono">
                            from-stone-900 to-600
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div
                            class="w-full h-20 rounded-2xl bg-gradient-to-r from-[#c48a3a] to-[#a6722d] shadow-sm"
                        >
                        </div>
                        <div class="font-semibold text-stone-900">
                            Gold Gradient
                        </div>
                        <div class="text-xs text-stone-500 font-mono">
                            from-[#c48a3a] to-[#a6722d]
                        </div>
                    </div>

                    <!-- Neutrals -->
                    <div class="space-y-2">
                        <div
                            class="w-full h-20 rounded-2xl border border-stone-200 bg-white shadow-sm"
                        >
                        </div>
                        <div class="font-semibold text-stone-900">
                            Surface (White)
                        </div>
                        <div class="text-xs text-stone-500 font-mono">
                            #ffffff
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div
                            class="w-full h-20 rounded-2xl border border-stone-200 bg-[#fdfcf9] shadow-sm"
                        >
                        </div>
                        <div class="font-semibold text-stone-900">
                            Background Base
                        </div>
                        <div class="text-xs text-stone-500 font-mono">
                            #fdfcf9
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div
                            class="w-full h-20 rounded-2xl bg-stone-100 shadow-sm"
                        >
                        </div>
                        <div class="font-semibold text-stone-900">
                            Neutral Light
                        </div>
                        <div class="text-xs text-stone-500 font-mono">
                            stone-100
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div
                            class="w-full h-20 rounded-2xl bg-stone-900 shadow-sm"
                        >
                        </div>
                        <div class="font-semibold text-stone-900">
                            Text Primary
                        </div>
                        <div class="text-xs text-stone-500 font-mono">
                            stone-900
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Buttons -->
        <section id="buttons" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Buttons
                </h2>
            </div>
            <div
                class="bg-white p-8 rounded-3xl border border-stone-200/60 shadow-[0_4px_20px_rgba(0,0,0,0.02)] space-y-8"
            >
                <div>
                    <p
                        class="text-sm font-semibold tracking-wider text-stone-400 uppercase mb-4"
                    >
                        Variants
                    </p>
                    <div class="flex flex-wrap gap-4 items-center">
                        <button
                            class="px-5 py-2.5 rounded-xl bg-gradient-to-r from-[#c48a3a] to-[#a6722d] text-white font-semibold shadow-[0_8px_16px_rgba(196,138,58,0.25)] hover:-translate-y-0.5 transition-all"
                        >
                            Primary Solid
                        </button>
                        <button
                            class="px-5 py-2.5 rounded-xl border-2 border-[#c48a3a] text-[#c48a3a] font-semibold hover:bg-[#c48a3a]/5 transition-all"
                        >
                            Primary Outline
                        </button>
                        <button
                            class="px-5 py-2.5 rounded-xl bg-stone-900 text-white font-semibold shadow-md hover:-translate-y-0.5 transition-all"
                        >
                            Secondary Dark
                        </button>
                        <button
                            class="px-5 py-2.5 rounded-xl border border-stone-200 bg-white font-semibold text-stone-600 hover:text-stone-900 hover:border-stone-300 hover:shadow-sm transition-all shadow-sm"
                        >
                            Outline Simple
                        </button>
                        <button
                            class="px-5 py-2.5 rounded-xl bg-stone-100 font-semibold text-stone-600 hover:bg-stone-200 hover:text-stone-900 transition-all"
                        >
                            Ghost / Soft
                        </button>
                        <button
                            class="px-5 py-2.5 rounded-xl bg-red-50 text-red-600 font-semibold border border-red-100 hover:bg-red-600 hover:text-white transition-all"
                        >
                            Danger Actions
                        </button>
                    </div>
                </div>

                <div class="w-full h-[1px] bg-stone-100"></div>

                <div>
                    <p
                        class="text-sm font-semibold tracking-wider text-stone-400 uppercase mb-4"
                    >
                        With Icons & Sizes
                    </p>
                    <div class="flex flex-wrap gap-4 items-center">
                        <button
                            class="flex items-center gap-2 px-6 py-3 rounded-2xl bg-gradient-to-r from-[#c48a3a] to-[#a6722d] text-white font-bold shadow-[0_8px_16px_rgba(196,138,58,0.25)] hover:-translate-y-0.5 transition-all text-[0.95rem]"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path d="M5 12h14"></path><path d="M12 5v14"
                                ></path></svg
                            >
                            Large with Icon
                        </button>

                        <button
                            class="flex items-center gap-2.5 px-4 py-2 rounded-xl border border-stone-200/80 bg-white/80 font-semibold text-stone-500 hover:text-stone-900 hover:bg-stone-50 cursor-pointer transition-all shadow-sm text-[0.85rem]"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path
                                    d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"
                                ></path><circle cx="12" cy="12" r="3"
                                ></circle></svg
                            >
                            Small Button
                        </button>

                        <button
                            class="w-10 h-10 rounded-xl border border-stone-200/80 bg-white flex items-center justify-center text-stone-500 cursor-pointer shadow-sm hover:text-red-500 hover:border-red-200 hover:bg-red-50 transition-all"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="18"
                                height="18"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2.5"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path d="M3 6h18"></path><path
                                    d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"
                                ></path><path
                                    d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"
                                ></path></svg
                            >
                        </button>

                        <button
                            class="w-8 h-8 rounded-lg flex items-center justify-center bg-stone-100 text-stone-400 hover:text-stone-800 hover:bg-stone-200 transition-colors cursor-pointer"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                ><path d="M12 5v14"></path><path d="M5 12h14"
                                ></path></svg
                            >
                        </button>
                    </div>
                </div>
            </div>
        </section>

        <!-- Inputs / Forms -->
        <section id="forms" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Form Elements
                </h2>
            </div>
            <div
                class="bg-white p-8 rounded-3xl border border-stone-200/60 shadow-[0_4px_20px_rgba(0,0,0,0.02)] grid grid-cols-1 md:grid-cols-2 gap-8"
            >
                <div class="space-y-4">
                    <div class="space-y-1.5">
                        <label
                            class="block text-sm font-semibold text-stone-700"
                            >Text Input (Default)</label
                        >
                        <input
                            type="text"
                            placeholder="Masukkan nama..."
                            class="w-full px-4 py-2.5 rounded-xl border border-stone-200 bg-white placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-[#c48a3a]/30 focus:border-[#c48a3a] transition-all text-stone-900"
                        />
                    </div>

                    <div class="space-y-1.5">
                        <label
                            class="block text-sm font-semibold text-stone-700"
                            >Text Input (With Error)</label
                        >
                        <input
                            type="text"
                            value="Salah format"
                            class="w-full px-4 py-2.5 rounded-xl border border-red-300 bg-red-50/50 text-red-900 focus:outline-none focus:ring-2 focus:ring-red-500/30 focus:border-red-500 transition-all"
                        />
                        <p class="text-xs text-red-500 font-medium">
                            Email tidak valid.
                        </p>
                    </div>

                    <div class="space-y-1.5">
                        <label
                            class="block text-sm font-semibold text-stone-700"
                            >Select Input</label
                        >
                        <select
                            class="w-full px-4 py-2.5 rounded-xl border border-stone-200 bg-white focus:outline-none focus:ring-2 focus:ring-[#c48a3a]/30 focus:border-[#c48a3a] transition-all text-stone-900 appearance-none cursor-pointer"
                        >
                            <option>Pilih Kategori</option>
                            <option>Roti Manis</option>
                            <option>Roti Tawar</option>
                        </select>
                    </div>
                </div>

                <div class="space-y-6">
                    <div class="space-y-1.5">
                        <label
                            class="block text-sm font-semibold text-stone-700"
                            >Textarea</label
                        >
                        <textarea
                            rows="4"
                            placeholder="Masukkan deskripsi..."
                            class="w-full px-4 py-2.5 rounded-xl border border-stone-200 bg-white placeholder:text-stone-400 focus:outline-none focus:ring-2 focus:ring-[#c48a3a]/30 focus:border-[#c48a3a] transition-all text-stone-900"
                        ></textarea>
                    </div>

                    <div class="flex items-center gap-3">
                        <input
                            type="checkbox"
                            id="checkbox1"
                            class="w-5 h-5 rounded border-stone-300 text-[#c48a3a] focus:ring-[#c48a3a] rounded-sm accent-[#c48a3a] cursor-pointer"
                            checked
                        />
                        <label
                            for="checkbox1"
                            class="text-sm font-medium text-stone-700 cursor-pointer"
                            >Aktifkan produk ini di katalog</label
                        >
                    </div>

                    <div class="flex items-center gap-3">
                        <label
                            class="relative inline-flex items-center cursor-pointer"
                        >
                            <input
                                type="checkbox"
                                value=""
                                class="sr-only peer"
                                checked
                            />
                            <div
                                class="w-11 h-6 bg-stone-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-[#c48a3a]/30 rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-stone-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-[#c48a3a]"
                            >
                            </div>
                            <span
                                class="ml-3 text-sm font-medium text-stone-700"
                                >Toggle Switch</span
                            >
                        </label>
                    </div>
                </div>
            </div>
        </section>

        <!-- Cards & Containers -->
        <section id="cards" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Cards & States
                </h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Data Card -->
                <div
                    class="bg-white rounded-3xl p-6 border border-stone-200/60 shadow-[0_4px_24px_rgba(0,0,0,0.02)] hover:shadow-[0_8px_32px_rgba(0,0,0,0.05)] transition-shadow"
                >
                    <div
                        class="w-12 h-12 rounded-2xl bg-stone-50 border border-stone-100 flex items-center justify-center text-[#c48a3a] mb-4"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="24"
                            height="24"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2.5"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            ><path
                                d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"
                            ></path><polyline points="14 2 14 8 20 8"
