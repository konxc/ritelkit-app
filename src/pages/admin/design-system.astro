    <script>
        document.addEventListener("astro:page-load", () => {
            const sections = document.querySelectorAll('.ds-section');
            const navLinks = document.querySelectorAll('.toc-link');
            
            if (!sections.length || !navLinks.length) return;

            const observer = new IntersectionObserver((entries) => {
                let currentId = '';
                entries.forEach(entry => {
                    // Check if element is reasonably visible
                    if (entry.isIntersecting) {
                        currentId = entry.target.id;
                    }
                });

                if (currentId) {
                    navLinks.forEach(link => {
                        const hrefAttr = link.getAttribute('href');
                        if (hrefAttr) {
                            const href = hrefAttr.substring(1);
                            if (href === currentId) {
                                link.setAttribute('data-active', 'true');
                            } else {
                                link.removeAttribute('data-active');
                            }
                        }
                    });
                }
            }, { 
                rootMargin: '-100px 0px -40% 0px',
                threshold: 0.2
            });

            sections.forEach(section => observer.observe(section));

            // Mobile Drawer Logic
            const drawerBtn = document.getElementById('ds-drawer-btn');
            const drawerClose = document.getElementById('ds-drawer-close');
            const drawer = document.getElementById('ds-drawer');
            const backdrop = document.getElementById('ds-drawer-backdrop');

            function toggleDrawer(force?: boolean) {
                if(!drawer || !backdrop) return;
                const isOpening = force !== undefined ? force : drawer.classList.contains('translate-x-full');
                
                if (isOpening) {
                    drawer.classList.remove('translate-x-full');
                    backdrop.classList.remove('opacity-0', 'pointer-events-none');
                    document.body.style.overflow = 'hidden'; // Prevent scrolling bg
                } else {
                    drawer.classList.add('translate-x-full');
                    backdrop.classList.add('opacity-0', 'pointer-events-none');
                    document.body.style.overflow = '';
                }
            }

            if (drawerBtn) drawerBtn.addEventListener('click', () => toggleDrawer(true));
            if (drawerClose) drawerClose.addEventListener('click', () => toggleDrawer(false));
            if (backdrop) backdrop.addEventListener('click', () => toggleDrawer(false));

            // Close drawer when a link is clicked on mobile
            navLinks.forEach(link => {
                link.addEventListener('click', () => {
                    if (window.innerWidth < 1280) { // xl breakpoint
                        toggleDrawer(false);
                    }
                });
            });
            
            // Set first item active manually on load if at top
            if(window.scrollY < 100) {
                 navLinks[0]?.setAttribute('data-active', 'true');
            }
        });
    </script>

