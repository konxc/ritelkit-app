---
import Alert from "../../components/admin/ui/feedback/Alert.svelte";
import Modal from "../../components/admin/ui/overlay/Modal.svelte";
import Tooltip from "../../components/admin/ui/overlay/Tooltip.svelte";
import Popover from "../../components/admin/ui/overlay/Popover.svelte";
import Pagination from "../../components/admin/ui/navigation/Pagination.svelte";
import Tabs from "../../components/admin/ui/navigation/Tabs.svelte";
import Breadcrumbs from "../../components/admin/ui/navigation/Breadcrumbs.svelte";
import TextInput from "../../components/admin/ui/forms/TextInput.svelte";
import Textarea from "../../components/admin/ui/forms/Textarea.svelte";
import SelectInput from "../../components/admin/ui/forms/SelectInput.svelte";
import Checkbox from "../../components/admin/ui/forms/Checkbox.svelte";
import ToggleSwitch from "../../components/admin/ui/forms/ToggleSwitch.svelte";
import Avatar from "../../components/admin/ui/media/Avatar.svelte";
import AvatarStack from "../../components/admin/ui/media/AvatarStack.svelte";
import ProductThumbnail from "../../components/admin/ui/media/ProductThumbnail.svelte";
import Card from "../../components/admin/ui/Card.svelte";
import StatCard from "../../components/admin/ui/StatCard.svelte";
import ActionCard from "../../components/admin/ui/ActionCard.svelte";
import EmptyState from "../../components/admin/ui/EmptyState.svelte";
import Skeleton from "../../components/admin/ui/feedback/Skeleton.svelte";
import Table from "../../components/admin/ui/Table.svelte";
import TableRow from "../../components/admin/ui/TableRow.svelte";
import TableCell from "../../components/admin/ui/TableCell.svelte";
import Button from "../../components/admin/ui/Button.svelte";
import Badge from "../../components/admin/ui/Badge.svelte";
import AsideNav from "../../components/admin/ui/layout/AsideNav.svelte";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/auth";
import { getDb, initDb } from "../../lib/db";

await initDb(Astro);
const db = getDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
  const adminCountResult = await db.execute("SELECT COUNT(*) as count FROM admin_users");
  const shouldRedirectToSetup = Number(adminCountResult.rows[0]?.count || 0) === 0;
  if (shouldRedirectToSetup) {
    return Astro.redirect("/admin/setup");
  }
  return Astro.redirect("/admin/login");
}

const title = "Sistem Desain";

const tocItems = [
  { id: "typography", label: "Typography" },
  { id: "colors", label: "Colors Palette" },
  { id: "buttons", label: "Buttons" },
  { id: "forms", label: "Form Elements" },
  { id: "cards", label: "Cards & States" },
  { id: "badges", label: "Badges & Tags" },
  { id: "tables", label: "Tables" },
  { id: "alerts", label: "Alerts & Callouts" },
  { id: "navigation", label: "Navigation & Pagination" },
  { id: "modals", label: "Modals / Dialogs" },
  { id: "skeletons", label: "Skeletons (Loading)" },
  { id: "tooltips", label: "Tooltips & Popovers" },
  { id: "avatars", label: "Avatars & Media" },
];
---

<AdminLayout title={title}>
  <div class="animate-fade-in-up relative flex flex-col items-start gap-8 pb-12 lg:gap-12 xl:flex-row">
    <!-- Desktop & Mobile TOC Navigation -->
    <AsideNav items={tocItems} title="Daftar Komponen" side="right" client:load />

    <div class="ds-content w-full min-w-0 flex-1 space-y-16">
      <!-- Typography -->
      <section id="typography" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">Typography</h2>
        </div>
        <div
          class="grid gap-8 rounded-3xl border border-stone-200/60 bg-white p-8 shadow-[0_4px_20px_rgba(0,0,0,0.02)]"
        >
          <div>
            <p class="mb-3 text-sm font-semibold tracking-wider text-stone-400 uppercase">Headings (Syne)</p>
            <div class="space-y-4">
              <h1 class="font-['Syne',sans-serif] text-4xl font-extrabold tracking-tight text-stone-900">Heading 1</h1>
              <h2 class="font-['Syne',sans-serif] text-3xl font-extrabold tracking-tight text-stone-900">Heading 2</h2>
              <h3 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-900">Heading 3</h3>
              <h4 class="font-['Syne',sans-serif] text-xl font-bold tracking-tight text-stone-900">Heading 4</h4>
            </div>
          </div>
          <div class="h-[1px] w-full bg-stone-100"></div>
          <div>
            <p class="mb-3 text-sm font-semibold tracking-wider text-stone-400 uppercase">Body (Plus Jakarta Sans)</p>
            <div class="max-w-2xl space-y-4 text-stone-600">
              <p class="text-lg">
                <strong>Text Large:</strong> Roti Sholawat menghadirkan rasa otentik dengan resep rahasia keluarga. Berdiri
                sejak bertahun-tahun yang lalu.
              </p>
              <p class="text-base">
                <strong>Text Base:</strong> Roti Sholawat menghadirkan rasa otentik dengan resep rahasia keluarga. Berdiri
                sejak bertahun-tahun yang lalu.
              </p>
              <p class="text-sm">
                <strong>Text Small:</strong> Roti Sholawat menghadirkan rasa otentik dengan resep rahasia keluarga. Berdiri
                sejak bertahun-tahun yang lalu.
              </p>
              <p class="text-xs">
                <strong>Text Extra Small:</strong> Roti Sholawat menghadirkan rasa otentik dengan resep rahasia keluarga.
                Berdiri sejak bertahun-tahun yang lalu.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Colors -->
      <section id="colors" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">Colors Palette</h2>
        </div>
        <div class="rounded-3xl border border-stone-200/60 bg-white p-8 shadow-[0_4px_20px_rgba(0,0,0,0.02)]">
          <div class="grid grid-cols-2 gap-6 md:grid-cols-4">
            <!-- Brand Colors -->
            <div class="space-y-2">
              <div class="h-20 w-full rounded-2xl bg-[#c48a3a] shadow-sm"></div>
              <div class="font-semibold text-stone-900">Brand Gold</div>
              <div class="font-mono text-xs text-stone-500">#c48a3a</div>
            </div>
            <div class="space-y-2">
              <div class="h-20 w-full rounded-2xl bg-[#a6722d] shadow-sm"></div>
              <div class="font-semibold text-stone-900">Brand Dark</div>
              <div class="font-mono text-xs text-stone-500">#a6722d</div>
            </div>
            <div class="space-y-2">
              <div class="h-20 w-full rounded-2xl bg-gradient-to-br from-stone-900 to-stone-600 shadow-sm"></div>
              <div class="font-semibold text-stone-900">Dark Gradient</div>
              <div class="font-mono text-xs text-stone-500">from-stone-900 to-600</div>
            </div>
            <div class="space-y-2">
              <div class="h-20 w-full rounded-2xl bg-gradient-to-r from-[#c48a3a] to-[#a6722d] shadow-sm"></div>
              <div class="font-semibold text-stone-900">Gold Gradient</div>
              <div class="font-mono text-xs text-stone-500">from-[#c48a3a] to-[#a6722d]</div>
            </div>

            <!-- Neutrals -->
            <div class="space-y-2">
              <div class="h-20 w-full rounded-2xl border border-stone-200 bg-white shadow-sm"></div>
              <div class="font-semibold text-stone-900">Surface (White)</div>
              <div class="font-mono text-xs text-stone-500">#ffffff</div>
            </div>
            <div class="space-y-2">
              <div class="h-20 w-full rounded-2xl border border-stone-200 bg-[#fdfcf9] shadow-sm"></div>
              <div class="font-semibold text-stone-900">Background Base</div>
              <div class="font-mono text-xs text-stone-500">#fdfcf9</div>
            </div>
            <div class="space-y-2">
              <div class="h-20 w-full rounded-2xl bg-stone-100 shadow-sm"></div>
              <div class="font-semibold text-stone-900">Neutral Light</div>
              <div class="font-mono text-xs text-stone-500">stone-100</div>
            </div>
            <div class="space-y-2">
              <div class="h-20 w-full rounded-2xl bg-stone-900 shadow-sm"></div>
              <div class="font-semibold text-stone-900">Text Primary</div>
              <div class="font-mono text-xs text-stone-500">stone-900</div>
            </div>
          </div>
        </div>
      </section>

      <!-- Buttons -->
      <section id="buttons" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">Buttons</h2>
        </div>
        <div class="space-y-8 rounded-3xl border border-stone-200/60 bg-white p-8 shadow-[0_4px_20px_rgba(0,0,0,0.02)]">
          <div>
            <p class="mb-4 text-sm font-semibold tracking-wider text-stone-400 uppercase">Variants</p>
            <div class="flex flex-wrap items-center gap-4">
              <Button variant="primary">Primary Solid</Button>
              <Button variant="outline">Primary Outline</Button>
              <Button variant="secondary">Secondary Dark</Button>
              <Button variant="simple">Outline Simple</Button>
              <Button variant="ghost">Ghost / Soft</Button>
              <Button variant="danger">Danger Actions</Button>
            </div>
          </div>

          <div class="h-[1px] w-full bg-stone-100"></div>

          <div>
            <p class="mb-4 text-sm font-semibold tracking-wider text-stone-400 uppercase">With Icons & Sizes</p>
            <div class="flex flex-wrap items-center gap-4">
              <Button variant="primary" size="lg">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg
                >
                Large with Icon
              </Button>

              <Button variant="simple" size="sm">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"
                  ></path><circle cx="12" cy="12" r="3"></circle></svg
                >
                Small Button
              </Button>

              <Button variant="simple" size="icon" class="hover:border-red-200 hover:bg-red-50 hover:text-red-500">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path
                    d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg
                >
              </Button>

              <Button variant="ghost" size="icon-sm">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"><path d="M12 5v14"></path><path d="M5 12h14"></path></svg
                >
              </Button>
            </div>
          </div>
        </div>
      </section>

      <!-- Inputs / Forms -->
      <section id="forms" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">Form Elements</h2>
        </div>
        <div
          class="grid grid-cols-1 gap-8 rounded-3xl border border-stone-200/60 bg-white p-8 shadow-[0_4px_20px_rgba(0,0,0,0.02)] md:grid-cols-2"
        >
          <div class="space-y-4">
            <TextInput label="Text Input (Default)" placeholder="Masukkan nama..." />

            <TextInput label="Text Input (With Error)" value="Salah format" error="Email tidak valid." />

            <SelectInput
              label="Select Input"
              options={[
                { label: "Pilih Kategori", value: "" },
                { label: "Roti Manis", value: "manis" },
                { label: "Roti Tawar", value: "tawar" },
              ]}
            />
          </div>

          <div class="space-y-6">
            <Textarea label="Textarea" placeholder="Masukkan deskripsi..." rows={4} />

            <Checkbox id="checkbox1"> Aktifkan produk ini di katalog </Checkbox>

            <ToggleSwitch label="Toggle Switch" checked={true} client:load />
          </div>
        </div>
      </section>

      <!-- Cards & Containers -->
      <section id="cards" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">Cards & States</h2>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
          <!-- Data Card -->
          <StatCard label="Total Pesanan" value="1,280" trend="+12.5%" trendType="up">
            <svg
              slot="icon"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline
                points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line
                x1="16"
                y1="17"
                x2="8"
                y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg
            >
          </StatCard>

          <!-- Info Card (Custom themed using Base Card) -->
          <Card class="relative overflow-hidden bg-gradient-to-br from-stone-900 to-stone-800 text-white">
            <div class="pointer-events-none absolute -top-6 -right-6 h-32 w-32 rounded-full bg-white/5 blur-2xl"></div>
            <div
              class="relative z-10 mb-4 flex h-12 w-12 items-center justify-center rounded-2xl border border-white/5 bg-white/10 text-[#c48a3a]"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg
              >
            </div>
            <h3 class="relative z-10 mb-1 text-xl font-bold">Premium Member</h3>
            <p class="relative z-10 text-sm text-stone-400">Akses semua fitur analitik tingkat lanjut.</p>
          </Card>

          <!-- Action Card -->
          <ActionCard title="Tambah Kategori Baru">
            <svg
              slot="icon"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg
            >
          </ActionCard>
        </div>

        <div class="mt-8 space-y-4">
          <h3 class="mb-4 text-sm font-bold tracking-wider text-stone-500 uppercase">Structural Panels & States</h3>
          <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
            <!-- Standard Panel -->
            <Card rounded="3xl">
              <div class="mb-6 flex items-center justify-between">
                <h2 class="font-['Syne',sans-serif] text-xl font-bold text-stone-800">Kartu Panel Standar</h2>
                <a href="#" class="text-sm font-bold text-[#c48a3a] transition-colors hover:text-[#a6722d]"
                  >Lihat Semua</a
                >
              </div>
              <p class="text-sm text-stone-500">
                Wadah serbaguna untuk membungkus konten seperti tabel, daftar, atau form. Memiliki bayangan minimalis
                dan sudut melengkung 24px (1.5rem) sesuai styling Roti Sholawat.
              </p>
            </Card>

            <!-- Empty State -->
            <EmptyState
              title="State Kosong (Empty State)"
              description="Tampilan pengganti ketika tabel pesanan atau data laporan kosong atau belum memiliki data."
            >
              <svg
                slot="icon"
                xmlns="http://www.w3.org/2000/svg"
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect width="8" height="4" x="8" y="2" rx="1" ry="1"></rect><path
                  d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path></svg
              >
            </EmptyState>
          </div>
        </div>
      </section>

      <!-- Lencana & Status -->
      <section id="badges" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">Badges & Tags</h2>
        </div>
        <div class="rounded-3xl border border-stone-200/60 bg-white p-6 shadow-sm">
          <div class="flex flex-wrap gap-4">
            <Badge variant="success" showDot={true}>Selesai</Badge>
            <Badge variant="warning" showDot={true}>Menunggu Pembayaran</Badge>
            <Badge variant="info" showDot={true}>Sedang Dikemas</Badge>
            <Badge variant="default" showDot={true}>Draf</Badge>
            <Badge variant="danger" showDot={true}>Dibatalkan</Badge>
          </div>
        </div>
      </section>

      <!-- Tables -->
      <section id="tables" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">Tables</h2>
        </div>
        <Table headers={["ID Pesanan", "Pelanggan", "Tanggal", "Status", "Total", "Aksi"]}>
          <TableRow>
            <TableCell bold={true}>#ORD-001</TableCell>
            <TableCell text-stone-600>Budi Santoso</TableCell>
            <TableCell class="text-stone-500">20 Okt 2026</TableCell>
            <TableCell>
              <Badge variant="success" showDot={true}>Selesai</Badge>
            </TableCell>
            <TableCell bold={true}>Rp 150.000</TableCell>
            <TableCell align="right">
              <Button variant="ghost" size="sm" class="font-bold text-[#c48a3a] hover:bg-[#c48a3a]/5">Detail</Button>
            </TableCell>
          </TableRow>
          <TableRow>
            <TableCell bold={true}>#ORD-002</TableCell>
            <TableCell text-stone-600>Siti Aminah</TableCell>
            <TableCell class="text-stone-500">21 Okt 2026</TableCell>
            <TableCell>
              <Badge variant="warning" showDot={true}>Menunggu</Badge>
            </TableCell>
            <TableCell bold={true}>Rp 75.000</TableCell>
            <TableCell align="right">
              <Button variant="ghost" size="sm" class="font-bold text-[#c48a3a] hover:bg-[#c48a3a]/5">Detail</Button>
            </TableCell>
          </TableRow>
        </Table>
      </section>

      <!-- Alerts & Callouts -->
      <section id="alerts" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">Alerts & Callouts</h2>
        </div>
        <div class="grid grid-cols-1 gap-4">
          <!-- Info Alert -->
          <Alert
            variant="info"
            title="Informasi"
            message="Pembaruan sistem akan dilakukan pada hari Sabtu pukul 00:00 WIB."
          />

          <!-- Success Alert -->
          <Alert variant="success" title="Berhasil" message="Data produk berhasil disimpan ke dalam sistem." />

          <!-- Warning Alert -->
          <Alert variant="warning" title="Peringatan" message="Stok produk 'Roti Coklat' tersisa 5 buah." />

          <!-- Error Alert -->
          <Alert variant="error" title="Gagal" message="Gagal mengunggah foto. Pastikan ukuran file di bawah 2MB." />
        </div>
      </section>

      <!-- Pagination & Navigation -->
      <section id="navigation" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            Navigation & Pagination
          </h2>
        </div>

        <div class="space-y-8 rounded-3xl border border-stone-200/60 bg-white p-8 shadow-[0_4px_20px_rgba(0,0,0,0.02)]">
          <!-- Pagination -->
          <div>
            <h3 class="mb-4 text-sm font-semibold tracking-wider text-stone-400 uppercase">Pagination</h3>
            <Pagination currentPage={1} totalPages={10} client:load />
          </div>

          <div class="h-[1px] w-full bg-stone-100"></div>

          <!-- Tabs -->
          <div>
            <h3 class="mb-4 text-sm font-semibold tracking-wider text-stone-400 uppercase">Tabs</h3>
            <Tabs
              tabs={[
                { id: "semua", label: "Semua" },
                { id: "aktif", label: "Aktif" },
                { id: "draf", label: "Draf" },
              ]}
              activeTab="semua"
              client:load
            />
          </div>

          <div class="h-[1px] w-full bg-stone-100"></div>

          <!-- Breadcrumbs -->
          <div>
            <h3 class="mb-4 text-sm font-semibold tracking-wider text-stone-400 uppercase">Breadcrumbs</h3>
            <Breadcrumbs
              items={[{ label: "Beranda", href: "#" }, { label: "Produk", href: "#" }, { label: "Roti Manis Coklat" }]}
            />
          </div>
        </div>
      </section>

      <!-- Modals -->
      <section id="modals" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            Modals / Dialogs Output Formats
          </h2>
        </div>

        <div
          class="flex flex-col items-center justify-center gap-8 rounded-3xl border border-stone-200/50 bg-stone-100/50 p-8 md:flex-row"
        >
          <!-- Standard Modal -->
          <Modal
            inline={true}
            title="Ubah Status"
            description="Apakah Anda yakin ingin mengubah status pesanan ini menjadi selesai?"
          >
            <Fragment slot="footer">
              <Button variant="ghost" class="font-bold">Batal</Button>
              <Button variant="primary">Konfirmasi</Button>
            </Fragment>
          </Modal>

          <!-- Danger Modal -->
          <Modal
            inline={true}
            title="Hapus Produk"
            description="Tindakan ini tidak dapat dibatalkan. Produk akan dihapus secara permanen dari database."
            class="text-center"
          >
            <div
              class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full border-4 border-white bg-red-50 text-red-500 shadow-[0_4px_12px_rgba(239,68,68,0.1)]"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path
                  d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path><line x1="10" x2="10" y1="11" y2="17"></line><line
                  x1="14"
                  x2="14"
                  y1="11"
                  y2="17"></line></svg
              >
            </div>

            <Fragment slot="footer">
              <div class="flex w-full flex-col gap-2">
                <Button variant="danger" class="w-full">Ya, Hapus Produk</Button>
                <Button variant="ghost" class="w-full font-bold">Batal</Button>
              </div>
            </Fragment>
          </Modal>
        </div>
      </section>
      <!-- Skeletons -->
      <section id="skeletons" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            Skeletons (Loading States)
          </h2>
        </div>

        <div
          class="grid gap-8 rounded-3xl border border-stone-200/60 bg-white p-8 shadow-[0_4px_20px_rgba(0,0,0,0.02)]"
        >
          <div>
            <p class="mb-4 text-sm font-semibold tracking-wider text-stone-400 uppercase">Text & Elements</p>
            <div class="max-w-lg space-y-4">
              <Skeleton height="h-8" width="w-3/4" />
              <div class="space-y-2">
                <Skeleton height="h-4" width="w-full" />
                <Skeleton height="h-4" width="w-5/6" />
                <Skeleton height="h-4" width="w-4/6" />
              </div>
              <div class="flex gap-3 pt-2">
                <Skeleton height="h-10" width="w-24" rounded="xl" />
                <Skeleton height="h-10" width="w-24" rounded="xl" />
              </div>
            </div>
          </div>

          <div class="h-[1px] w-full bg-stone-100"></div>

          <div>
            <p class="mb-4 text-sm font-semibold tracking-wider text-stone-400 uppercase">Card Placeholder</p>
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
              <div class="space-y-4 rounded-3xl border border-stone-200 p-6">
                <Skeleton height="h-12" width="w-12" rounded="2xl" />
                <div class="space-y-2">
                  <Skeleton height="h-4" width="w-1/3" />
                  <Skeleton height="h-8" width="w-1/2" />
                </div>
              </div>
              <div class="flex items-center gap-4 space-y-4 rounded-3xl border border-stone-200 p-6">
                <Skeleton height="h-16" width="w-16" rounded="full" />
                <div class="w-full space-y-2">
                  <Skeleton height="h-5" width="w-2/3" />
                  <Skeleton height="h-4" width="w-1/2" />
                  <Skeleton height="h-4" width="w-1/3" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Tooltips & Popovers -->
      <section id="tooltips" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">Tooltips & Popovers</h2>
        </div>

        <div
          class="flex flex-wrap items-center justify-center gap-12 rounded-3xl border border-stone-200/60 bg-[#fdfcf9] p-12 shadow-inner"
        >
          <!-- Tooltip Top -->
          <Tooltip text="Edit Data" position="top" client:load>
            <Button variant="simple" size="icon" class="h-12 w-12 rounded-xl">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M12 20h9"></path><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 Z"></path></svg
              >
            </Button>
          </Tooltip>

          <!-- Tooltip Bottom Danger -->
          <Tooltip text="Hapus Permanen" position="bottom" variant="danger" client:load>
            <Button
              variant="simple"
              size="icon"
              class="h-12 w-12 rounded-xl text-red-500 hover:border-red-200 hover:bg-red-50 hover:text-red-600"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path
                  d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg
              >
            </Button>
          </Tooltip>

          <!-- Popover Interactive -->
          <Popover client:load>
            <Button slot="trigger" variant="simple" class="group flex items-center gap-2 font-semibold text-stone-700">
              Opsi Lanjutan
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-stone-400 transition-transform duration-300 group-hover:rotate-180"
                ><path d="m6 9 6 6 6-6"></path></svg
              >
            </Button>

            <div class="rounded-2xl border border-stone-200/80 bg-white p-2 shadow-[0_10px_40px_rgba(0,0,0,0.1)]">
              <Button variant="ghost" size="sm" href="#" class="block w-full text-left font-medium text-stone-700"
                >Unduh Laporan</Button
              >
              <Button variant="ghost" size="sm" href="#" class="block w-full text-left font-medium text-stone-700"
                >Bagikan Link</Button
              >
              <div class="my-1 h-[1px] w-full bg-stone-100"></div>
              <Button
                variant="ghost"
                size="sm"
                href="#"
                class="block w-full text-left font-bold text-red-600 hover:bg-red-50">Bekukan Akun</Button
              >
            </div>
          </Popover>
        </div>
      </section>

      <!-- Avatars & Media -->
      <section id="avatars" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            Avatars & Media Containers
          </h2>
        </div>

        <div
          class="grid grid-cols-1 gap-12 rounded-3xl border border-stone-200/60 bg-white p-8 shadow-[0_4px_20px_rgba(0,0,0,0.02)] md:grid-cols-2"
        >
          <!-- User Avatars -->
          <div>
            <p class="mb-5 text-sm font-semibold tracking-wider text-stone-400 uppercase">User Profiles</p>

            <div class="mb-8 flex flex-wrap items-end gap-6">
              <Avatar
                size="lg"
                status="online"
                src="https://ui-avatars.com/api/?name=Admin+Utama&background=c48a3a&color=fff&size=128"
                alt="Admin"
              />
              <Avatar
                size="md"
                src="https://ui-avatars.com/api/?name=Budi+S&background=f3f4f6&color=374151&size=128"
                alt="User"
              />
              <Avatar size="sm" initials="SA" />
            </div>

            <!-- Avatar Stack (Overlap) -->
            <p class="mb-3 text-xs font-semibold tracking-wider text-stone-400 uppercase">Avatar Stack (Team)</p>
            <AvatarStack
              users={[
                { src: "https://ui-avatars.com/api/?name=User+A&background=random" },
                { src: "https://ui-avatars.com/api/?name=User+B&background=random" },
                { src: "https://ui-avatars.com/api/?name=User+C&background=random" },
                { initials: "D" },
                { initials: "E" },
                { initials: "F" },
                { initials: "G" },
              ]}
              limit={3}
            />
          </div>

          <!-- Product Images -->
          <div>
            <p class="mb-5 text-sm font-semibold tracking-wider text-stone-400 uppercase">Thumbnail Produk</p>

            <div class="grid grid-cols-2 gap-4">
              <ProductThumbnail isEmpty={true} />
              <ProductThumbnail
                src="https://images.unsplash.com/photo-1509440159596-0249088772ff?q=80&w=2072&auto=format&fit=crop"
                alt="Roti Manis"
              />
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>

  <script>
    // Placeholder for any non-nav related page scripts
    document.addEventListener("astro:page-load", () => {
      // No more imperative drawer/toc logic needed! All modular.
    });
  </script>

  <Fragment slot="modals">
    <!-- Modals are now handled modularly or via this slot -->
  </Fragment>
</AdminLayout>
