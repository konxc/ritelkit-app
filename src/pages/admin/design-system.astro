                    <h3
                        class="font-bold text-stone-900 text-sm group-hover:text-[#c48a3a] transition-colors"
                    >
                        Tambah Kategori Baru
                    </h3>
                </div>
            </div>
        </section>

        <!-- Badges & Status -->
        <section class="space-y-6">
            <div class="border-b border-stone-200 pb-2">
                <h2
                    class="font-['Syne',sans-serif] text-xl font-bold text-stone-800"
