                    class="group bg-[#fdfcf9] rounded-3xl p-6 border-2 border-dashed border-stone-200 hover:border-[#c48a3a]/50 hover:bg-[#c48a3a]/5 transition-colors cursor-pointer flex flex-col items-center justify-center text-center"
