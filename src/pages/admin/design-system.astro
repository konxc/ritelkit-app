---
import Alert from "../../components/admin/ui/feedback/Alert.svelte";
import Modal from "../../components/admin/ui/overlay/Modal.svelte";
import Tooltip from "../../components/admin/ui/overlay/Tooltip.svelte";
import Popover from "../../components/admin/ui/overlay/Popover.svelte";
import Pagination from "../../components/admin/ui/navigation/Pagination.svelte";
import Tabs from "../../components/admin/ui/navigation/Tabs.svelte";
import Breadcrumbs from "../../components/admin/ui/navigation/Breadcrumbs.svelte";
import TextInput from "../../components/admin/ui/forms/TextInput.svelte";
import Textarea from "../../components/admin/ui/forms/Textarea.svelte";
import SelectInput from "../../components/admin/ui/forms/SelectInput.svelte";
import Checkbox from "../../components/admin/ui/forms/Checkbox.svelte";
import ToggleSwitch from "../../components/admin/ui/forms/ToggleSwitch.svelte";
import Avatar from "../../components/admin/ui/media/Avatar.svelte";
import AvatarStack from "../../components/admin/ui/media/AvatarStack.svelte";
import ProductThumbnail from "../../components/admin/ui/media/ProductThumbnail.svelte";
import Card from "../../components/admin/ui/Card.svelte";
import StatCard from "../../components/admin/ui/StatCard.svelte";
import ActionCard from "../../components/admin/ui/ActionCard.svelte";
import EmptyState from "../../components/admin/ui/EmptyState.svelte";
import Skeleton from "../../components/admin/ui/feedback/Skeleton.svelte";
import Table from "../../components/admin/ui/Table.svelte";
import TableRow from "../../components/admin/ui/TableRow.svelte";
import TableCell from "../../components/admin/ui/TableCell.svelte";
import Button from "../../components/admin/ui/Button.svelte";
import Badge from "../../components/admin/ui/Badge.svelte";
import AsideNav from "../../components/admin/ui/layout/AsideNav.svelte";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/auth";
import { getDb, initDb } from "../../lib/db";

await initDb(Astro);
const db = getDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
  const adminCountResult = await db.execute("SELECT COUNT(*) as count FROM admin_users");
  const shouldRedirectToSetup = Number(adminCountResult.rows[0]?.count || 0) === 0;
  if (shouldRedirectToSetup) {
    return Astro.redirect("/admin/setup");
  }
  return Astro.redirect("/admin/login");
}

const title = "Design System";

const tocItems = [
  { id: "typography", label: "Typography" },
  { id: "colors", label: "Colors Palette" },
  { id: "buttons", label: "Buttons" },
  { id: "forms", label: "Form Elements" },
  { id: "cards", label: "Cards & States" },
  { id: "badges", label: "Badges & Tags" },
  { id: "tables", label: "Tables" },
  { id: "alerts", label: "Alerts & Callouts" },
  { id: "navigation", label: "Navigation & Pagination" },
  { id: "modals", label: "Modals / Dialogs" },
  { id: "skeletons", label: "Skeletons (Loading)" },
  { id: "tooltips", label: "Tooltips & Popovers" },
  { id: "avatars", label: "Avatars & Media" },
];
---

<AdminLayout title={title}>
    <div class="flex flex-col xl:flex-row gap-8 lg:gap-12 items-start animate-fade-in-up pb-12 relative">
    <!-- Desktop & Mobile TOC Navigation -->
    <AsideNav items={tocItems} title="Daftar Komponen" side="right" client:load />

    <div class="flex-1 space-y-16 w-full min-w-0 ds-content">

        <!-- Typography -->
        <section id="typography" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Typography
                </h2>
            </div>
            <div
                class="bg-white p-8 rounded-3xl border border-stone-200/60 shadow-[0_4px_20px_rgba(0,0,0,0.02)] grid gap-8"
            >
                <div>
                    <p
                        class="text-sm font-semibold tracking-wider text-stone-400 uppercase mb-3"
                    >
                        Headings (Syne)
                    </p>
                    <div class="space-y-4">
                        <h1
                            class="font-['Syne',sans-serif] text-4xl font-extrabold text-stone-900 tracking-tight"
                        >
                            Heading 1
                        </h1>
                        <h2
                            class="font-['Syne',sans-serif] text-3xl font-extrabold text-stone-900 tracking-tight"
                        >
                            Heading 2
                        </h2>
                        <h3
                            class="font-['Syne',sans-serif] text-2xl font-bold text-stone-900 tracking-tight"
                        >
                            Heading 3
                        </h3>
                        <h4
                            class="font-['Syne',sans-serif] text-xl font-bold text-stone-900 tracking-tight"
                        >
                            Heading 4
                        </h4>
                    </div>
                </div>
                <div class="w-full h-[1px] bg-stone-100"></div>
                <div>
                    <p
                        class="text-sm font-semibold tracking-wider text-stone-400 uppercase mb-3"
                    >
                        Body (Plus Jakarta Sans)
                    </p>
                    <div class="space-y-4 max-w-2xl text-stone-600">
                        <p class="text-lg">
                            <strong>Text Large:</strong> Roti Sholawat menghadirkan
                            rasa otentik dengan resep rahasia keluarga. Berdiri sejak
                            bertahun-tahun yang lalu.
                        </p>
                        <p class="text-base">
                            <strong>Text Base:</strong> Roti Sholawat menghadirkan
                            rasa otentik dengan resep rahasia keluarga. Berdiri sejak
                            bertahun-tahun yang lalu.
                        </p>
                        <p class="text-sm">
                            <strong>Text Small:</strong> Roti Sholawat menghadirkan
                            rasa otentik dengan resep rahasia keluarga. Berdiri sejak
                            bertahun-tahun yang lalu.
                        </p>
                        <p class="text-xs">
                            <strong>Text Extra Small:</strong> Roti Sholawat menghadirkan
                            rasa otentik dengan resep rahasia keluarga. Berdiri sejak
                            bertahun-tahun yang lalu.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Colors -->
        <section id="colors" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Colors Palette
                </h2>
            </div>
            <div
                class="bg-white p-8 rounded-3xl border border-stone-200/60 shadow-[0_4px_20px_rgba(0,0,0,0.02)]"
            >
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    <!-- Brand Colors -->
                    <div class="space-y-2">
                        <div
                            class="w-full h-20 rounded-2xl bg-[#c48a3a] shadow-sm"
                        >
                        </div>
                        <div class="font-semibold text-stone-900">
                            Brand Gold
                        </div>
                        <div class="text-xs text-stone-500 font-mono">
                            #c48a3a
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div
                            class="w-full h-20 rounded-2xl bg-[#a6722d] shadow-sm"
                        >
                        </div>
                        <div class="font-semibold text-stone-900">
                            Brand Dark
                        </div>
                        <div class="text-xs text-stone-500 font-mono">
                            #a6722d
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div
                            class="w-full h-20 rounded-2xl bg-gradient-to-br from-stone-900 to-stone-600 shadow-sm"
                        >
                        </div>
                        <div class="font-semibold text-stone-900">
                            Dark Gradient
                        </div>
                        <div class="text-xs text-stone-500 font-mono">
                            from-stone-900 to-600
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div
                            class="w-full h-20 rounded-2xl bg-gradient-to-r from-[#c48a3a] to-[#a6722d] shadow-sm"
                        >
                        </div>
                        <div class="font-semibold text-stone-900">
                            Gold Gradient
                        </div>
                        <div class="text-xs text-stone-500 font-mono">
                            from-[#c48a3a] to-[#a6722d]
                        </div>
                    </div>

                    <!-- Neutrals -->
                    <div class="space-y-2">
                        <div
                            class="w-full h-20 rounded-2xl border border-stone-200 bg-white shadow-sm"
                        >
                        </div>
                        <div class="font-semibold text-stone-900">
                            Surface (White)
                        </div>
                        <div class="text-xs text-stone-500 font-mono">
                            #ffffff
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div
                            class="w-full h-20 rounded-2xl border border-stone-200 bg-[#fdfcf9] shadow-sm"
                        >
                        </div>
                        <div class="font-semibold text-stone-900">
                            Background Base
                        </div>
                        <div class="text-xs text-stone-500 font-mono">
                            #fdfcf9
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div
                            class="w-full h-20 rounded-2xl bg-stone-100 shadow-sm"
                        >
                        </div>
                        <div class="font-semibold text-stone-900">
                            Neutral Light
                        </div>
                        <div class="text-xs text-stone-500 font-mono">
                            stone-100
                        </div>
                    </div>
                    <div class="space-y-2">
                        <div
                            class="w-full h-20 rounded-2xl bg-stone-900 shadow-sm"
                        >
                        </div>
                        <div class="font-semibold text-stone-900">
                            Text Primary
                        </div>
                        <div class="text-xs text-stone-500 font-mono">
                            stone-900
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Buttons -->
        <section id="buttons" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Buttons
                </h2>
            </div>
            <div
                class="bg-white p-8 rounded-3xl border border-stone-200/60 shadow-[0_4px_20px_rgba(0,0,0,0.02)] space-y-8"
            >
                <div>
                    <p
                        class="text-sm font-semibold tracking-wider text-stone-400 uppercase mb-4"
                    >
                        Variants
                    </p>
                    <div class="flex flex-wrap gap-4 items-center">
                        <Button variant="primary">Primary Solid</Button>
                        <Button variant="outline">Primary Outline</Button>
                        <Button variant="secondary">Secondary Dark</Button>
                        <Button variant="simple">Outline Simple</Button>
                        <Button variant="ghost">Ghost / Soft</Button>
                        <Button variant="danger">Danger Actions</Button>
                    </div>
                </div>

                <div class="w-full h-[1px] bg-stone-100"></div>

                <div>
                    <p
                        class="text-sm font-semibold tracking-wider text-stone-400 uppercase mb-4"
                    >
                        With Icons & Sizes
                    </p>
                    <div class="flex flex-wrap gap-4 items-center">
                        <Button variant="primary" size="lg">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg>
    Large with Icon
</Button>

                        <Button variant="simple" size="sm">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"></path><circle cx="12" cy="12" r="3"></circle></svg>
    Small Button
</Button>

                        <Button variant="simple" size="icon" class="hover:text-red-500 hover:border-red-200 hover:bg-red-50">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
</Button>

                        <Button variant="ghost" size="icon-sm">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"></path><path d="M5 12h14"></path></svg>
</Button>
                    </div>
                </div>
            </div>
        </section>

        <!-- Inputs / Forms -->
        <section id="forms" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Form Elements
                </h2>
            </div>
            <div class="bg-white p-8 rounded-3xl border border-stone-200/60 shadow-[0_4px_20px_rgba(0,0,0,0.02)] grid grid-cols-1 md:grid-cols-2 gap-8">
                <div class="space-y-4">
                    <TextInput label="Text Input (Default)" placeholder="Masukkan nama..." />

                    <TextInput 
                        label="Text Input (With Error)" 
                        value="Salah format" 
                        error="Email tidak valid." 
                    />

                    <SelectInput 
                        label="Select Input" 
                        options={[
                            { label: 'Pilih Kategori', value: '' },
                            { label: 'Roti Manis', value: 'manis' },
                            { label: 'Roti Tawar', value: 'tawar' }
                        ]} 
                    />
                </div>

                <div class="space-y-6">
                    <Textarea label="Textarea" placeholder="Masukkan deskripsi..." rows={4} />

                    <Checkbox id="checkbox1">
                        Aktifkan produk ini di katalog
                    </Checkbox>

                    <ToggleSwitch label="Toggle Switch" checked={true} client:load />
                </div>
            </div>
        </section>

        <!-- Cards & Containers -->
        <section id="cards" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Cards & States
                </h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <!-- Data Card -->
                <StatCard 
                    label="Total Pesanan" 
                    value="1,280" 
                    trend="+12.5%" 
                    trendType="up"
                >
                    <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line x1="16" y1="17" x2="8" y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg>
                </StatCard>

                <!-- Info Card (Custom themed using Base Card) -->
                <Card class="bg-gradient-to-br from-stone-900 to-stone-800 text-white relative overflow-hidden">
                    <div class="absolute -right-6 -top-6 w-32 h-32 bg-white/5 rounded-full blur-2xl pointer-events-none"></div>
                    <div class="w-12 h-12 rounded-2xl bg-white/10 border border-white/5 flex items-center justify-center text-[#c48a3a] mb-4 relative z-10">
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>
                    </div>
                    <h3 class="font-bold text-xl mb-1 relative z-10">Premium Member</h3>
                    <p class="text-stone-400 text-sm relative z-10">Akses semua fitur analitik tingkat lanjut.</p>
                </Card>

                <!-- Action Card -->
                <ActionCard title="Tambah Kategori Baru">
                    <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg>
                </ActionCard>
            </div>

            <div class="mt-8 space-y-4">
                <h3 class="text-sm font-bold text-stone-500 uppercase tracking-wider mb-4">Structural Panels & States</h3>
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <!-- Standard Panel -->
                    <Card rounded="3xl">
                        <div class="flex items-center justify-between mb-6">
                            <h2 class="font-['Syne',sans-serif] text-xl font-bold text-stone-800">Standard Panel Card</h2>
                            <a href="#" class="text-sm font-bold text-[#c48a3a] hover:text-[#a6722d] transition-colors">Lihat Semua</a>
                        </div>
                        <p class="text-stone-500 text-sm">Wadah serbaguna untuk membungkus konten seperti tabel, daftar, atau form. Memiliki bayangan minimalis dan sudut melengkung 24px (1.5rem) sesuai styling Roti Sholawat.</p>
                    </Card>

                    <!-- Empty State -->
                    <EmptyState 
                        title="State Kosong (Empty State)" 
                        description="Tampilan pengganti ketika tabel pesanan atau data laporan kosong atau belum memiliki data."
                    >
                        <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"></rect><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path></svg>
                    </EmptyState>
                </div>
            </div>
        </section>

        <!-- Badges & Status -->
        <section id="badges" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Badges & Tags
                </h2>
            </div>
            <div
                class="bg-white p-6 rounded-3xl border border-stone-200/60 shadow-sm"
            >
                <div class="flex flex-wrap gap-4">
                    <Badge variant="success" showDot={true}>Selesai</Badge>
                    <Badge variant="warning" showDot={true}>Menunggu Pembayaran</Badge>
                    <Badge variant="info" showDot={true}>Sedang Dikemas</Badge>
                    <Badge variant="default" showDot={true}>Draf</Badge>
                    <Badge variant="danger" showDot={true}>Dibatalkan</Badge>
                </div>
            </div>
        </section>

        <!-- Tables -->
        <section id="tables" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Tables
                </h2>
            </div>
            <Table headers={["ID Pesanan", "Pelanggan", "Tanggal", "Status", "Total", "Aksi"]}>
                <TableRow>
                    <TableCell bold={true}>#ORD-001</TableCell>
                    <TableCell text-stone-600>Budi Santoso</TableCell>
                    <TableCell class="text-stone-500">20 Okt 2026</TableCell>
                    <TableCell>
                        <Badge variant="success" showDot={true}>Selesai</Badge>
                    </TableCell>
                    <TableCell bold={true}>Rp 150.000</TableCell>
                    <TableCell align="right">
                        <Button variant="ghost" size="sm" class="font-bold text-[#c48a3a] hover:bg-[#c48a3a]/5">Detail</Button>
                    </TableCell>
                </TableRow>
                <TableRow>
                    <TableCell bold={true}>#ORD-002</TableCell>
                    <TableCell text-stone-600>Siti Aminah</TableCell>
                    <TableCell class="text-stone-500">21 Okt 2026</TableCell>
                    <TableCell>
                        <Badge variant="warning" showDot={true}>Menunggu</Badge>
                    </TableCell>
                    <TableCell bold={true}>Rp 75.000</TableCell>
                    <TableCell align="right">
                        <Button variant="ghost" size="sm" class="font-bold text-[#c48a3a] hover:bg-[#c48a3a]/5">Detail</Button>
                    </TableCell>
                </TableRow>
            </Table>
        </section>

        <!-- Alerts & Callouts -->
        <section id="alerts" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Alerts & Callouts
                </h2>
            </div>
            <div class="grid grid-cols-1 gap-4">
                <!-- Info Alert -->
                <Alert 
                    variant="info" 
                    title="Informasi" 
                    message="Pembaruan sistem akan dilakukan pada hari Sabtu pukul 00:00 WIB." 
                />

                <!-- Success Alert -->
                <Alert 
                    variant="success" 
                    title="Berhasil" 
                    message="Data produk berhasil disimpan ke dalam sistem." 
                />

                <!-- Warning Alert -->
                <Alert variant="warning" title="Peringatan" message="Stok produk 'Roti Coklat' tersisa 5 buah." />

                <!-- Error Alert -->
                <Alert variant="error" title="Gagal" message="Gagal mengunggah foto. Pastikan ukuran file di bawah 2MB." />
            </div>
        </section>

        <!-- Pagination & Navigation -->
        <section id="navigation" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Navigation & Pagination
                </h2>
            </div>

            <div
                class="bg-white p-8 rounded-3xl border border-stone-200/60 shadow-[0_4px_20px_rgba(0,0,0,0.02)] space-y-8"
            >
                <!-- Pagination -->
                <div>
                    <h3
                        class="text-sm font-semibold tracking-wider text-stone-400 uppercase mb-4"
                    >
                        Pagination
                    </h3>
                    <Pagination currentPage={1} totalPages={10} client:load />
                </div>

                <div class="w-full h-[1px] bg-stone-100"></div>

                <!-- Tabs -->
                <div>
                    <h3
                        class="text-sm font-semibold tracking-wider text-stone-400 uppercase mb-4"
                    >
                        Tabs
                    </h3>
                    <Tabs tabs={[{id: "semua", label: "Semua"}, {id: "aktif", label: "Aktif"}, {id: "draf", label: "Draf"}]} activeTab="semua" client:load />
                </div>

                <div class="w-full h-[1px] bg-stone-100"></div>

                <!-- Breadcrumbs -->
                <div>
                    <h3
                        class="text-sm font-semibold tracking-wider text-stone-400 uppercase mb-4"
                    >
                        Breadcrumbs
                    </h3>
                    <Breadcrumbs items={[{label: "Beranda", href: "#"}, {label: "Produk", href: "#"}, {label: "Roti Manis Coklat"}]} />
                </div>
            </div>
        </section>

        <!-- Modals -->
        <section id="modals" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Modals / Dialogs Output Formats
                </h2>
            </div>

            <div
                class="bg-stone-100/50 p-8 rounded-3xl border border-stone-200/50 flex flex-col md:flex-row gap-8 justify-center items-center"
            >
                <!-- Standard Modal -->
                <Modal 
                    inline={true} 
                    title="Ubah Status" 
                    description="Apakah Anda yakin ingin mengubah status pesanan ini menjadi selesai?"
                >
                    <Fragment slot="footer">
                        <Button variant="ghost" class="font-bold">Batal</Button>
                        <Button variant="primary">Konfirmasi</Button>
                    </Fragment>
                </Modal>

                <!-- Danger Modal -->
                <Modal 
                    inline={true} 
                    title="Hapus Produk" 
                    description="Tindakan ini tidak dapat dibatalkan. Produk akan dihapus secara permanen dari database."
                    class="text-center"
                >
                    <div class="w-16 h-16 rounded-full bg-red-50 text-red-500 flex items-center justify-center mx-auto mb-4 border-4 border-white shadow-[0_4px_12px_rgba(239,68,68,0.1)]">
                        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path><line x1="10" x2="10" y1="11" y2="17"></line><line x1="14" x2="14" y1="11" y2="17"></line></svg>
                    </div>

                    <Fragment slot="footer">
                        <div class="flex flex-col w-full gap-2">
                            <Button variant="danger" class="w-full">Ya, Hapus Produk</Button>
                            <Button variant="ghost" class="w-full font-bold">Batal</Button>
                        </div>
                    </Fragment>
                </Modal>
            </div>
        </section>
        <!-- Skeletons -->
        <section id="skeletons" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Skeletons (Loading States)
                </h2>
            </div>
            
            <div class="bg-white p-8 rounded-3xl border border-stone-200/60 shadow-[0_4px_20px_rgba(0,0,0,0.02)] grid gap-8">
                <div>
                     <p class="text-sm font-semibold tracking-wider text-stone-400 uppercase mb-4">Text & Elements</p>
                     <div class="space-y-4 max-w-lg">
                        <Skeleton height="h-8" width="w-3/4" />
                        <div class="space-y-2">
                            <Skeleton height="h-4" width="w-full" />
                            <Skeleton height="h-4" width="w-5/6" />
                            <Skeleton height="h-4" width="w-4/6" />
                        </div>
                        <div class="flex gap-3 pt-2">
                            <Skeleton height="h-10" width="w-24" rounded="xl" />
                            <Skeleton height="h-10" width="w-24" rounded="xl" />
                        </div>
                     </div>
                </div>

                <div class="w-full h-[1px] bg-stone-100"></div>

                <div>
                     <p class="text-sm font-semibold tracking-wider text-stone-400 uppercase mb-4">Card Placeholder</p>
                     <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                         <div class="p-6 border border-stone-200 rounded-3xl space-y-4">
                             <Skeleton height="h-12" width="w-12" rounded="2xl" />
                             <div class="space-y-2">
                                <Skeleton height="h-4" width="w-1/3" />
                                <Skeleton height="h-8" width="w-1/2" />
                             </div>
                         </div>
                         <div class="p-6 border border-stone-200 rounded-3xl space-y-4 flex items-center gap-4">
                             <Skeleton height="h-16" width="w-16" rounded="full" />
                             <div class="space-y-2 w-full">
                                <Skeleton height="h-5" width="w-2/3" />
                                <Skeleton height="h-4" width="w-1/2" />
                                <Skeleton height="h-4" width="w-1/3" />
                             </div>
                         </div>
                     </div>
                </div>
            </div>
        </section>

        <!-- Tooltips & Popovers -->
        <section id="tooltips" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Tooltips & Popovers
                </h2>
            </div>
            
            <div class="bg-[#fdfcf9] p-12 rounded-3xl border border-stone-200/60 shadow-inner flex flex-wrap gap-12 justify-center items-center">
                <!-- Tooltip Top -->
                <Tooltip text="Edit Data" position="top" client:load>
                    <Button variant="simple" size="icon" class="w-12 h-12 rounded-xl">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"></path><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 Z"></path></svg>
                    </Button>
                </Tooltip>

                <!-- Tooltip Bottom Danger -->
                <Tooltip text="Hapus Permanen" position="bottom" variant="danger" client:load>
                    <Button variant="simple" size="icon" class="w-12 h-12 rounded-xl text-red-500 hover:text-red-600 hover:bg-red-50 hover:border-red-200">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg>
                    </Button>
                </Tooltip>


                <!-- Popover Interactive -->
                <Popover client:load>
                    <Button slot="trigger" variant="simple" class="flex items-center gap-2 text-stone-700 font-semibold group">
                        Opsi Lanjutan
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-stone-400 group-hover:rotate-180 transition-transform duration-300"><path d="m6 9 6 6 6-6"></path></svg>
                    </Button>
                    
                    <div class="bg-white rounded-2xl border border-stone-200/80 shadow-[0_10px_40px_rgba(0,0,0,0.1)] p-2">
                        <Button variant="ghost" size="sm" href="#" class="block w-full text-left font-medium text-stone-700">Unduh Laporan</Button>
                        <Button variant="ghost" size="sm" href="#" class="block w-full text-left font-medium text-stone-700">Bagikan Link</Button>
                        <div class="w-full h-[1px] bg-stone-100 my-1"></div>
                        <Button variant="ghost" size="sm" href="#" class="block w-full text-left font-bold text-red-600 hover:bg-red-50">Bekukan Akun</Button>
                    </div>

                </Popover>
            </div>
        </section>

        <!-- Avatars & Media -->
        <section id="avatars" class="ds-section space-y-6 scroll-mt-0">
            <div class="sticky top-0 z-30 bg-white/95 backdrop-blur-md border-b border-stone-200 py-4 -mx-4 px-4 sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6">
                <h2
                    class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800"
                >
                    Avatars & Media Containers
                </h2>
            </div>
            
            <div class="bg-white p-8 rounded-3xl border border-stone-200/60 shadow-[0_4px_20px_rgba(0,0,0,0.02)] grid grid-cols-1 md:grid-cols-2 gap-12">
                <!-- User Avatars -->
                <div>
                     <p class="text-sm font-semibold tracking-wider text-stone-400 uppercase mb-5">User Profiles</p>
                     
                     <div class="flex flex-wrap items-end gap-6 mb-8">
                         <Avatar size="lg" status="online" src="https://ui-avatars.com/api/?name=Admin+Utama&background=c48a3a&color=fff&size=128" alt="Admin" />
                         <Avatar size="md" src="https://ui-avatars.com/api/?name=Budi+S&background=f3f4f6&color=374151&size=128" alt="User" />
                         <Avatar size="sm" initials="SA" />
                     </div>

                     <!-- Avatar Stack (Overlap) -->
                     <p class="text-xs font-semibold tracking-wider text-stone-400 uppercase mb-3">Avatar Stack (Team)</p>
                     <AvatarStack 
                         users={[
                             { src: "https://ui-avatars.com/api/?name=User+A&background=random" },
                             { src: "https://ui-avatars.com/api/?name=User+B&background=random" },
                             { src: "https://ui-avatars.com/api/?name=User+C&background=random" },
                             { initials: "D" },
                             { initials: "E" },
                             { initials: "F" },
                             { initials: "G" }
                         ]} 
                         limit={3} 
                     />
                </div>

                <!-- Product Images -->
                <div>
                     <p class="text-sm font-semibold tracking-wider text-stone-400 uppercase mb-5">Product Thumbnails</p>
                     
                     <div class="grid grid-cols-2 gap-4">
                         <ProductThumbnail isEmpty={true} />
                         <ProductThumbnail src="https://images.unsplash.com/photo-1509440159596-0249088772ff?q=80&w=2072&auto=format&fit=crop" alt="Roti Manis" />
                     </div>
                </div>
            </div>
        </section>

    </div>
    </div>

    <script>
        // Placeholder for any non-nav related page scripts
        document.addEventListener("astro:page-load", () => {
            // No more imperative drawer/toc logic needed! All modular.
        });
    </script>

    <Fragment slot="modals">
        <!-- Modals are now handled modularly or via this slot -->
    </Fragment>
</AdminLayout>

