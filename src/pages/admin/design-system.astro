                </div>
            </div>
        </section>

        <!-- Cards & Containers -->
        <section class="space-y-6">
            <div class="border-b border-stone-200 pb-2">
                <h2
                    class="font-['Syne',sans-serif] text-xl font-bold text-stone-800"
