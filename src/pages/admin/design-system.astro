---
import Alert from "../../components/admin/ui/feedback/Alert.svelte";
import Modal from "../../components/admin/ui/overlay/Modal.svelte";
import Tooltip from "../../components/admin/ui/overlay/Tooltip.svelte";
import Popover from "../../components/admin/ui/overlay/Popover.svelte";
import Pagination from "../../components/admin/ui/navigation/Pagination.svelte";
import Tabs from "../../components/admin/ui/navigation/Tabs.svelte";
import Breadcrumbs from "../../components/admin/ui/navigation/Breadcrumbs.svelte";
import TextInput from "../../components/admin/ui/forms/TextInput.svelte";
import Textarea from "../../components/admin/ui/forms/Textarea.svelte";
import SelectInput from "../../components/admin/ui/forms/SelectInput.svelte";
import Checkbox from "../../components/admin/ui/forms/Checkbox.svelte";
import ToggleSwitch from "../../components/admin/ui/forms/ToggleSwitch.svelte";
import Avatar from "../../components/admin/ui/media/Avatar.svelte";
import AvatarStack from "../../components/admin/ui/media/AvatarStack.svelte";
import ProductThumbnail from "../../components/admin/ui/media/ProductThumbnail.svelte";
import Card from "../../components/admin/ui/Card.svelte";
import StatCard from "../../components/admin/ui/StatCard.svelte";
import ActionCard from "../../components/admin/ui/ActionCard.svelte";
import EmptyState from "../../components/admin/ui/EmptyState.svelte";
import Skeleton from "../../components/admin/ui/feedback/Skeleton.svelte";
import Table from "../../components/admin/ui/Table.svelte";
import TableRow from "../../components/admin/ui/TableRow.svelte";
import TableCell from "../../components/admin/ui/TableCell.svelte";
import Button from "../../components/admin/ui/Button.svelte";
import Badge from "../../components/admin/ui/Badge.svelte";
import AsideNav from "../../components/admin/ui/layout/AsideNav.svelte";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/auth";
import { getDb, initDb } from "../../lib/db";

await initDb(Astro);
const db = getDb(Astro);
import { getLang, type LanguageCode, tServer } from "../../lib/i18n/server";
const lang: LanguageCode = getLang(Astro.cookies);

const admin = await requireAdmin(Astro);
if (!admin) {
  const adminCountResult = await db.execute("SELECT COUNT(*) as count FROM admin_users");
  const shouldRedirectToSetup = Number(adminCountResult.rows[0]?.count || 0) === 0;
  if (shouldRedirectToSetup) {
    return Astro.redirect("/admin/setup");
  }
  return Astro.redirect("/admin/login");
}

const title = tServer(lang, "nav.design_system");

const tocItems = [
  { id: "typography", label: tServer(lang, "design_system.typography") },
  { id: "colors", label: tServer(lang, "design_system.colors") },
  { id: "buttons", label: tServer(lang, "design_system.buttons") },
  { id: "forms", label: tServer(lang, "design_system.forms") },
  { id: "cards", label: tServer(lang, "design_system.cards") },
  { id: "badges", label: tServer(lang, "design_system.badges") },
  { id: "tables", label: tServer(lang, "design_system.tables") },
  { id: "alerts", label: tServer(lang, "design_system.alerts") },
  { id: "navigation", label: tServer(lang, "design_system.navigation") },
  { id: "modals", label: tServer(lang, "design_system.modals") },
  { id: "skeletons", label: tServer(lang, "design_system.skeletons") },
  { id: "tooltips", label: tServer(lang, "design_system.tooltips") },
  { id: "avatars", label: tServer(lang, "design_system.avatars") },
];
---

<AdminLayout title={title}>
  <div class="relative flex flex-col items-start gap-8 pb-12 lg:gap-12 xl:flex-row">
    <!-- Desktop & Mobile TOC Navigation -->
    <AsideNav items={tocItems} title={tServer(lang, "design_system.toc_title")} side="right" client:load />

    <div class="ds-content w-full min-w-0 flex-1 space-y-16">
      <!-- Tipografi -->
      <section id="typography" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            {tServer(lang, "design_system.typography")}
          </h2>
        </div>
        <div
          class="grid gap-8 rounded-3xl border border-stone-200/60 bg-white p-8 shadow-[0_4px_20px_rgba(0,0,0,0.02)]"
        >
          <div>
            <p class="mb-3 text-sm font-semibold tracking-wider text-stone-400 uppercase">
              {tServer(lang, "design_system.typography_title")}
            </p>
            <div class="space-y-4">
              <h1 class="font-['Syne',sans-serif] text-4xl font-extrabold tracking-tight text-stone-900">
                {tServer(lang, "design_system.typography_h1")}
              </h1>
              <h2 class="font-['Syne',sans-serif] text-3xl font-extrabold tracking-tight text-stone-900">
                {tServer(lang, "design_system.typography_h2")}
              </h2>
              <h3 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-900">
                {tServer(lang, "design_system.typography_h3")}
              </h3>
              <h4 class="font-['Syne',sans-serif] text-xl font-bold tracking-tight text-stone-900">
                {tServer(lang, "design_system.typography_h4")}
              </h4>
            </div>
          </div>
          <div class="h-[1px] w-full bg-stone-100"></div>
          <div>
            <p class="mb-3 text-sm font-semibold tracking-wider text-stone-400 uppercase">
              {tServer(lang, "design_system.typography_body")}
            </p>
            <div class="max-w-2xl space-y-4 text-stone-600">
              <p class="text-lg">
                <strong>{tServer(lang, "design_system.typography_large_label")}:</strong>
                {tServer(lang, "design_system.typography_sample_text")}
              </p>
              <p class="text-base">
                <strong>{tServer(lang, "design_system.typography_base_label")}:</strong>
                {tServer(lang, "design_system.typography_sample_text")}
              </p>
              <p class="text-sm">
                <strong>{tServer(lang, "design_system.typography_small_label")}:</strong>
                {tServer(lang, "design_system.typography_sample_text")}
              </p>
              <p class="text-xs">
                <strong>{tServer(lang, "design_system.typography_xs_label")}:</strong>
                {tServer(lang, "design_system.typography_sample_text")}
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Warna -->
      <section id="colors" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            {tServer(lang, "design_system.colors")}
          </h2>
        </div>
        <div class="rounded-3xl border border-stone-200/60 bg-white p-8 shadow-[0_4px_20px_rgba(0,0,0,0.02)]">
          <div class="grid grid-cols-2 gap-6 md:grid-cols-4">
            <!-- Warna Brand -->
            <div class="col-span-2 space-y-4 md:col-span-4">
              <p class="text-sm font-semibold tracking-wider text-stone-400 uppercase">
                {tServer(lang, "design_system.colors_brand")}
              </p>
            </div>
            <div class="space-y-2">
              <div class="h-20 w-full rounded-2xl bg-[#c48a3a] shadow-sm"></div>
              <div class="font-semibold text-stone-900">{tServer(lang, "design_system.color_brand_gold_label")}</div>
              <div class="font-mono text-xs text-stone-500">#c48a3a</div>
            </div>
            <div class="space-y-2">
              <div class="h-20 w-full rounded-2xl bg-[#a6722d] shadow-sm"></div>
              <div class="font-semibold text-stone-900">{tServer(lang, "design_system.color_brand_dark_label")}</div>
              <div class="font-mono text-xs text-stone-500">#a6722d</div>
            </div>
            <div class="space-y-2">
              <div class="h-20 w-full rounded-2xl bg-gradient-to-br from-stone-900 to-stone-600 shadow-sm"></div>
              <div class="font-semibold text-stone-900">
                {tServer(lang, "design_system.color_brand_grad_dark_label")}
              </div>
              <div class="font-mono text-xs text-stone-500">from-stone-900 to-600</div>
            </div>
            <div class="space-y-2">
              <div class="h-20 w-full rounded-2xl bg-gradient-to-r from-[#c48a3a] to-[#a6722d] shadow-sm"></div>
              <div class="font-semibold text-stone-900">
                {tServer(lang, "design_system.color_brand_grad_gold_label")}
              </div>
              <div class="font-mono text-xs text-stone-500">from-[#c48a3a] to-[#a6722d]</div>
            </div>

            <!-- Neutrals -->
            <div class="col-span-2 space-y-4 pt-4 md:col-span-4">
              <p class="text-sm font-semibold tracking-wider text-stone-400 uppercase">
                {tServer(lang, "design_system.colors_neutral")}
              </p>
            </div>
            <div class="space-y-2">
              <div class="h-20 w-full rounded-2xl border border-stone-200 bg-white shadow-sm"></div>
              <div class="font-semibold text-stone-900">
                {tServer(lang, "design_system.color_neutrals_surface_label")}
              </div>
              <div class="font-mono text-xs text-stone-500">#ffffff</div>
            </div>
            <div class="space-y-2">
              <div class="h-20 w-full rounded-2xl border border-stone-200 bg-[#fdfcf9] shadow-sm"></div>
              <div class="font-semibold text-stone-900">{tServer(lang, "design_system.color_neutrals_bg_label")}</div>
              <div class="font-mono text-xs text-stone-500">#fdfcf9</div>
            </div>
            <div class="space-y-2">
              <div class="h-20 w-full rounded-2xl bg-stone-100 shadow-sm"></div>
              <div class="font-semibold text-stone-900">
                {tServer(lang, "design_system.color_neutrals_light_label")}
              </div>
              <div class="font-mono text-xs text-stone-500">stone-100</div>
            </div>
            <div class="space-y-2">
              <div class="h-20 w-full rounded-2xl bg-stone-900 shadow-sm"></div>
              <div class="font-semibold text-stone-900">{tServer(lang, "design_system.color_neutrals_text_label")}</div>
              <div class="font-mono text-xs text-stone-500">stone-900</div>
            </div>
          </div>
        </div>
      </section>

      <!-- Tombol -->
      <section id="buttons" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            {tServer(lang, "design_system.buttons")}
          </h2>
        </div>
        <div class="space-y-8 rounded-3xl border border-stone-200/60 bg-white p-8 shadow-[0_4px_20px_rgba(0,0,0,0.02)]">
          <div>
            <p class="mb-4 text-sm font-semibold tracking-wider text-stone-400 uppercase">
              {tServer(lang, "design_system.buttons_variants")}
            </p>
            <div class="flex flex-wrap items-center gap-4">
              <Button variant="primary">{tServer(lang, "design_system.button_solid_label")}</Button>
              <Button variant="outline">{tServer(lang, "design_system.button_outline_label")}</Button>
              <Button variant="secondary">{tServer(lang, "design_system.button_secondary_label")}</Button>
              <Button variant="simple">{tServer(lang, "design_system.button_simple_label")}</Button>
              <Button variant="ghost">{tServer(lang, "design_system.button_ghost_label")}</Button>
              <Button variant="danger">{tServer(lang, "design_system.button_danger_label")}</Button>
            </div>
          </div>

          <div class="h-[1px] w-full bg-stone-100"></div>

          <div>
            <p class="mb-4 text-sm font-semibold tracking-wider text-stone-400 uppercase">
              {tServer(lang, "design_system.buttons_icons")}
            </p>
            <div class="flex flex-wrap items-center gap-4">
              <Button variant="primary" size="lg">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg
                >
                {tServer(lang, "design_system.button_large_icon_label")}
              </Button>

              <Button variant="simple" size="sm">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"
                  ></path><circle cx="12" cy="12" r="3"></circle></svg
                >
                {tServer(lang, "design_system.button_small_label")}
              </Button>

              <Button variant="simple" size="icon" class="hover:border-red-200 hover:bg-red-50 hover:text-red-500">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path
                    d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg
                >
              </Button>

              <Button variant="ghost" size="icon-sm">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"><path d="M12 5v14"></path><path d="M5 12h14"></path></svg
                >
              </Button>
            </div>
          </div>
        </div>
      </section>

      <!-- Input / Form -->
      <section id="forms" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            {tServer(lang, "design_system.forms")}
          </h2>
        </div>
        <div
          class="grid grid-cols-1 gap-8 rounded-3xl border border-stone-200/60 bg-white p-8 shadow-[0_4px_20px_rgba(0,0,0,0.02)] md:grid-cols-2"
        >
          <div class="space-y-4">
            <TextInput
              label={tServer(lang, "design_system.form_input_label")}
              placeholder={tServer(lang, "design_system.form_input_placeholder")}
            />

            <TextInput
              label={tServer(lang, "design_system.form_input_error_label")}
              value={tServer(lang, "design_system.form_input_error_value")}
              error={tServer(lang, "design_system.form_input_error_msg")}
            />

            <SelectInput
              label={tServer(lang, "design_system.form_select_label")}
              options={[
                { label: tServer(lang, "design_system.form_select_placeholder"), value: "" },
                { label: tServer(lang, "design_system.sample_category_sweet"), value: "manis" },
                { label: tServer(lang, "design_system.sample_category_plain"), value: "tawar" },
              ]}
            />
          </div>

          <div class="space-y-6">
            <Textarea
              label={tServer(lang, "design_system.form_textarea_label")}
              placeholder={tServer(lang, "design_system.form_textarea_placeholder")}
              rows={4}
            />

            <Checkbox id="checkbox1"> {tServer(lang, "design_system.form_checkbox_label")} </Checkbox>

            <ToggleSwitch label={tServer(lang, "design_system.form_toggle_label")} checked={true} client:load />
          </div>
        </div>
      </section>

      <!-- Kartu & Kontainer -->
      <section id="cards" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            {tServer(lang, "design_system.cards")}
          </h2>
        </div>

        <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
          <!-- Data Card -->
          <StatCard
            label={tServer(lang, "nav.orders")}
            value={tServer(lang, "design_system.sample_stat_value")}
            trend="+12.5%"
            trendType="up"
          >
            <svg
              slot="icon"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline
                points="14 2 14 8 20 8"></polyline><line x1="16" y1="13" x2="8" y2="13"></line><line
                x1="16"
                y1="17"
                x2="8"
                y2="17"></line><polyline points="10 9 9 9 8 9"></polyline></svg
            >
          </StatCard>

          <!-- Kartu Informasi (Custom themed using Base Card) -->
          <Card class="relative overflow-hidden bg-gradient-to-br from-stone-900 to-stone-800 text-white">
            <div class="pointer-events-none absolute -top-6 -right-6 h-32 w-32 rounded-full bg-white/5 blur-2xl"></div>
            <div
              class="relative z-10 mb-4 flex h-12 w-12 items-center justify-center rounded-2xl border border-white/5 bg-white/10 text-[#c48a3a]"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg
              >
            </div>
            <h3 class="relative z-10 mb-1 text-xl font-bold">{tServer(lang, "design_system.card_premium_label")}</h3>
            <p class="relative z-10 text-sm text-stone-400">{tServer(lang, "design_system.card_premium_desc")}</p>
          </Card>

          <!-- Action Card -->
          <ActionCard title={tServer(lang, "catalog.categories.add")}>
            <svg
              slot="icon"
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"><path d="M5 12h14"></path><path d="M12 5v14"></path></svg
            >
          </ActionCard>
        </div>

        <div class="mt-8 space-y-4">
          <h3 class="mb-4 text-sm font-bold tracking-wider text-stone-500 uppercase">
            {tServer(lang, "design_system.cards_panel")}
          </h3>
          <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
            <!-- Standard Panel -->
            <Card rounded="3xl">
              <div class="mb-6 flex items-center justify-between">
                <h2 class="font-['Syne',sans-serif] text-xl font-bold text-stone-800">
                  {tServer(lang, "design_system.card_panel_standard_label")}
                </h2>
                <a href="#" class="text-sm font-bold text-[#c48a3a] transition-colors hover:text-[#a6722d]"
                  >{tServer(lang, "common.see_all")}</a
                >
              </div>
              <p class="text-sm text-stone-500">
                {tServer(lang, "design_system.card_panel_standard_desc")}
              </p>
            </Card>

            <!-- Empty State -->
            <EmptyState
              title={tServer(lang, "design_system.card_empty_state_label")}
              description={tServer(lang, "design_system.card_empty_state_desc")}
            >
              <svg
                slot="icon"
                xmlns="http://www.w3.org/2000/svg"
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><rect width="8" height="4" x="8" y="2" rx="1" ry="1"></rect><path
                  d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"></path></svg
              >
            </EmptyState>
          </div>
        </div>
      </section>

      <!-- Lencana & Status -->
      <section id="badges" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            {tServer(lang, "design_system.badges")}
          </h2>
        </div>
        <div class="rounded-3xl border border-stone-200/60 bg-white p-6 shadow-sm">
          <div class="flex flex-wrap gap-4">
            <Badge variant="success" showDot={true}>{tServer(lang, "orders.statuses.completed")}</Badge>
            <Badge variant="warning" showDot={true}>{tServer(lang, "orders.statuses.pending")}</Badge>
            <Badge variant="info" showDot={true}>{tServer(lang, "orders.statuses.processing")}</Badge>
            <Badge variant="default" showDot={true}>{tServer(lang, "common.draft_status")}</Badge>
            <Badge variant="danger" showDot={true}>{tServer(lang, "orders.statuses.cancelled")}</Badge>
          </div>
        </div>
      </section>

      <!-- Tables -->
      <section id="tables" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            {tServer(lang, "design_system.tables")}
          </h2>
        </div>
        <Table
          headers={[
            "ID",
            tServer(lang, "common.customer"),
            tServer(lang, "common.date"),
            tServer(lang, "common.status"),
            tServer(lang, "common.total"),
            tServer(lang, "common.actions"),
          ]}
        >
          <TableRow>
            <TableCell bold={true}>#ORD-001</TableCell>
            <TableCell text-stone-600>{tServer(lang, "design_system.sample_name_1")}</TableCell>
            <TableCell class="text-stone-500">{tServer(lang, "design_system.sample_date_1")}</TableCell>
            <TableCell>
              <Badge variant="success" showDot={true}>{tServer(lang, "orders.statuses.completed")}</Badge>
            </TableCell>
            <TableCell bold={true}
              >{tServer(lang, "common.currency_symbol")} {tServer(lang, "design_system.sample_total_1")}</TableCell
            >
            <TableCell align="right">
              <Button variant="ghost" size="sm" class="font-bold text-[#c48a3a] hover:bg-[#c48a3a]/5"
                >{tServer(lang, "common.detail")}</Button
              >
            </TableCell>
          </TableRow>
          <TableRow>
            <TableCell bold={true}>#ORD-002</TableCell>
            <TableCell text-stone-600>{tServer(lang, "design_system.sample_name_2")}</TableCell>
            <TableCell class="text-stone-500">{tServer(lang, "design_system.sample_date_2")}</TableCell>
            <TableCell>
              <Badge variant="warning" showDot={true}>{tServer(lang, "orders.statuses.pending")}</Badge>
            </TableCell>
            <TableCell bold={true}
              >{tServer(lang, "common.currency_symbol")} {tServer(lang, "design_system.sample_total_2")}</TableCell
            >
            <TableCell align="right">
              <Button variant="ghost" size="sm" class="font-bold text-[#c48a3a] hover:bg-[#c48a3a]/5"
                >{tServer(lang, "common.detail")}</Button
              >
            </TableCell>
          </TableRow>
        </Table>
      </section>

      <!-- Alerts & Callouts -->
      <section id="alerts" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            {tServer(lang, "design_system.alerts")}
          </h2>
        </div>
        <div class="grid grid-cols-1 gap-4">
          <!-- Info Alert -->
          <Alert
            variant="info"
            title={tServer(lang, "design_system.alert_info_title")}
            message={tServer(lang, "design_system.alert_info_msg")}
          />

          <!-- Success Alert -->
          <Alert
            variant="success"
            title={tServer(lang, "design_system.alert_success_title")}
            message={tServer(lang, "design_system.alert_success_msg")}
          />

          <!-- Warning Alert -->
          <Alert
            variant="warning"
            title={tServer(lang, "design_system.alert_warning_title")}
            message={tServer(lang, "design_system.alert_warning_msg")}
          />

          <!-- Error Alert -->
          <Alert
            variant="error"
            title={tServer(lang, "design_system.alert_error_title")}
            message={tServer(lang, "design_system.alert_error_msg")}
          />
        </div>
      </section>

      <!-- Pagination & Navigation -->
      <section id="navigation" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            {tServer(lang, "design_system.navigation")}
          </h2>
        </div>

        <div class="space-y-8 rounded-3xl border border-stone-200/60 bg-white p-8 shadow-[0_4px_20px_rgba(0,0,0,0.02)]">
          <!-- Pagination -->
          <div>
            <h3 class="mb-4 text-sm font-semibold tracking-wider text-stone-400 uppercase">
              {tServer(lang, "design_system.navigation_pagination")}
            </h3>
            <Pagination currentPage={1} totalPages={10} client:load />
          </div>

          <div class="h-[1px] w-full bg-stone-100"></div>

          <!-- Tabs -->
          <div>
            <h3 class="mb-4 text-sm font-semibold tracking-wider text-stone-400 uppercase">
              {tServer(lang, "design_system.navigation_tabs")}
            </h3>
            <Tabs
              tabs={[
                { id: "semua", label: tServer(lang, "common.all_statuses") },
                { id: "aktif", label: tServer(lang, "common.active") },
                { id: "draf", label: tServer(lang, "common.draft_status") },
              ]}
              activeTab="semua"
              client:load
            />
          </div>

          <div class="h-[1px] w-full bg-stone-100"></div>

          <!-- Breadcrumbs -->
          <div>
            <h3 class="mb-4 text-sm font-semibold tracking-wider text-stone-400 uppercase">
              {tServer(lang, "design_system.navigation_breadcrumb")}
            </h3>
            <Breadcrumbs
              items={[
                { label: tServer(lang, "design_system.nav_breadcrumb_home"), href: "#" },
                { label: tServer(lang, "design_system.nav_breadcrumb_products"), href: "#" },
                { label: tServer(lang, "design_system.nav_breadcrumb_sample") },
              ]}
            />
          </div>
        </div>
      </section>

      <!-- Modals -->
      <section id="modals" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            {tServer(lang, "design_system.modals_format")}
          </h2>
        </div>

        <div
          class="flex flex-col items-center justify-center gap-8 rounded-3xl border border-stone-200/50 bg-stone-100/50 p-8 md:flex-row"
        >
          <!-- Standard Modal -->
          <Modal
            inline={true}
            title={tServer(lang, "design_system.modal_change_status_title")}
            description={tServer(lang, "design_system.modal_change_status_desc")}
          >
            <Fragment slot="footer">
              <Button variant="ghost" class="font-bold">{tServer(lang, "common.cancel")}</Button>
              <Button variant="primary">{tServer(lang, "common.confirm")}</Button>
            </Fragment>
          </Modal>

          <!-- Danger Modal -->
          <Modal
            inline={true}
            title={tServer(lang, "design_system.modal_delete_product_title")}
            description={tServer(lang, "design_system.modal_delete_product_desc")}
            class="text-center"
          >
            <div
              class="mx-auto mb-4 flex h-16 w-16 items-center justify-center rounded-full border-4 border-white bg-red-50 text-red-500 shadow-[0_4px_12px_rgba(239,68,68,0.1)]"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="28"
                height="28"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path
                  d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path><line x1="10" x2="10" y1="11" y2="17"></line><line
                  x1="14"
                  x2="14"
                  y1="11"
                  y2="17"></line></svg
              >
            </div>

            <Fragment slot="footer">
              <div class="flex w-full flex-col gap-2">
                <Button variant="danger" class="w-full">{tServer(lang, "design_system.modal_delete_confirm")}</Button>
                <Button variant="ghost" class="w-full font-bold">{tServer(lang, "common.cancel")}</Button>
              </div>
            </Fragment>
          </Modal>
        </div>
      </section>
      <!-- Skeletons -->
      <section id="skeletons" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            {tServer(lang, "design_system.skeletons")}
          </h2>
        </div>

        <div
          class="grid gap-8 rounded-3xl border border-stone-200/60 bg-white p-8 shadow-[0_4px_20px_rgba(0,0,0,0.02)]"
        >
          <div>
            <p class="mb-4 text-sm font-semibold tracking-wider text-stone-400 uppercase">
              {tServer(lang, "design_system.skeletons_elements")}
            </p>
            <div class="max-w-lg space-y-4">
              <Skeleton height="h-8" width="w-3/4" />
              <div class="space-y-2">
                <Skeleton height="h-4" width="w-full" />
                <Skeleton height="h-4" width="w-5/6" />
                <Skeleton height="h-4" width="w-4/6" />
              </div>
              <div class="flex gap-3 pt-2">
                <Skeleton height="h-10" width="w-24" rounded="xl" />
                <Skeleton height="h-10" width="w-24" rounded="xl" />
              </div>
            </div>
          </div>

          <div class="h-[1px] w-full bg-stone-100"></div>

          <div>
            <p class="mb-4 text-sm font-semibold tracking-wider text-stone-400 uppercase">
              {tServer(lang, "design_system.skeletons_cards")}
            </p>
            <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
              <div class="space-y-4 rounded-3xl border border-stone-200 p-6">
                <Skeleton height="h-12" width="w-12" rounded="2xl" />
                <div class="space-y-2">
                  <Skeleton height="h-4" width="w-1/3" />
                  <Skeleton height="h-8" width="w-1/2" />
                </div>
              </div>
              <div class="flex items-center gap-4 space-y-4 rounded-3xl border border-stone-200 p-6">
                <Skeleton height="h-16" width="w-16" rounded="full" />
                <div class="w-full space-y-2">
                  <Skeleton height="h-5" width="w-2/3" />
                  <Skeleton height="h-4" width="w-1/2" />
                  <Skeleton height="h-4" width="w-1/3" />
                </div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Tooltip & Popover -->
      <section id="tooltips" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            {tServer(lang, "design_system.tooltips")}
          </h2>
        </div>

        <div
          class="flex flex-wrap items-center justify-center gap-12 rounded-3xl border border-stone-200/60 bg-[#fdfcf9] p-12 shadow-inner"
        >
          <!-- Tooltip Top -->
          <Tooltip text={tServer(lang, "design_system.tooltip_edit")} position="top" client:load>
            <Button variant="simple" size="icon" class="h-12 w-12 rounded-xl">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M12 20h9"></path><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4 Z"></path></svg
              >
            </Button>
          </Tooltip>

          <!-- Tooltip Bottom Danger -->
          <Tooltip text={tServer(lang, "design_system.tooltip_delete")} position="bottom" variant="danger" client:load>
            <Button
              variant="simple"
              size="icon"
              class="h-12 w-12 rounded-xl text-red-500 hover:border-red-200 hover:bg-red-50 hover:text-red-600"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M3 6h18"></path><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"></path><path
                  d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"></path></svg
              >
            </Button>
          </Tooltip>

          <!-- Popover Interactive -->
          <Popover client:load>
            <Button slot="trigger" variant="simple" class="group flex items-center gap-2 font-semibold text-stone-700">
              {tServer(lang, "design_system.popover_options")}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-stone-400 transition-transform duration-300 group-hover:rotate-180"
                ><path d="m6 9 6 6 6-6"></path></svg
              >
            </Button>

            <div class="rounded-2xl border border-stone-200/80 bg-white p-2 shadow-[0_10px_40px_rgba(0,0,0,0.1)]">
              <Button variant="ghost" size="sm" href="#" class="block w-full text-left font-medium text-stone-700"
                >{tServer(lang, "design_system.popover_download")}</Button
              >
              <Button variant="ghost" size="sm" href="#" class="block w-full text-left font-medium text-stone-700"
                >{tServer(lang, "design_system.popover_share")}</Button
              >
              <div class="my-1 h-[1px] w-full bg-stone-100"></div>
              <Button
                variant="ghost"
                size="sm"
                href="#"
                class="block w-full text-left font-bold text-red-600 hover:bg-red-50"
                >{tServer(lang, "design_system.popover_freeze")}</Button
              >
            </div>
          </Popover>
        </div>
      </section>

      <!-- Avatar & Media -->
      <section id="avatars" class="ds-section scroll-mt-0 space-y-6">
        <div
          class="sticky top-0 z-30 -mx-4 border-b border-stone-200 bg-white/95 px-4 py-4 backdrop-blur-md sm:-mx-8 sm:px-8 xl:-mx-6 xl:px-6"
        >
          <h2 class="font-['Syne',sans-serif] text-2xl font-bold tracking-tight text-stone-800">
            {tServer(lang, "design_system.avatars")}
          </h2>
        </div>

        <div
          class="grid grid-cols-1 gap-12 rounded-3xl border border-stone-200/60 bg-white p-8 shadow-[0_4px_20px_rgba(0,0,0,0.02)] md:grid-cols-2"
        >
          <!-- Avatar Pengguna -->
          <div>
            <p class="mb-5 text-sm font-semibold tracking-wider text-stone-400 uppercase">
              {tServer(lang, "profile.title")}
            </p>

            <div class="mb-8 flex flex-wrap items-end gap-6">
              <Avatar
                size="lg"
                status="online"
                src={`https://ui-avatars.com/api/?name=${encodeURIComponent(tServer(lang, "design_system.sample_alt_admin"))}&background=c48a3a&color=fff&size=128`}
                alt={tServer(lang, "design_system.sample_alt_admin")}
              />
              <Avatar
                size="md"
                src={`https://ui-avatars.com/api/?name=${encodeURIComponent(tServer(lang, "design_system.sample_alt_user"))}&background=f3f4f6&color=374151&size=128`}
                alt={tServer(lang, "design_system.sample_alt_user")}
              />
              <Avatar size="sm" initials={tServer(lang, "design_system.sample_initials_1")} />
            </div>

            <!-- Tumpukan Avatar (Overlap) -->
            <p class="mb-3 text-xs font-semibold tracking-wider text-stone-400 uppercase">
              {tServer(lang, "design_system.avatar_team_stack")}
            </p>
            <AvatarStack
              users={[
                {
                  src: `https://ui-avatars.com/api/?name=${encodeURIComponent(tServer(lang, "design_system.sample_initials_2"))}&background=random`,
                },
                {
                  src: `https://ui-avatars.com/api/?name=${encodeURIComponent(tServer(lang, "design_system.sample_initials_3"))}&background=random`,
                },
                {
                  src: `https://ui-avatars.com/api/?name=${encodeURIComponent(tServer(lang, "design_system.sample_initials_4"))}&background=random`,
                },
                { initials: tServer(lang, "design_system.sample_initials_2") },
                { initials: tServer(lang, "design_system.sample_initials_3") },
                { initials: tServer(lang, "design_system.sample_initials_4") },
                { initials: tServer(lang, "design_system.sample_initials_5") },
              ]}
              limit={3}
            />
          </div>

          <!-- Product Images -->
          <div>
            <p class="mb-5 text-sm font-semibold tracking-wider text-stone-400 uppercase">
              {tServer(lang, "catalog.products.media_visual")}
            </p>

            <div class="grid grid-cols-2 gap-4">
              <ProductThumbnail isEmpty={true} />
              <ProductThumbnail
                src="https://images.unsplash.com/photo-1509440159596-0249088772ff?q=80&w=2072&auto=format&fit=crop"
                alt={tServer(lang, "design_system.sample_category_sweet")}
              />
            </div>
          </div>
        </div>
      </section>
    </div>
  </div>

  <script>
    // Placeholder for any non-nav related page scripts
    document.addEventListener("astro:page-load", () => {
      // No more imperative drawer/toc logic needed! All modular.
    });
  </script>

  <Fragment slot="modals">
    <!-- Modals are now handled modularly or via this slot -->
  </Fragment>
</AdminLayout>
