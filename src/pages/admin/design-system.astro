---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/auth";
import { getDb, initDb } from "../../lib/db";

await initDb(Astro);
const db = getDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
	const adminCountResult = await db.execute(
		"SELECT COUNT(*) as count FROM admin_users",
	);
	const shouldRedirectToSetup =
		Number(adminCountResult.rows[0]?.count || 0) === 0;
	if (shouldRedirectToSetup) {
		return Astro.redirect("/admin/setup");
	}
	return Astro.redirect("/admin/login");
}

const title = "Design System";
---

<AdminLayout title={title}>
    <div class="max-w-5xl mx-auto space-y-12 animate-fade-in-up pb-12">
        <!-- Header -->
        <div>
            <h1
                class="font-['Syne',sans-serif] text-3xl font-extrabold text-stone-900 tracking-tight"
            >
                Design System
            </h1>
            <p class="text-stone-500 mt-2">
                Panduan komponen UI, warna, dan tipografi untuk Roti Sholawat
                Admin Dashboard.
            </p>
        </div>

        <!-- Typography -->
        <section class="space-y-6">
            <div class="border-b border-stone-200 pb-2">
                <h2
                    class="font-['Syne',sans-serif] text-xl font-bold text-stone-800"
                >
                    Typography
                </h2>
            </div>
            <div
