---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";
import { parsePage } from "../../lib/admin";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const { page, q, offset, limit } = parsePage(Astro.url, 20);
const where = q ? "WHERE order_no LIKE ?" : "";
const args = q ? [`%${q}%`] : [];

const refundsRes = await db.execute({
    sql: `SELECT id, order_no, amount, reason, status, created_at
          FROM refunds
          ${where}
          ORDER BY created_at DESC
          LIMIT ? OFFSET ?`,
    args: [...args, limit, offset],
});
const countRes = await db.execute({
    sql: `SELECT COUNT(*) as count FROM refunds ${where}`,
    args,
});
const total = Number((countRes.rows[0] as any)?.count || 0);
const totalPages = Math.max(1, Math.ceil(total / limit));
---

<AdminLayout title="Refund">
    <div class="section-header">
        <h2>Buat Refund</h2>
        <span class="badge danger">Dana Keluar</span>
    </div>
    <form class="form-row" id="refund-form">
        <div>
            <label>Order No</label>
            <input name="order_no" required />
        </div>
        <div>
            <label>Jumlah (Rp)</label>
            <input name="amount" type="number" required />
        </div>
        <div>
            <label>Status</label>
            <select name="status">
                <option value="requested">Requested</option>
                <option value="approved">Approved</option>
                <option value="rejected">Rejected</option>
            </select>
        </div>
        <div>
            <label>Alasan</label>
            <input name="reason" />
        </div>
        <button class="primary" type="submit">Simpan</button>
    </form>

    <div class="toolbar">
        <strong>Daftar Refund</strong>
        <form method="get">
            <input name="q" placeholder="Cari order" value={q} />
            <button class="btn-ghost" type="submit">Cari</button>
            <a class="btn-ghost" href="/api/admin/export?entity=refunds">Export CSV</a>
        </form>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Order</th>
                <th>Jumlah</th>
                <th>Status</th>
                <th>Gateway</th>
                <th>Alasan</th>
                <th>Aksi</th>
            </tr>
        </thead>
        <tbody>
            {refundsRes.rows.map((r: any) => (
                <tr data-id={r.id}>
                    <td contenteditable="true" data-field="order_no">{r.order_no}</td>
                    <td contenteditable="true" data-field="amount">{r.amount}</td>
                    <td contenteditable="true" data-field="status">{r.status}</td>
                    <td>{r.provider_status || "-"}</td>
                    <td contenteditable="true" data-field="reason">{r.reason || ""}</td>
                    <td>
                        <div class="table-actions">
                            <button class="btn-ghost" data-action="save">Simpan</button>
                            <button class="btn-ghost" data-action="delete">Hapus</button>
                        </div>
                    </td>
                </tr>
            ))}
        </tbody>
    </table>

    <div class="pagination">
        {page > 1 && (
            <a href={`?q=${encodeURIComponent(q)}&page=${page - 1}`}>Prev</a>
        )}
        <span class="muted">Hal {page} / {totalPages}</span>
        {page < totalPages && (
            <a href={`?q=${encodeURIComponent(q)}&page=${page + 1}`}>Next</a>
        )}
    </div>

    <script>
        const form = document.querySelector("#refund-form") as HTMLFormElement | null;
        const csrf = document
            .querySelector("meta[name='csrf-token']")
            ?.getAttribute("content") || "";

        form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            if (!form) return;
            const data = new FormData(form);
            const res = await fetch("/api/admin/refunds", {
                method: "POST",
                headers: { "X-CSRF-Token": csrf },
                body: data,
            });
            if (res.ok) location.reload();
            else alert(await res.text());
        });

        document.querySelectorAll("tr[data-id]").forEach((row) => {
            row.addEventListener("click", async (e) => {
                const target = e.target as HTMLElement;
                const action = target.getAttribute("data-action");
                if (!action) return;
                const id = row.getAttribute("data-id");
                if (!id) return;
                if (action === "delete") {
                    if (!confirm("Hapus refund ini?")) return;
                    const res = await fetch(`/api/admin/refunds/${id}`, {
                        method: "DELETE",
                        headers: { "X-CSRF-Token": csrf },
                    });
                    if (res.ok) location.reload();
                    else alert(await res.text());
                    return;
                }
                if (action === "save") {
                    const fields: Record<string, string> = {};
                    row.querySelectorAll("[data-field]").forEach((cell) => {
                        const field = cell.getAttribute("data-field");
                        if (!field) return;
                        fields[field] = String(cell.textContent?.trim() || "");
                    });
                    const res = await fetch(`/api/admin/refunds/${id}`, {
                        method: "PUT",
                        headers: {
                            "Content-Type": "application/json",
                            "X-CSRF-Token": csrf,
                        },
                        body: JSON.stringify(fields),
                    });
                    if (!res.ok) alert(await res.text());
                }
            });
        });
    </script>
</AdminLayout>
