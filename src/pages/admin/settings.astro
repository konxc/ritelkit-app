---
import AdminLayout from "../../layouts/AdminLayout.astro";
import SettingsManager from "../../components/admin/pages/SettingsManager.svelte";
import { requireAdmin } from "../../lib/auth";
import { appRouter } from "../../server/router";
import { createContext } from "../../server/context";
import { createQueryClient } from "../../lib/queryClient";
import { dehydrate } from "@tanstack/svelte-query";

const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}

// SSR Pre-fetching
const queryClient = createQueryClient();
const trpc = appRouter.createCaller(await createContext(Astro));

await queryClient.prefetchQuery({
    queryKey: ["settings"],
    queryFn: () => trpc.settings.getSettings(),
});

const dehydratedState = dehydrate(queryClient);
---

<AdminLayout title="Pengaturan" dehydratedState={dehydratedState}>
    <SettingsManager client:load />
</AdminLayout>
