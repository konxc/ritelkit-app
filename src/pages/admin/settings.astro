---
import SettingsPageContent from "@components/admin/pages/SettingsPageContent.svelte";
import AdminLayout from "@layouts/AdminLayout.astro";
import { requireAdmin } from "@lib/auth";
import { initDb } from "@lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
  return Astro.redirect("/admin/login");
}
import { getLang, type LanguageCode, tServer } from "@lib/i18n/server";
const lang: LanguageCode = getLang(Astro.cookies);
---

<AdminLayout title={tServer(lang, "nav.settings")}>
  <SettingsPageContent {lang} client:load />
</AdminLayout>
