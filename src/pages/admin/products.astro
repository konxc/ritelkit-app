---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const productsRes = await db.execute(
    `SELECT p.*, c.name as category_name
     FROM products p
     LEFT JOIN categories c ON c.id = p.category_id
     ORDER BY p.created_at DESC`,
);
const categoriesRes = await db.execute(
    "SELECT id, name FROM categories ORDER BY name ASC",
);
---

<AdminLayout title="Produk">
    <div class="section-header">
        <h2>Tambah Produk</h2>
        <span class="badge">E-commerce Ready</span>
    </div>
    <form class="form-row" id="product-form">
        <div class="grid grid-2">
            <div>
                <label>Nama Produk</label>
                <input name="name" required />
            </div>
            <div>
                <label>SKU (Opsional)</label>
                <input name="sku" />
            </div>
            <div>
                <label>Kategori</label>
                <select name="category_id">
                    <option value="">Pilih Kategori</option>
                    {
                        categoriesRes.rows.map((cat: any) => (
                            <option value={cat.id}>{cat.name}</option>
                        ))
                    }
                </select>
            </div>
            <div>
                <label>Status</label>
                <select name="is_active" id="new-is-active">
                    <option value="true">Aktif</option>
                    <option value="false">Draf</option>
                </select>
            </div>
            <div>
                <label>Harga (Rp)</label>
                <input name="price" type="number" value="0" required />
            </div>
            <div>
                <label>Stok</label>
                <input
                    name="stock"
                    type="number"
                    placeholder="Bisa dikosongkan"
                />
            </div>
        </div>
        <div class="mt-3">
            <label>Deskripsi</label>
            <textarea name="description" rows="3"></textarea>
        </div>

        <div class="field mt-3">
            <label>Gambar Produk</label>
            <div class="upload-zone" id="upload-zone">
                <input
                    type="file"
                    id="file-input"
                    multiple
                    accept="image/*"
                    class="hidden"
                />
                <div class="upload-placeholder">
                    <span>Drag & drop gambar atau klik untuk upload</span>
                    <p class="muted">Urutan gambar pertama = Foto Utama</p>
                </div>
            </div>
            <div id="new-gallery" class="thumbnail-gallery" data-has="false">
            </div>
            <div id="upload-status" class="muted mt-1.5">
            </div>
            <input type="hidden" name="image_urls" id="new-image-urls" />
        </div>

        <button class="primary mt-5" type="submit" id="submit-btn"
            >Tambah Produk</button
        >
    </form>

    <div class="section-header mt-10">
        <h2>Daftar Produk</h2>
        <span class="muted">Klik sel untuk edit</span>
    </div>
    <div class="toolbar">
        <strong>Produk</strong>
        <div class="table-actions">
            <a class="btn-ghost" href="/api/admin/export?entity=products">Export CSV</a>
        </div>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>Foto</th>
                <th>Nama</th>
                <th>Kategori</th>
                <th>Harga</th>
                <th>Stok</th>
                <th>Status</th>
                <th>Aksi</th>
            </tr>
        </thead>
        <tbody>
            {
                productsRes.rows.map((p: any) => {
                    return (
                        <tr data-id={p.id}>
                            <td>
                                <div
                                    class="edit-gallery thumbnail-gallery"
                                    data-field="images_json"
                                    data-value={p.images_json}
                                />
                            </td>
                            <td>
                                <div contenteditable="true" data-field="name">
                                    {p.name}
                                </div>
                                <div class="muted text-[0.8em]">
                                    SKU:{" "}
                                    <span
                                        contenteditable="true"
                                        data-field="sku"
                                    >
                                        {p.sku || "-"}
                                    </span>
                                </div>
                            </td>
                            <td>
                                <select data-field="category_id">
                                    <option value="">Tanpa Kategori</option>
                                    {categoriesRes.rows.map((cat: any) => (
                                        <option
                                            value={cat.id}
                                            selected={cat.id === p.category_id}
                                        >
                                            {cat.name}
                                        </option>
                                    ))}
                                </select>
                            </td>
                            <td contenteditable="true" data-field="price">
                                {p.price}
                            </td>
                            <td contenteditable="true" data-field="stock">
                                {p.stock}
                            </td>
                            <td>
                                <select data-field="is_active">
                                    <option value="true" selected={p.is_active}>
                                        Aktif
                                    </option>
                                    <option
                                        value="false"
                                        selected={!p.is_active}
                                    >
                                        Draf
                                    </option>
                                </select>
                            </td>
                            <td>
                                <div class="table-actions">
                                    <button
                                        class="btn-ghost"
                                        data-action="save"
                                    >
                                        Simpan
                                    </button>
                                    <button
                                        class="btn-ghost"
                                        data-action="delete"
                                    >
                                        Hapus
                                    </button>
                                </div>
                            </td>
                        </tr>
                    );
                })
            }
        </tbody>
    </table>

    <script>
        const form = document.querySelector("#product-form") as HTMLFormElement | null;
        const uploadZone = document.querySelector("#upload-zone") as HTMLElement | null;
        const fileInput = document.querySelector("#file-input") as HTMLInputElement | null;
        const newGallery = document.querySelector("#new-gallery") as HTMLElement | null;
        const urlInput = document.querySelector("#new-image-urls") as HTMLInputElement | null;
        const activeSelect = document.querySelector("#new-is-active") as HTMLSelectElement | null;
        const submitBtn = document.querySelector("#submit-btn") as HTMLButtonElement | null;
        const statusEl = document.querySelector("#upload-status") as HTMLElement | null;
        const csrf = document
            .querySelector("meta[name='csrf-token']")
            ?.getAttribute("content") || "";

        const parseUrls = (val = "") =>
            val
                .split(",")
                .map((u) => u.trim())
                .filter(Boolean);

        const resizeImage = async (file: File): Promise<Blob> => {
            const img = await createImageBitmap(file);
            const maxSize = 1200;
            const scale = Math.min(
                1,
                maxSize / Math.max(img.width, img.height),
            );
            const width = Math.round(img.width * scale);
            const height = Math.round(img.height * scale);
            const canvas = document.createElement("canvas");
            canvas.width = width;
            canvas.height = height;
            const ctx = canvas.getContext("2d");
            if (!ctx) return file;
            ctx.drawImage(img, 0, 0, width, height);
            return await new Promise((resolve) => {
                canvas.toBlob(
                    (blob) => resolve(blob || file),
                    "image/webp",
                    0.85,
                );
            });
        };

        const uploadFiles = async (
            files: FileList | File[],
            onProgress?: (curr: number, total: number) => void,
        ): Promise<string[]> => {
            const urls: string[] = [];
            for (let i = 0; i < files.length; i += 1) {
                onProgress?.(i, files.length);
                const resized = await resizeImage(files[i]);
                const formData = new FormData();
                formData.append("file", resized, files[i].name);
                const res = await fetch("/api/admin/upload-image", {
                    method: "POST",
                    headers: { "X-CSRF-Token": csrf },
                    body: formData,
                });
                if (!res.ok) {
                    throw new Error(await res.text());
                }
                const data = (await res.json()) as { url?: string };
                if (!data.url) {
                    throw new Error("Response upload tidak valid");
                }
                urls.push(data.url);
            }
            onProgress?.(files.length, files.length);
            return urls;
        };

        const renderGallery = (
            container: HTMLElement,
            urls: string[],
            onChange: (next: string[]) => void,
        ) => {
            container.innerHTML = "";
            container.setAttribute("data-has", urls.length ? "true" : "false");
            urls.forEach((url, index) => {
                const item = document.createElement("div");
                item.className = "thumb-item";
                item.draggable = true;
                item.dataset.index = String(index);

                const img = document.createElement("img");
                img.src = url;
                img.alt = "preview";

                const actions = document.createElement("div");
                actions.className = "thumb-actions";

                const leftBtn = document.createElement("button");
                leftBtn.type = "button";
                leftBtn.textContent = "◀";
                leftBtn.onclick = () => {
                    if (index === 0) return;
                    const next = [...urls];
                    [next[index - 1], next[index]] = [
                        next[index],
                        next[index - 1],
                    ];
                    onChange(next);
                };

                const rightBtn = document.createElement("button");
                rightBtn.type = "button";
                rightBtn.textContent = "▶";
                rightBtn.onclick = () => {
                    if (index === urls.length - 1) return;
                    const next = [...urls];
                    [next[index + 1], next[index]] = [
                        next[index],
                        next[index + 1],
                    ];
                    onChange(next);
                };

                const delBtn = document.createElement("button");
                delBtn.type = "button";
                delBtn.textContent = "✕";
                delBtn.onclick = () => {
                    const next = urls.filter((_, i) => i !== index);
                    onChange(next);
                };

                actions.appendChild(leftBtn);
                actions.appendChild(rightBtn);
                actions.appendChild(delBtn);
                item.appendChild(img);
                item.appendChild(actions);
                container.appendChild(item);

                item.addEventListener("dragstart", (e) => {
                    e.dataTransfer?.setData("text/plain", String(index));
                });
                item.addEventListener("dragover", (e) => e.preventDefault());
                item.addEventListener("drop", (e) => {
                    e.preventDefault();
                    const from = Number(e.dataTransfer?.getData("text/plain"));
                    const to = index;
                    if (Number.isNaN(from) || from === to) return;
                    const next = [...urls];
                    const [moved] = next.splice(from, 1);
                    next.splice(to, 0, moved);
                    onChange(next);
                });
            });
        };

        const validateProductForm = () => {
            if (!submitBtn || !activeSelect || !urlInput) return;
            const isActive = activeSelect.value === "true";
            const urls = parseUrls(urlInput.value || "");
            if (isActive && urls.length === 0) {
                submitBtn.disabled = true;
                submitBtn.textContent = "Tambah Produk (butuh 1 gambar)";
            } else {
                submitBtn.disabled = false;
                submitBtn.textContent = "Tambah Produk";
            }
        };

        const updateNewGallery = () => {
            if (!urlInput || !newGallery) return;
            const urls = parseUrls(urlInput.value || "");
            renderGallery(newGallery, urls, (next) => {
                urlInput.value = next.join(",");
                updateNewGallery();
            });
            validateProductForm();
        };

        const attachDrop = (
            el: HTMLElement | null,
            onFiles: (files: FileList) => Promise<void>,
        ) => {
            if (!el) return;
            el.addEventListener("dragover", (e) => {
                e.preventDefault();
                el.classList.add("dragging");
            });
            el.addEventListener("dragleave", () =>
                el.classList.remove("dragging"),
            );
            el.addEventListener("drop", async (e) => {
                e.preventDefault();
                el.classList.remove("dragging");
                const files = e.dataTransfer?.files;
                if (!files || !files.length) return;
                await onFiles(files);
            });
        };

        uploadZone?.addEventListener("click", () => fileInput?.click());
        attachDrop(uploadZone, async (files) => {
            if (statusEl) statusEl.textContent = "Uploading... (0%)";
            const urls = await uploadFiles(files, (done: number, total: number) => {
                if (statusEl)
                    statusEl.textContent = `Uploading... (${Math.round((done / total) * 100)}%)`;
            });
            if (urlInput) {
                const current = parseUrls(urlInput.value);
                urlInput.value = [...current, ...urls].join(",");
                updateNewGallery();
            }
            if (statusEl) statusEl.textContent = `Uploaded ${urls.length} file`;
        });

        fileInput?.addEventListener("change", async () => {
            if (!fileInput?.files?.length) return;
            if (statusEl) statusEl.textContent = "Uploading... (0%)";
            const urls = await uploadFiles(fileInput.files, (done: number, total: number) => {
                if (statusEl)
                    statusEl.textContent = `Uploading... (${Math.round((done / total) * 100)}%)`;
            });
            if (urlInput) {
                const current = parseUrls(urlInput.value);
                urlInput.value = [...current, ...urls].join(",");
                updateNewGallery();
            }
            if (statusEl) statusEl.textContent = `Uploaded ${urls.length} file`;
        });

        activeSelect?.addEventListener("change", validateProductForm);

        form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            if (!form) return;
            const data = new FormData(form);
            const response = await fetch("/api/admin/products", {
                method: "POST",
                headers: { "X-CSRF-Token": csrf },
                body: data,
            });
            if (response.ok) {
                location.reload();
            } else {
                alert(await response.text());
            }
        });

        document.querySelectorAll(".edit-gallery").forEach((el) => {
            const container = el as HTMLElement;
            const initial = JSON.parse(
                container.getAttribute("data-value") || "[]",
            );
            const update = (next: string[]) => {
                container.setAttribute("data-value", JSON.stringify(next));
                renderGallery(container, next, update);
            };
            renderGallery(container, initial, update);
            attachDrop(container, async (files) => {
                if (statusEl) statusEl.textContent = "Uploading... (0%)";
                const urls = await uploadFiles(files, (done: number, total: number) => {
                    if (statusEl)
                        statusEl.textContent = `Uploading... (${Math.round((done / total) * 100)}%)`;
                });
                const current = JSON.parse(
                    container.getAttribute("data-value") || "[]",
                );
                update([...current, ...urls]);
                if (statusEl)
                    statusEl.textContent = `Uploaded ${urls.length} file`;
            });
        });

        document.querySelectorAll("tr[data-id]").forEach((row) => {
            row.addEventListener("click", async (e) => {
                const target = e.target;
                if (!(target instanceof HTMLElement)) return;
                const action = target.getAttribute("data-action");
                if (!action) return;
                const id = row.getAttribute("data-id");
                if (!id) return;

                if (action === "delete") {
                    if (!confirm("Hapus produk ini?")) return;
                    const res = await fetch(`/api/admin/products/${id}`, {
                        method: "DELETE",
                        headers: { "X-CSRF-Token": csrf },
                    });
                    if (res.ok) location.reload();
                    else alert(await res.text());
                    return;
                }

                if (action === "save") {
                    const fields: Record<string, unknown> = {};
                    row.querySelectorAll("[data-field]").forEach((cell) => {
                        const field = cell.getAttribute("data-field");
                        if (!field) return;
                        if (
                            cell instanceof HTMLSelectElement ||
                            cell instanceof HTMLInputElement
                        ) {
                            fields[field] = cell.value;
                            return;
                        }
                        if (field === "images_json") {
                            fields[field] = JSON.parse(
                                cell.getAttribute("data-value") || "[]",
                            );
                            return;
                        }
                        fields[field] = cell.textContent?.trim() || "";
                    });

                    const res = await fetch(`/api/admin/products/${id}`, {
                        method: "PUT",
                        headers: {
                            "Content-Type": "application/json",
                            "X-CSRF-Token": csrf,
                        },
                        body: JSON.stringify(fields),
                    });
                    if (!res.ok) alert(await res.text());
                    else location.reload();
                }
            });
        });

        validateProductForm();
    </script>
</AdminLayout>
