---
import { actions } from "astro:actions";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { ensureCsrfToken, requireAdmin } from "../../lib/auth";
import { getDb, initDb } from "../../lib/db";

await initDb(Astro);
const db = getDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
  const adminCountResult = await db.execute("SELECT COUNT(*) as count FROM admin_users");
  const shouldRedirectToSetup = Number(adminCountResult.rows[0]?.count || 0) === 0;
  if (shouldRedirectToSetup) {
    return Astro.redirect("/admin/setup");
  }
  return Astro.redirect("/admin/login");
}
ensureCsrfToken(Astro);
---

<AdminLayout title="Profil Admin">
  <div class="animate-fade-in-up mx-auto w-full max-w-md pt-4 sm:pt-8">
    <!-- Profile Card -->
    <div
      class="relative mb-8 flex flex-col items-center overflow-hidden rounded-3xl border border-stone-200/80 bg-white p-8 text-center shadow-[0_12px_40px_rgba(0,0,0,0.04)]"
    >
      <!-- decorative bg -->
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-br from-[#c48a3a]/5 to-transparent"></div>

      <div
        class="relative z-10 mb-6 flex h-24 w-24 items-center justify-center rounded-full border-4 border-white bg-stone-100 text-[#c48a3a] shadow-[0_8px_24px_rgba(196,138,58,0.15)]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="40"
          height="40"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg
        >
      </div>

      <h2 class="relative z-10 mb-2 font-['Syne',sans-serif] text-2xl font-bold text-stone-900">Admin Roti Sholawat</h2>
      <p class="relative z-10 rounded-full bg-stone-100 px-4 py-1.5 text-sm font-semibold text-stone-500">
        {admin.email}
      </p>
    </div>

    <div class="flex flex-col gap-3">
      <h3 class="mb-2 pl-2 font-bold text-stone-900">Menu Profil</h3>

      <a
        href="/admin/settings"
        class="group flex items-center justify-between rounded-2xl border border-stone-200/80 bg-white p-4 no-underline transition-all hover:border-[#c48a3a]/30 hover:shadow-md"
      >
        <div class="flex items-center gap-4">
          <div
            class="flex h-11 w-11 items-center justify-center rounded-xl bg-stone-50 text-stone-500 transition-colors group-hover:bg-[#c48a3a]/10 group-hover:text-[#c48a3a]"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"
              ></path><circle cx="12" cy="12" r="3"></circle></svg
            >
          </div>
          <div>
            <div class="text-[0.95rem] font-bold text-stone-900 transition-colors group-hover:text-[#c48a3a]">
              Pengaturan Lengkap
            </div>
            <div class="text-[0.8rem] font-medium text-stone-500">Kelola website, SEO, & banner</div>
          </div>
        </div>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-stone-300 transition-all group-hover:translate-x-1 group-hover:text-[#c48a3a]"
          ><path d="m9 18 6-6-6-6"></path></svg
        >
      </a>

      <form method="post" action={actions.adminLogout} class="m-0 mt-4 block">
        <button
          type="submit"
          class="flex h-[56px] w-full cursor-pointer items-center justify-center gap-3 rounded-2xl border border-red-100 bg-red-50 p-4 font-bold text-red-600 shadow-sm transition-all hover:bg-red-600 hover:text-white"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path><polyline points="16 17 21 12 16 7"
            ></polyline><line x1="21" x2="9" y1="12" y2="12"></line></svg
          >
          Keluar Sesi
        </button>
      </form>
    </div>
  </div>
</AdminLayout>
