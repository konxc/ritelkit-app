---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const categories = await db.execute(
    "SELECT id, name, slug, sort_order, is_active FROM categories ORDER BY sort_order ASC, name ASC",
);
---

<AdminLayout title="Kategori">
    <div class="section-header">
        <h2>Tambah Kategori</h2>
        <span class="badge">Kelola menu</span>
    </div>
    <form class="form-row" id="category-form">
        <div>
            <label>Nama Kategori</label>
            <input name="name" required />
        </div>
        <div>
            <label>Slug</label>
            <input name="slug" placeholder="opsional" />
        </div>
        <div>
            <label>Urutan</label>
            <input name="sort_order" type="number" value="0" />
        </div>
        <div>
            <label>Aktif</label>
            <select name="is_active">
                <option value="true">Ya</option>
                <option value="false">Tidak</option>
            </select>
        </div>
        <button class="primary" type="submit">Tambah Kategori</button>
    </form>

    <div class="section-header mt-6">
        <h2>Daftar Kategori</h2>
        <span class="muted">Klik sel untuk edit</span>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>Nama</th>
                <th>Slug</th>
                <th>Urutan</th>
                <th>Status</th>
                <th>Aksi</th>
            </tr>
        </thead>
        <tbody>
            {
                categories.rows.map((cat: any) => (
                    <tr data-id={cat.id}>
                        <td contenteditable="true" data-field="name">
                            {cat.name}
                        </td>
                        <td contenteditable="true" data-field="slug">
                            {cat.slug}
                        </td>
                        <td contenteditable="true" data-field="sort_order">
                            {cat.sort_order}
                        </td>
                        <td>
                            <select data-field="is_active">
                                <option value="true" selected={cat.is_active}>
                                    Aktif
                                </option>
                                <option value="false" selected={!cat.is_active}>
                                    Nonaktif
                                </option>
                            </select>
                        </td>
                        <td>
                            <div class="table-actions">
                                <button class="btn-ghost" data-action="save">
                                    Simpan
                                </button>
                                <button class="btn-ghost" data-action="delete">
                                    Hapus
                                </button>
                            </div>
                        </td>
                    </tr>
                ))
            }
        </tbody>
    </table>

    <script>
        const form = document.querySelector<HTMLFormElement>("#category-form");
        const csrf = document
            .querySelector("meta[name='csrf-token']")
            ?.getAttribute("content") || "";
        form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            if (!form) return;
            const data = new FormData(form);
            const response = await fetch("/api/admin/categories", {
                method: "POST",
                headers: { "X-CSRF-Token": csrf },
                body: data,
            });
            if (response.ok) {
                location.reload();
            } else {
                alert(await response.text());
            }
        });

        document.querySelectorAll("tr[data-id]").forEach((row) => {
            row.addEventListener("click", async (e) => {
                const target = e.target;
                if (!(target instanceof HTMLElement)) return;
                const action = target.getAttribute("data-action");
                if (!action) return;
                const id = row.getAttribute("data-id");
                if (!id) return;
                if (action === "delete") {
                    if (!confirm("Hapus kategori ini?")) return;
                    const res = await fetch(`/api/admin/categories/${id}`, {
                        method: "DELETE",
                        headers: { "X-CSRF-Token": csrf },
                    });
                    if (res.ok) location.reload();
                    else alert(await res.text());
                    return;
                }
                if (action === "save") {
                    const fields: Record<string, string> = {};
                    row.querySelectorAll("[data-field]").forEach((cell) => {
                        const field = cell.getAttribute("data-field");
                        if (!field) return;
                        if (
                            cell instanceof HTMLSelectElement ||
                            cell instanceof HTMLInputElement
                        ) {
                            fields[field] = String(cell.value);
                            return;
                        }
                        fields[field] = String(cell.textContent?.trim() || "");
                    });
                    const res = await fetch(`/api/admin/categories/${id}`, {
                        method: "PUT",
                        headers: {
                            "Content-Type": "application/json",
                            "X-CSRF-Token": csrf,
                        },
                        body: JSON.stringify(fields),
                    });
                    if (!res.ok) alert(await res.text());
                    else location.reload();
                }
            });
        });
    </script>
</AdminLayout>
