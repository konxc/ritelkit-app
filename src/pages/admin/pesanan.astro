---
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminTabs from "../../components/admin/AdminTabs.astro";
import OrdersManager from "../../components/admin/pages/OrdersManager.svelte";
import FulfillmentManager from "../../components/admin/pages/FulfillmentManager.svelte";
import ShippingManager from "../../components/admin/pages/ShippingManager.svelte";
import InvoicesManager from "../../components/admin/pages/InvoicesManager.svelte";
import RefundsManager from "../../components/admin/pages/RefundsManager.svelte";
import PaginationNav from "../../components/admin/PaginationNav.svelte";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";
import { parsePage } from "../../lib/admin";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}

const db = getDb(Astro);
const tab = Astro.url.searchParams.get("tab") || "order";
const { page, q, offset, limit } = parsePage(Astro.url, 20);

// Data for Tabs
let data: any = { rows: [] };
let totalPages = 1;

if (tab === "order") {
    const where = q
        ? "WHERE order_no LIKE ? OR customer_name LIKE ? OR customer_phone LIKE ?"
        : "";
    const args = q ? [`%${q}%`, `%${q}%`, `%${q}%`] : [];
    const ordersRes = await db.execute({
        sql: `SELECT id, order_no, status, payment_status, customer_name, total, created_at FROM orders ${where} ORDER BY created_at DESC LIMIT ? OFFSET ?`,
        args: [...args, limit, offset],
    });
    const countRes = await db.execute({
        sql: `SELECT COUNT(*) as count FROM orders ${where}`,
        args,
    });
    data.rows = ordersRes.rows;
    const total = Number((countRes.rows[0] as any)?.count || 0);
    totalPages = Math.max(1, Math.ceil(total / limit));
} else if (tab === "fulfillment") {
    const where = q ? "AND (order_no LIKE ? OR customer_name LIKE ?)" : "";
    const args = q ? [`%${q}%`, `%${q}%`] : [];
    const ordersRes = await db.execute({
        sql: `SELECT id, order_no, status, customer_name, items_json FROM orders WHERE status IN ('pending', 'processing') ${where} ORDER BY created_at ASC LIMIT ? OFFSET ?`,
        args: [...args, limit, offset],
    });
    const countRes = await db.execute({
        sql: `SELECT COUNT(*) as count FROM orders WHERE status IN ('pending', 'processing') ${where}`,
        args,
    });
    data.rows = ordersRes.rows;
    const total = Number((countRes.rows[0] as any)?.count || 0);
    totalPages = Math.max(1, Math.ceil(total / limit));
} else if (tab === "shipping") {
    const where = q ? "WHERE order_no LIKE ? OR tracking_no LIKE ?" : "";
    const args = q ? [`%${q}%`, `%${q}%`] : [];
    const shipmentsRes = await db.execute({
        sql: `SELECT id, order_no, status, carrier, tracking_no, shipped_at, delivered_at FROM shipments ${where} ORDER BY created_at DESC LIMIT ? OFFSET ?`,
        args: [...args, limit, offset],
    });
    const countRes = await db.execute({
        sql: `SELECT COUNT(*) as count FROM shipments ${where}`,
        args,
    });
    data.rows = shipmentsRes.rows;
    const total = Number((countRes.rows[0] as any)?.count || 0);
    totalPages = Math.max(1, Math.ceil(total / limit));
} else if (tab === "invoice") {
    const where = q
        ? "WHERE invoice_no LIKE ? OR order_id IN (SELECT id FROM orders WHERE order_no LIKE ?)"
        : "";
    const args = q ? [`%${q}%`, `%${q}%`] : [];
    const invoicesRes = await db.execute({
        sql: `SELECT i.id, i.invoice_no, i.status, i.issued_at, i.due_at, o.order_no 
              FROM invoices i 
              JOIN orders o ON o.id = i.order_id 
              ${where} 
              ORDER BY i.created_at DESC 
              LIMIT ? OFFSET ?`,
        args: [...args, limit, offset],
    });
    const countRes = await db.execute({
        sql: `SELECT COUNT(*) as count FROM invoices i JOIN orders o ON o.id = i.order_id ${where}`,
        args,
    });
    data.rows = invoicesRes.rows;
    const total = Number((countRes.rows[0] as any)?.count || 0);
    totalPages = Math.max(1, Math.ceil(total / limit));
} else if (tab === "refund") {
    const where = q ? "WHERE order_no LIKE ? OR reason LIKE ?" : "";
    const args = q ? [`%${q}%`, `%${q}%`] : [];
    const refundsRes = await db.execute({
        sql: `SELECT id, order_no, amount, reason, status, created_at FROM refunds ${where} ORDER BY created_at DESC LIMIT ? OFFSET ?`,
        args: [...args, limit, offset],
    });
    const countRes = await db.execute({
        sql: `SELECT COUNT(*) as count FROM refunds ${where}`,
        args,
    });
    data.rows = refundsRes.rows;
    const total = Number((countRes.rows[0] as any)?.count || 0);
    totalPages = Math.max(1, Math.ceil(total / limit));
}

const tabs = [
    {
        id: "order",
        label: "Order",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>',
    },
    {
        id: "fulfillment",
        label: "Fulfillment",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l2-1.14"/><path d="m16 21 2-2 4 4"/><circle cx="12" cy="12" r="3"/></svg>',
    },
    {
        id: "shipping",
        label: "Pengiriman",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 17h4V5H2v12h3"/><path d="M20 17h2v-3.34a4 4 0 0 0-1.17-2.83L19 9h-5v8h2"/><path d="M14 17h1"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>',
    },
    {
        id: "invoice",
        label: "Invoice",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><rect width="12" height="2" x="6" y="14"/><rect width="8" height="2" x="6" y="18"/></svg>',
    },
    {
        id: "refund",
        label: "Refund",
        icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v6h6"/><path d="M21 17v-6h-6"/><path d="M18.5 4.5A10 10 0 0 0 4 11"/><path d="M5.5 19.5A10 10 0 0 0 20 13"/></svg>',
    },
];
---

<AdminLayout title="Pesanan">
    <div slot="header-tabs">
        <AdminTabs tabs={tabs} activeTab={tab} />
    </div>

    {tab === "order" && <OrdersManager rows={data.rows as any[]} client:load />}

    {
        tab === "fulfillment" && (
            <FulfillmentManager rows={data.rows as any[]} client:load />
        )
    }

    {
        tab === "shipping" && (
            <ShippingManager rows={data.rows as any[]} client:load />
        )
    }

    {
        tab === "invoice" && (
            <InvoicesManager rows={data.rows as any[]} client:load />
        )
    }

    {
        tab === "refund" && (
            <RefundsManager rows={data.rows as any[]} client:load />
        )
    }

    <PaginationNav
        page={page}
        totalPages={totalPages}
        prevHref={page > 1
            ? `?tab=${tab}&q=${encodeURIComponent(q)}&page=${page - 1}`
            : undefined}
        nextHref={page < totalPages
            ? `?tab=${tab}&q=${encodeURIComponent(q)}&page=${page + 1}`
            : undefined}
    />
</AdminLayout>
