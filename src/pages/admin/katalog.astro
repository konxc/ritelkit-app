---
import { asc, desc, eq, like, or, sql } from "drizzle-orm";
import AdminFilterForm from "../../components/admin/AdminFilterForm.svelte";
import AdminTabs from "../../components/admin/AdminTabs.astro";
import AdminToolbar from "../../components/admin/AdminToolbar.svelte";
import PaginationNav from "../../components/admin/PaginationNav.svelte";
import KatalogTabContent from "../../components/admin/pages/KatalogTabContent.svelte";
import { categories, inventoryMovements, products } from "../../db/schema";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { parsePage } from "../../lib/admin";
import { requireAdmin } from "../../lib/auth";
import { getDrizzle, initDb } from "../../lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
  return Astro.redirect("/admin/login");
}

const tab = Astro.url.searchParams.get("tab") || "kategori";
const { page, q, offset, limit } = parsePage(Astro.url, 20);
const db = getDrizzle(Astro);

let totalPages = 1;
const initialData = {
  categories: [] as any[],
  products: [] as any[],
  inventoryProducts: [] as any[],
  inventoryMovements: [] as any[],
};

// Common: Always fetch categories for dropdowns/list
initialData.categories = await db
  .select()
  .from(categories)
  .orderBy(asc(categories.sortOrder), asc(categories.name));

if (tab === "produk") {
  const where = q ? or(like(products.name, `%${q}%`), like(products.sku, `%${q}%`)) : undefined;

  initialData.products = await db
    .select({
      id: products.id,
      sku: products.sku,
      name: products.name,
      slug: products.slug,
      description: products.description,
      categoryId: products.categoryId,
      categoryName: categories.name,
      price: products.price,
      cost: products.cost,
      stock: products.stock,
      isActive: products.isActive,
      imagesJson: products.imagesJson,
    })
    .from(products)
    .leftJoin(categories, eq(products.categoryId, categories.id))
    .where(where)
    .limit(limit)
    .offset(offset)
    .orderBy(desc(products.createdAt));

  const totalRes = await db.select({ count: sql<number>`count(*)` }).from(products).where(where);

  const total = totalRes[0]?.count || 0;
  totalPages = Math.max(1, Math.ceil(total / limit));
} else if (tab === "inventory") {
  const where = q ? or(like(products.name, `%${q}%`), like(products.sku, `%${q}%`)) : undefined;

  initialData.inventoryProducts = await db
    .select({
      id: products.id,
      sku: products.sku,
      name: products.name,
      price: products.price,
      stock: products.stock,
    })
    .from(products)
    .where(where)
    .limit(limit)
    .offset(offset)
    .orderBy(desc(products.createdAt));

  initialData.inventoryMovements = await db
    .select({
      id: inventoryMovements.id,
      productId: inventoryMovements.productId,
      type: inventoryMovements.type,
      qty: inventoryMovements.qty,
      notes: inventoryMovements.notes,
      refOrderNo: inventoryMovements.refOrderNo,
      createdAt: inventoryMovements.createdAt,
      productName: products.name,
    })
    .from(inventoryMovements)
    .leftJoin(products, eq(inventoryMovements.productId, products.id))
    .orderBy(desc(inventoryMovements.createdAt))
    .limit(30);

  const totalRes = await db.select({ count: sql<number>`count(*)` }).from(products).where(where);

  const total = totalRes[0]?.count || 0;
  totalPages = Math.max(1, Math.ceil(total / limit));
}

const tabs = [
  {
    id: "kategori",
    label: "Kategori",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>',
  },
  {
    id: "produk",
    label: "Produk",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m7.5 4.27 9 5.15"/><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>',
  },
  {
    id: "inventory",
    label: "Inventory",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.29 7 12 12 20.71 7"/><line x1="12" y1="22" x2="12" y2="12"/></svg>',
  },
];
---

<AdminLayout title="Katalog">
    <div slot="header-tabs">
        <AdminTabs tabs={tabs} activeTab={tab} />
    </div>

    <KatalogTabContent
        {tab}
        {q}
        {page}
        {limit}
        {initialData}
        client:load
    />

    {
        tab === "produk" && (
            <>
                <PaginationNav
                    page={page}
                    totalPages={totalPages}
                    prevHref={
                        page > 1
                            ? `?tab=produk&q=${encodeURIComponent(q)}&page=${page - 1}`
                            : undefined
                    }
                    nextHref={
                        page < totalPages
                            ? `?tab=produk&q=${encodeURIComponent(q)}&page=${page + 1}`
                            : undefined
                    }
                />
            </>
        )
    }

    {
        tab === "inventory" && (
            <>
                <AdminToolbar title="Data Inventory">
                    <AdminFilterForm>
                        <input type="hidden" name="tab" value="inventory" />
                        
                        <div class="relative min-w-[200px] flex-1">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3.5 top-1/2 -translate-y-1/2 text-stone-400"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                            <input
                                name="q"
                                placeholder="Cari nama / SKU"
                                value={q}
                                class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-stone-200 focus:ring-2 focus:ring-[#c48a3a]/30 focus:border-[#c48a3a] transition-all bg-stone-50 focus:bg-white text-[0.85rem] font-medium placeholder:text-stone-400 outline-none shadow-sm"
                            />
                        </div>
                        
                        <button class="flex items-center gap-1.5 px-4 py-2.5 bg-stone-900 border border-transparent rounded-xl text-white text-[0.85rem] font-bold shadow-sm hover:bg-stone-800 transition-all hover:shadow-md shrink-0 whitespace-nowrap" type="submit">
                            Cari Stok
                        </button>
                        
                        <div class="w-px h-6 bg-stone-200/80 mx-1 hidden md:block"></div>
                        
                        <a
                            class="flex items-center gap-1.5 px-4 py-2.5 bg-white border border-stone-200 rounded-xl text-stone-700 text-[0.85rem] font-bold shadow-sm hover:bg-stone-50 hover:text-stone-900 hover:border-stone-300 transition-all shrink-0 whitespace-nowrap"
                            href="/api/admin/export?entity=products"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                            Export
                        </a>
                        <a
                            class="flex items-center gap-1.5 px-4 py-2.5 bg-white border border-stone-200 rounded-xl text-stone-700 text-[0.85rem] font-bold shadow-sm hover:bg-stone-50 hover:text-stone-900 hover:border-stone-300 transition-all shrink-0 whitespace-nowrap"
                            href="/api/admin/export?entity=inventory"
                        >
                            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10.4 12.6a2 2 0 1 1 3 3L8 21l-4 1 1-4Z"/><path d="M18 18l-1.5-1.5"/><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7z"/></svg>
                            Log
                        </a>
                    </AdminFilterForm>
                </AdminToolbar>

                <PaginationNav
                    page={page}
                    totalPages={totalPages}
                    prevHref={
                        page > 1
                            ? `?tab=inventory&q=${encodeURIComponent(q)}&page=${page - 1}`
                            : undefined
                    }
                    nextHref={
                        page < totalPages
                            ? `?tab=inventory&q=${encodeURIComponent(q)}&page=${page + 1}`
                            : undefined
                    }
                />
            </>
        )
    }
</AdminLayout>
