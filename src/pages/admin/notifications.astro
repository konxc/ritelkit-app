---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";
import { parsePage } from "../../lib/admin";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const { page, q, offset, limit } = parsePage(Astro.url, 20);
const where = q ? "WHERE recipient LIKE ? OR channel LIKE ?" : "";
const args = q ? [`%${q}%`, `%${q}%`] : [];

const rows = await db.execute({
    sql: `SELECT id, channel, recipient, template, status, created_at, sent_at
          FROM notifications
          ${where}
          ORDER BY created_at DESC
          LIMIT ? OFFSET ?`,
    args: [...args, limit, offset],
});
const countRes = await db.execute({
    sql: `SELECT COUNT(*) as count FROM notifications ${where}`,
    args,
});
const total = Number((countRes.rows[0] as any)?.count || 0);
const totalPages = Math.max(1, Math.ceil(total / limit));
---

<AdminLayout title="Notifikasi">
    <div class="section-header">
        <h2>Buat Notifikasi</h2>
        <span class="badge">Manual Send</span>
    </div>
    <form class="form-row" id="notif-form">
        <div>
            <label>Channel</label>
            <select name="channel">
                <option value="whatsapp">WhatsApp</option>
                <option value="email">Email</option>
            </select>
        </div>
        <div>
            <label>Penerima</label>
            <input name="recipient" required />
        </div>
        <div>
            <label>Template</label>
            <input name="template" placeholder="opsional" />
        </div>
        <div>
            <label>Payload (JSON)</label>
            <textarea name="payload_json" rows="3" placeholder='{"message":"..."}'></textarea>
        </div>
        <button class="primary" type="submit">Simpan</button>
    </form>

    <div class="toolbar">
        <strong>Log Notifikasi</strong>
        <form method="get">
            <input name="q" placeholder="Cari channel/penerima" value={q} />
            <button class="btn-ghost" type="submit">Cari</button>
        </form>
    </div>

    <table class="table">
        <thead>
            <tr>
                <th>Channel</th>
                <th>Penerima</th>
                <th>Status</th>
                <th>Created</th>
                <th>Sent</th>
                <th>Aksi</th>
            </tr>
        </thead>
        <tbody>
            {rows.rows.map((n: any) => (
                <tr data-id={n.id}>
                    <td contenteditable="true" data-field="channel">{n.channel}</td>
                    <td contenteditable="true" data-field="recipient">{n.recipient}</td>
                    <td contenteditable="true" data-field="status">{n.status}</td>
                    <td>{String(n.created_at).split("T")[0]}</td>
                    <td>{n.sent_at ? String(n.sent_at).split("T")[0] : "-"}</td>
                    <td>
                        <div class="table-actions">
                            <button class="btn-ghost" data-action="send">Send</button>
                            <button class="btn-ghost" data-action="save">Simpan</button>
                            <button class="btn-ghost" data-action="delete">Hapus</button>
                        </div>
                    </td>
                </tr>
            ))}
        </tbody>
    </table>

    <div class="pagination">
        {page > 1 && (
            <a href={`?q=${encodeURIComponent(q)}&page=${page - 1}`}>Prev</a>
        )}
        <span class="muted">Hal {page} / {totalPages}</span>
        {page < totalPages && (
            <a href={`?q=${encodeURIComponent(q)}&page=${page + 1}`}>Next</a>
        )}
    </div>

    <script>
        const form = document.querySelector("#notif-form") as HTMLFormElement | null;
        const csrf = document
            .querySelector("meta[name='csrf-token']")
            ?.getAttribute("content") || "";

        form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            if (!form) return;
            const data = new FormData(form);
            const res = await fetch("/api/admin/notifications", {
                method: "POST",
                headers: { "X-CSRF-Token": csrf },
                body: data,
            });
            if (res.ok) location.reload();
            else alert(await res.text());
        });

        document.querySelectorAll("tr[data-id]").forEach((row) => {
            row.addEventListener("click", async (e) => {
                const target = e.target as HTMLElement;
                const action = target.getAttribute("data-action");
                if (!action) return;
                const id = row.getAttribute("data-id");
                if (!id) return;
                if (action === "delete") {
                    if (!confirm("Hapus notifikasi ini?")) return;
                    const res = await fetch(`/api/admin/notifications/${id}`, {
                        method: "DELETE",
                        headers: { "X-CSRF-Token": csrf },
                    });
                    if (res.ok) location.reload();
                    else alert(await res.text());
                    return;
                }
                if (action === "send") {
                    const res = await fetch(`/api/admin/notifications/send`, {
                        method: "POST",
                        headers: {
                            "Content-Type": "application/json",
                            "X-CSRF-Token": csrf,
                        },
                        body: JSON.stringify({ id }),
                    });
                    if (!res.ok) alert(await res.text());
                    else location.reload();
                    return;
                }
                if (action === "save") {
                    const fields: Record<string, string> = {};
                    row.querySelectorAll("[data-field]").forEach((cell) => {
                        const field = cell.getAttribute("data-field");
                        if (!field) return;
                        fields[field] = String(cell.textContent?.trim() || "");
                    });
                    const res = await fetch(`/api/admin/notifications/${id}`, {
                        method: "PUT",
                        headers: {
                            "Content-Type": "application/json",
                            "X-CSRF-Token": csrf,
                        },
                        body: JSON.stringify(fields),
                    });
                    if (!res.ok) alert(await res.text());
                }
            });
        });
    </script>
</AdminLayout>
