---
import AdminLayout from "../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const usersRes = await db.execute(
    "SELECT id, email, role, created_at FROM admin_users ORDER BY created_at DESC",
);
---

<AdminLayout title="Admin User">
    <div class="section-header">
        <h2>Tambah Admin</h2>
        <span class="badge">Role</span>
    </div>
    <form class="form-row" id="user-form">
        <div>
            <label>Email</label>
            <input name="email" type="email" required />
        </div>
        <div>
            <label>Password</label>
            <input name="password" type="password" required minlength="8" />
        </div>
        <div>
            <label>Role</label>
            <select name="role">
                <option value="owner">Owner</option>
                <option value="admin">Admin</option>
                <option value="staff">Staff</option>
            </select>
        </div>
        <button class="primary" type="submit">Tambah</button>
    </form>

    <div class="section-header mt-6">
        <h2>Daftar Admin</h2>
        <span class="muted">Edit role / reset password</span>
    </div>
    <table class="table">
        <thead>
            <tr>
                <th>Email</th>
                <th>Role</th>
                <th>Password Baru</th>
                <th>Aksi</th>
            </tr>
        </thead>
        <tbody>
            {usersRes.rows.map((u: any) => (
                <tr data-id={u.id}>
                    <td>{u.email}</td>
                    <td contenteditable="true" data-field="role">{u.role || "owner"}</td>
                    <td>
                        <input data-field="password" type="password" placeholder="Kosong = tidak diubah" />
                    </td>
                    <td>
                        <div class="table-actions">
                            <button class="btn-ghost" data-action="save">Simpan</button>
                            <button class="btn-ghost" data-action="delete">Hapus</button>
                        </div>
                    </td>
                </tr>
            ))}
        </tbody>
    </table>

    <script>
        const form = document.querySelector("#user-form") as HTMLFormElement | null;
        const csrf = document
            .querySelector("meta[name='csrf-token']")
            ?.getAttribute("content") || "";

        form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            if (!form) return;
            const data = new FormData(form);
            const res = await fetch("/api/admin/users", {
                method: "POST",
                headers: { "X-CSRF-Token": csrf },
                body: data,
            });
            if (res.ok) location.reload();
            else alert(await res.text());
        });

        document.querySelectorAll("tr[data-id]").forEach((row) => {
            row.addEventListener("click", async (e) => {
                const target = e.target as HTMLElement;
                const action = target.getAttribute("data-action");
                if (!action) return;
                const id = row.getAttribute("data-id");
                if (!id) return;
                if (action === "delete") {
                    if (!confirm("Hapus admin ini?")) return;
                    const res = await fetch(`/api/admin/users/${id}`, {
                        method: "DELETE",
                        headers: { "X-CSRF-Token": csrf },
                    });
                    if (res.ok) location.reload();
                    else alert(await res.text());
                    return;
                }
                if (action === "save") {
                    const role = row.querySelector("[data-field='role']")?.textContent || "";
                    const password = (row.querySelector("[data-field='password']") as HTMLInputElement | null)?.value;
                    const res = await fetch(`/api/admin/users/${id}`, {
                        method: "PUT",
                        headers: {
                            "Content-Type": "application/json",
                            "X-CSRF-Token": csrf,
                        },
                        body: JSON.stringify({ role, password }),
                    });
                    if (!res.ok) alert(await res.text());
                    else location.reload();
                }
            });
        });
    </script>
</AdminLayout>
