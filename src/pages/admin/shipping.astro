---
import AdminLayout from "../../layouts/AdminLayout.astro";
import SectionHeader from "../../components/admin/SectionHeader.svelte";
import AdminDataTable from "../../components/admin/AdminDataTable.svelte";
import CrudInlineForm from "../../components/admin/CrudInlineForm.svelte";
import RowActions from "../../components/admin/RowActions.svelte";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const rules = await db.execute(
    "SELECT id, name, type, priority, is_active, config_json FROM shipping_rules ORDER BY priority ASC",
);
---

<AdminLayout title="Pengiriman">
    <SectionHeader title="Tambah Rule" badge="Ongkir dinamis" />
    <CrudInlineForm id="shipping-form">
        <div>
            <label>Nama Rule</label>
            <input name="name" required />
        </div>
        <div>
            <label>Tipe</label>
            <select name="type">
                <option value="flat">Flat</option>
                <option value="free_threshold">Free Threshold</option>
                <option value="zone">Zone</option>
            </select>
        </div>
        <div>
            <label>Prioritas</label>
            <input name="priority" type="number" value="100" />
        </div>
        <div id="flat-config">
            <label>Flat Fee (Rp)</label>
            <input name="flat_fee" type="number" value="10000" />
        </div>
        <div id="threshold-config" class="hidden">
            <label>Threshold (Rp)</label>
            <input name="threshold_amount" type="number" value="150000" />
            <label>Fee jika di bawah threshold (Rp)</label>
            <input name="threshold_fee" type="number" value="10000" />
        </div>
        <div id="zone-config" class="hidden">
            <label>Zone List</label>
            <textarea
                name="zone_list"
                rows="5"
                placeholder="DI Yogyakarta|Bantul|Sewon|8000
DI Yogyakarta|Sleman||12000"
            ></textarea>
            <p class="muted">
                Format: province|city|district|fee, satu baris per zona
            </p>
        </div>
        <div>
            <label>Config (preview)</label>
            <textarea name="config_preview" rows="4" readonly></textarea>
        </div>
        <button class="primary" type="submit">Tambah Rule</button>
    </CrudInlineForm>

    <div class="mt-6">
        <SectionHeader title="Daftar Rule" muted="Klik sel untuk edit" />
    </div>
    <div class="mt-6">
        <SectionHeader title="Simulasi Ongkir" badge="Test Rule" />
    </div>
    <CrudInlineForm id="shipping-simulate">
        <div>
            <label>Subtotal (Rp)</label>
            <input name="subtotal" type="number" value="150000" />
        </div>
        <div>
            <label>Provinsi</label>
            <input name="province" value="DI Yogyakarta" />
        </div>
        <div>
            <label>Kota</label>
            <input name="city" value="Bantul" />
        </div>
        <div>
            <label>Kecamatan</label>
            <input name="district" value="Sewon" />
        </div>
        <div>
            <label>Free Shipping</label>
            <select name="free_shipping">
                <option value="false">Tidak</option>
                <option value="true">Ya</option>
            </select>
        </div>
        <button class="primary" type="submit">Hitung</button>
        <div class="card hidden" id="simulate-result"></div>
    </CrudInlineForm>
    <AdminDataTable>
        <thead>
            <tr>
                <th>Nama</th>
                <th>Tipe</th>
                <th>Prioritas</th>
                <th>Config</th>
                <th>Status</th>
                <th>Aksi</th>
            </tr>
        </thead>
        <tbody>
            {
                rules.rows.map((rule: any) => (
                    <tr data-id={rule.id}>
                        <td contenteditable="true" data-field="name">
                            {rule.name}
                        </td>
                        <td contenteditable="true" data-field="type">
                            {rule.type}
                        </td>
                        <td contenteditable="true" data-field="priority">
                            {rule.priority}
                        </td>
                        <td>
                            <textarea data-field="config" rows="3">
                                {rule.config_json}
                            </textarea>
                        </td>
                        <td>
                            <select data-field="is_active">
                                <option value="true" selected={rule.is_active}>
                                    Aktif
                                </option>
                                <option
                                    value="false"
                                    selected={!rule.is_active}
                                >
                                    Nonaktif
                                </option>
                            </select>
                        </td>
                        <td>
                            <RowActions />
                        </td>
                    </tr>
                ))
            }
        </tbody>
    </AdminDataTable>

    <script>
        import { bindCrudTable, getCsrfToken } from "../../lib/admin-client";
        import { initShippingRuleConfig } from "../../lib/admin-shipping-client";

        const form = document.querySelector("#shipping-form") as HTMLFormElement | null;
        const csrf = getCsrfToken();
        const buildConfig = form ? initShippingRuleConfig(form) : () => ({});

        form?.addEventListener("submit", async (e) => {
            e.preventDefault();
            if (!form) return;
            const formData = new FormData(form);
            try {
                const config = buildConfig();
                const payload = Object.fromEntries(formData.entries()) as Record<
                    string,
                    string
                >;
                const body = { ...payload, config };
                const response = await fetch("/api/admin/shipping-rules", {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        "X-CSRF-Token": csrf,
                    },
                    body: JSON.stringify(body),
                });
                if (response.ok) {
                    location.reload();
                } else {
                    alert(await response.text());
                }
            } catch (err) {
                alert("Config JSON tidak valid");
            }
        });

        const simulateForm = document.querySelector(
            "#shipping-simulate",
        ) as HTMLFormElement | null;
        const simulateResult = document.querySelector("#simulate-result") as HTMLElement | null;
        simulateForm?.addEventListener("submit", async (e) => {
            e.preventDefault();
            if (!simulateForm) return;
            const data = new FormData(simulateForm);
            const payload = {
                subtotal: Number(data.get("subtotal") || 0),
                province: String(data.get("province") || ""),
                city: String(data.get("city") || ""),
                district: String(data.get("district") || ""),
                free_shipping: String(data.get("free_shipping") || "false") === "true",
            };
            const res = await fetch("/api/admin/shipping-simulate", {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "X-CSRF-Token": csrf,
                },
                body: JSON.stringify(payload),
            });
            if (!simulateResult) return;
            if (!res.ok) {
                simulateResult.style.display = "block";
                simulateResult.textContent = await res.text();
                return;
            }
            const result = (await res.json()) as { fee: number; rule: string };
            simulateResult.style.display = "block";
            simulateResult.textContent = `Rule: ${result.rule} | Ongkir: Rp ${Number(
                result.fee,
            ).toLocaleString("id-ID")}`;
        });

        bindCrudTable({
            basePath: "/api/admin/shipping-rules",
            deleteConfirm: "Hapus rule ini?",
            reloadOnSave: true,
            mapFields: (fields) => ({
                name: fields.name || "",
                type: fields.type || "",
                priority: Number(fields.priority || 0),
                config: fields.config ? JSON.parse(fields.config) : {},
                is_active: fields.is_active,
            }),
        });
    </script>
</AdminLayout>
