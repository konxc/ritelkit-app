---
import AdminLayout from "../../layouts/AdminLayout.astro";
import AdminToolbar from "../../components/admin/AdminToolbar.svelte";
import AdminFilterForm from "../../components/admin/AdminFilterForm.svelte";
import PaginationNav from "../../components/admin/PaginationNav.svelte";
import ShippingManager from "../../components/admin/pages/ShippingManager.svelte";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const rules = await db.execute(
    "SELECT id, name, type, priority, is_active, config_json FROM shipping_rules ORDER BY priority ASC",
);
---

<AdminLayout title="Pengiriman">
    <ShippingManager rows={rules.rows as any[]} client:load />

    <AdminToolbar title="Daftar Rule">
        <AdminFilterForm>
            <input name="q" placeholder="Cari rule" />
            <button class="btn-ghost" type="submit">Cari</button>
        </AdminFilterForm>
    </AdminToolbar>

    <PaginationNav page={1} totalPages={1} />
</AdminLayout>
