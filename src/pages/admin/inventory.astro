---
import AdminLayout from "../../layouts/AdminLayout.astro";
import SectionHeader from "../../components/admin/SectionHeader.svelte";
import PaginationNav from "../../components/admin/PaginationNav.svelte";
import AdminDataTable from "../../components/admin/AdminDataTable.svelte";
import AdminToolbar from "../../components/admin/AdminToolbar.svelte";
import AdminFilterForm from "../../components/admin/AdminFilterForm.svelte";
import CrudInlineForm from "../../components/admin/CrudInlineForm.svelte";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";
import { parsePage } from "../../lib/admin";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const { page, q, offset, limit } = parsePage(Astro.url, 20);

const where = q ? "WHERE name LIKE ? OR sku LIKE ?" : "";
const args = q ? [`%${q}%`, `%${q}%`] : [];
const productsRes = await db.execute({
    sql: `SELECT id, name, sku, stock, price FROM products ${where} ORDER BY created_at DESC LIMIT ? OFFSET ?`,
    args: [...args, limit, offset],
});
const countRes = await db.execute({
    sql: `SELECT COUNT(*) as count FROM products ${where}`,
    args,
});
const total = Number((countRes.rows[0] as any)?.count || 0);
const totalPages = Math.max(1, Math.ceil(total / limit));

const movementsRes = await db.execute(
    `SELECT m.id, m.type, m.qty, m.notes, m.ref_order_no, m.created_at, p.name as product_name
     FROM inventory_movements m
     LEFT JOIN products p ON p.id = m.product_id
     ORDER BY m.created_at DESC
     LIMIT 30`,
);
---

<AdminLayout title="Inventory">
    <SectionHeader title="Tambah Mutasi Stok" badge="Restock & Penyesuaian" />
    <CrudInlineForm id="inventory-form">
        <div>
            <label>Produk</label>
            <select name="product_id" required>
                {productsRes.rows.map((p: any) => (
                    <option value={p.id}>{p.name}</option>
                ))}
            </select>
        </div>
        <div>
            <label>Tipe</label>
            <select name="type">
                <option value="in">Stock In</option>
                <option value="out">Stock Out</option>
                <option value="adjustment">Adjustment</option>
            </select>
        </div>
        <div>
            <label>Qty</label>
            <input name="qty" type="number" required />
        </div>
        <div>
            <label>Catatan</label>
            <input name="notes" placeholder="Opsional" />
        </div>
        <button class="primary" type="submit">Simpan</button>
    </CrudInlineForm>

    <AdminToolbar title="Stok Produk">
        <AdminFilterForm>
            <input name="q" placeholder="Cari nama / SKU" value={q} />
            <button class="btn-ghost" type="submit">Cari</button>
            <a class="btn-ghost" href="/api/admin/export?entity=products">Export Produk</a>
            <a class="btn-ghost" href="/api/admin/export?entity=inventory">Export Mutasi</a>
        </AdminFilterForm>
    </AdminToolbar>

    <AdminDataTable>
        <thead>
            <tr>
                <th>Produk</th>
                <th>SKU</th>
                <th>Stok</th>
                <th>Harga</th>
            </tr>
        </thead>
        <tbody>
            {productsRes.rows.map((p: any) => (
                <tr>
                    <td>{p.name}</td>
                    <td>{p.sku || "-"}</td>
                    <td>{p.stock ?? "-"}</td>
                    <td>Rp {Number(p.price).toLocaleString("id-ID")}</td>
                </tr>
            ))}
        </tbody>
    </AdminDataTable>

    <PaginationNav
        page={page}
        totalPages={totalPages}
        prevHref={page > 1 ? `?q=${encodeURIComponent(q)}&page=${page - 1}` : undefined}
        nextHref={page < totalPages ? `?q=${encodeURIComponent(q)}&page=${page + 1}` : undefined}
    />

    <div class="mt-6">
        <SectionHeader title="Mutasi Terakhir" muted="30 entri terakhir" />
    </div>
    <AdminDataTable>
        <thead>
            <tr>
                <th>Produk</th>
                <th>Tipe</th>
                <th>Qty</th>
                <th>Order Ref</th>
                <th>Catatan</th>
                <th>Tanggal</th>
            </tr>
        </thead>
        <tbody>
            {movementsRes.rows.map((m: any) => (
                <tr>
                    <td>{m.product_name || "-"}</td>
                    <td>{m.type}</td>
                    <td>{m.qty}</td>
                    <td>{m.ref_order_no || "-"}</td>
                    <td>{m.notes || "-"}</td>
                    <td>{String(m.created_at).split("T")[0]}</td>
                </tr>
            ))}
        </tbody>
    </AdminDataTable>

    <script>
        import { bindCreateForm } from "../../lib/admin-client";

        bindCreateForm({
            formSelector: "#inventory-form",
            endpoint: "/api/admin/inventory-movements",
        });
    </script>
</AdminLayout>
