---
import AdminLayout from "../../layouts/AdminLayout.astro";
import PaginationNav from "../../components/admin/PaginationNav.svelte";
import AdminToolbar from "../../components/admin/AdminToolbar.svelte";
import AdminFilterForm from "../../components/admin/AdminFilterForm.svelte";
import InventoryManager from "../../components/admin/pages/InventoryManager.svelte";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";
import { parsePage } from "../../lib/admin";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const { page, q, offset, limit } = parsePage(Astro.url, 20);

const where = q ? "WHERE name LIKE ? OR sku LIKE ?" : "";
const args = q ? [`%${q}%`, `%${q}%`] : [];
const productsRes = await db.execute({
    sql: `SELECT id, name, sku, stock, price FROM products ${where} ORDER BY created_at DESC LIMIT ? OFFSET ?`,
    args: [...args, limit, offset],
});
const countRes = await db.execute({
    sql: `SELECT COUNT(*) as count FROM products ${where}`,
    args,
});
const total = Number((countRes.rows[0] as any)?.count || 0);
const totalPages = Math.max(1, Math.ceil(total / limit));

const movementsRes = await db.execute(
    `SELECT m.id, m.type, m.qty, m.notes, m.ref_order_no, m.created_at, p.name as product_name
     FROM inventory_movements m
     LEFT JOIN products p ON p.id = m.product_id
     ORDER BY m.created_at DESC
     LIMIT 30`,
);
---

<AdminLayout title="Inventory">
    <InventoryManager
        products={productsRes.rows as any[]}
        movements={movementsRes.rows as any[]}
        client:load
    />

    <AdminToolbar title="Stok Produk">
        <AdminFilterForm>
            <input name="q" placeholder="Cari nama / SKU" value={q} />
            <button class="btn-ghost" type="submit">Cari</button>
            <a class="btn-ghost" href="/api/admin/export?entity=products">Export Produk</a>
            <a class="btn-ghost" href="/api/admin/export?entity=inventory">Export Mutasi</a>
        </AdminFilterForm>
    </AdminToolbar>

    <PaginationNav
        page={page}
        totalPages={totalPages}
        prevHref={page > 1 ? `?q=${encodeURIComponent(q)}&page=${page - 1}` : undefined}
        nextHref={page < totalPages ? `?q=${encodeURIComponent(q)}&page=${page + 1}` : undefined}
    />
</AdminLayout>
