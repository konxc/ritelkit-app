---
import AdminLayout from "../../layouts/AdminLayout.astro";
import SectionHeader from "../../components/admin/SectionHeader.svelte";
import PaginationNav from "../../components/admin/PaginationNav.svelte";
import AdminDataTable from "../../components/admin/AdminDataTable.svelte";
import AdminToolbar from "../../components/admin/AdminToolbar.svelte";
import RowActions from "../../components/admin/RowActions.svelte";
import AdminFilterForm from "../../components/admin/AdminFilterForm.svelte";
import CrudInlineForm from "../../components/admin/CrudInlineForm.svelte";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";
import { parsePage } from "../../lib/admin";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const { page, q, offset, limit } = parsePage(Astro.url, 20);

const where = q ? "WHERE name LIKE ? OR phone LIKE ? OR email LIKE ?" : "";
const args = q ? [`%${q}%`, `%${q}%`, `%${q}%`] : [];
const customersRes = await db.execute({
    sql: `SELECT id, name, email, phone, notes, created_at
          FROM customers
          ${where}
          ORDER BY created_at DESC
          LIMIT ? OFFSET ?`,
    args: [...args, limit, offset],
});
const countRes = await db.execute({
    sql: `SELECT COUNT(*) as count FROM customers ${where}`,
    args,
});
const total = Number((countRes.rows[0] as any)?.count || 0);
const totalPages = Math.max(1, Math.ceil(total / limit));
---

<AdminLayout title="Pelanggan">
    <SectionHeader title="Tambah Pelanggan" badge="CRM" />
    <CrudInlineForm id="customer-form">
        <div>
            <label>Nama</label>
            <input name="name" required />
        </div>
        <div>
            <label>Telepon</label>
            <input name="phone" required />
        </div>
        <div>
            <label>Email</label>
            <input name="email" type="email" />
        </div>
        <div>
            <label>Catatan</label>
            <textarea name="notes" rows="2"></textarea>
        </div>
        <button class="primary" type="submit">Simpan</button>
    </CrudInlineForm>

    <AdminToolbar title="Daftar Pelanggan">
        <AdminFilterForm>
            <input name="q" placeholder="Cari nama / telepon / email" value={q} />
            <button class="btn-ghost" type="submit">Cari</button>
            <a class="btn-ghost" href="/api/admin/export?entity=customers">Export CSV</a>
        </AdminFilterForm>
    </AdminToolbar>

    <AdminDataTable>
            <thead>
                <tr>
                    <th>Nama</th>
                    <th>Telepon</th>
                    <th>Email</th>
                    <th>Catatan</th>
                    <th>Aksi</th>
                </tr>
            </thead>
            <tbody>
                {customersRes.rows.map((row: any) => (
                    <tr data-id={row.id}>
                        <td contenteditable="true" data-field="name">{row.name}</td>
                        <td contenteditable="true" data-field="phone">{row.phone}</td>
                        <td contenteditable="true" data-field="email">{row.email || ""}</td>
                        <td contenteditable="true" data-field="notes">{row.notes || ""}</td>
                        <td>
                            <RowActions detailHref={`/admin/customers/${row.id}`} />
                        </td>
                    </tr>
                ))}
            </tbody>
    </AdminDataTable>

    <PaginationNav
        page={page}
        totalPages={totalPages}
        prevHref={page > 1 ? `?q=${encodeURIComponent(q)}&page=${page - 1}` : undefined}
        nextHref={page < totalPages ? `?q=${encodeURIComponent(q)}&page=${page + 1}` : undefined}
    />

    <script>
        import { bindCreateForm, bindCrudTable } from "../../lib/admin-client";

        bindCreateForm({
            formSelector: "#customer-form",
            endpoint: "/api/admin/customers",
        });

        bindCrudTable({
            basePath: "/api/admin/customers",
            deleteConfirm: "Hapus pelanggan ini?",
        });
    </script>
</AdminLayout>
