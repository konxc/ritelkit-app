---
import InvoiceDetailPageContent from "../../../components/admin/pages/InvoiceDetailPageContent.svelte";
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { requireAdmin } from "../../../lib/auth";
import { getDb, initDb } from "../../../lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
  return Astro.redirect("/admin/login");
}
const invoiceNo = Astro.params.invoice_no;
const db = getDb(Astro);
const result = await db.execute({
  sql: `SELECT i.*, o.order_no, o.customer_name, o.customer_phone, o.items_json, o.shipping_address_json
          FROM invoices i JOIN orders o ON o.id = i.order_id
          WHERE i.invoice_no = ?`,
  args: [invoiceNo ?? ""],
});
const invoice = result.rows[0] as unknown as
  | {
      id: string;
      invoice_no: string;
      status: string;
      due_at?: string | null;
      total: number;
      order_no: string;
      customer_name: string;
      customer_phone: string;
      items_json: string;
      shipping_address_json: string;
      parsedItems?: unknown[];
    }
  | undefined;
if (!invoice) {
  return Astro.redirect("/admin/invoices");
}
const items = JSON.parse(String(invoice.items_json || "[]"));
const address = JSON.parse(String(invoice.shipping_address_json || "{}"));
invoice.parsedItems = items;
invoice.shipping_address_json = address;
import { getLang, type LanguageCode, tServer } from "../../../lib/i18n/server";
const lang: LanguageCode = getLang(Astro.cookies);
---

<AdminLayout title={`${tServer(lang, "invoice.title_detail")} ${invoice.invoice_no}`}>
  <InvoiceDetailPageContent invoice={invoice} {lang} client:load />
</AdminLayout>
