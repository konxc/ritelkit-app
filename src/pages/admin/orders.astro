---
import AdminTabs from "../../components/admin/AdminTabs.astro";
import PaginationNav from "../../components/admin/PaginationNav.svelte";
import PesananTabContent from "../../components/admin/pages/PesananTabContent.svelte";
import AdminLayout from "../../layouts/AdminLayout.astro";
import { normalizeTab, parsePage } from "../../lib/admin";
import { requireAdmin } from "../../lib/auth";
import { getDrizzle, initDb } from "../../lib/db";
import { appRouter } from "../../server/router";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
  return Astro.redirect("/admin/login");
}

const TAB_IDS = ["order", "fulfillment", "shipping", "invoice", "refund"] as const;

const rawTab = Astro.url.searchParams.get("tab");

const tab = normalizeTab(rawTab, {
  allowed: TAB_IDS,
  defaultTab: "order",
  aliases: {
    orders: "order",
    fulfill: "fulfillment",
    invoices: "invoice",
    refunds: "refund",
  },
});

if (rawTab && rawTab !== tab) {
  const canonicalUrl = new URL(Astro.url);
  canonicalUrl.searchParams.set("tab", tab);
  return Astro.redirect(canonicalUrl.pathname + canonicalUrl.search);
}
const { page, q, offset, limit } = parsePage(Astro.url, 20);
const statusFilter = Astro.url.searchParams.get("status");

const db = getDrizzle(Astro);

const caller = appRouter.createCaller({ db, admin, ctx: Astro as any });

let totalPages = 1;
const initialData = {
  orders: [] as any[],
  ordersTotal: 0,
  shipments: [] as any[],
  shipmentsTotal: 0,
  shippingRules: [] as any[],
  invoices: [] as any[],
  invoicesTotal: 0,
  refunds: [] as any[],
  refundsTotal: 0,
};

if (tab === "order") {
  const result = await caller.orders.list({
    q: q || undefined,
    status: statusFilter ? [statusFilter] : undefined,
    limit,
    offset,
  });
  initialData.orders = result.rows;
  initialData.ordersTotal = result.total;
  totalPages = Math.max(1, Math.ceil(result.total / limit));
} else if (tab === "fulfillment") {
  const result = await caller.shipments.list({
    q: q || undefined,
    status: statusFilter ? [statusFilter] : undefined,
    limit,
    offset,
  });
  initialData.shipments = result.rows;
  initialData.shipmentsTotal = result.total;
  totalPages = Math.max(1, Math.ceil(result.total / limit));
} else if (tab === "shipping") {
  const result = await caller.shippingRules.list();
  initialData.shippingRules = result;
  totalPages = 1;
} else if (tab === "invoice") {
  const result = await caller.invoices.list({
    q: q || undefined,
    limit,
    offset,
  });
  initialData.invoices = result.rows;
  initialData.invoicesTotal = result.total;
  totalPages = Math.max(1, Math.ceil(result.total / limit));
} else if (tab === "refund") {
  const result = await caller.refunds.list({
    q: q || undefined,
    limit,
    offset,
  });
  initialData.refunds = result.rows;
  initialData.refundsTotal = result.total;
  totalPages = Math.max(1, Math.ceil(result.total / limit));
}

const tabs = [
  {
    id: "order",
    label: "nav.orders",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>',
  },
  {
    id: "fulfillment",
    label: "fulfillment.title",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l2-1.14"/><circle cx="12" cy="12" r="3"/></svg>',
  },
  {
    id: "shipping",
    label: "shipping.title",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 17h4V5H2v12h3"/><path d="M20 17h2v-3.34a4 4 0 0 0-1.17-2.83L19 9h-5v8h2"/><path d="M14 17h1"/><circle cx="7.5" cy="17.5" r="2.5"/><circle cx="17.5" cy="17.5" r="2.5"/></svg>',
  },
  {
    id: "invoice",
    label: "invoice.title",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><rect width="12" height="2" x="6" y="14"/><rect width="8" height="2" x="6" y="18"/></svg>',
  },
  {
    id: "refund",
    label: "refund.title",
    icon: '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7v6h6"/><path d="M21 17v-6h-6"/><path d="M18.5 4.5A10 10 0 0 0 4 11"/><path d="M5.5 19.5A10 10 0 0 0 20 13"/></svg>',
  },
];
import { getLang, tServer } from "../../lib/i18n/server";
import AdminToolbar from "../../components/admin/AdminToolbar.svelte";
import AdminHeaderFilters from "../../components/admin/AdminHeaderFilters.svelte";
const lang = getLang(Astro.cookies);
---

<AdminLayout title={tServer(lang, "nav.orders")}>
  <div slot="header-tabs">
    <AdminTabs tabs={tabs} activeTab={tab} {lang} />
  </div>

  <AdminToolbar
    title={tServer(lang, "common.filter")}
    class="sticky top-0 z-20 sm:top-2 md:top-4 lg:hidden"
    showMobileFloat={true}
    client:load
  >
    <AdminHeaderFilters tab={tab} q={q} status={statusFilter || ""} lang={lang} client:load />
  </AdminToolbar>

  <PesananTabContent {tab} {q} status={statusFilter || ""} {page} {limit} {initialData} {lang} client:load />


</AdminLayout>
