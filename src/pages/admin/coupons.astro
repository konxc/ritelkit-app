---
import AdminLayout from "../../layouts/AdminLayout.astro";
import SectionHeader from "../../components/admin/SectionHeader.svelte";
import AdminDataTable from "../../components/admin/AdminDataTable.svelte";
import CrudInlineForm from "../../components/admin/CrudInlineForm.svelte";
import RowActions from "../../components/admin/RowActions.svelte";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const coupons = await db.execute(
    "SELECT id, code, type, value, min_order, max_discount, start_at, end_at, usage_limit, per_user_limit, is_active FROM coupons ORDER BY created_at DESC",
);
---

<AdminLayout title="Kupon">
    <SectionHeader title="Tambah Kupon" badge="Promo & diskon" />
    <CrudInlineForm id="coupon-form">
        <div>
            <label>Kode</label>
            <input name="code" required />
        </div>
        <div>
            <label>Tipe</label>
            <select name="type">
                <option value="percent">Percent</option>
                <option value="fixed">Fixed</option>
                <option value="free_shipping">Free Shipping</option>
            </select>
        </div>
        <div>
            <label>Nilai</label>
            <input name="value" type="number" required />
        </div>
        <div>
            <label>Min Order</label>
            <input name="min_order" type="number" />
        </div>
        <div>
            <label>Max Diskon</label>
            <input name="max_discount" type="number" />
        </div>
        <div>
            <label>Mulai</label>
            <input name="start_at" type="date" />
        </div>
        <div>
            <label>Berakhir</label>
            <input name="end_at" type="date" />
        </div>
        <div>
            <label>Usage Limit</label>
            <input name="usage_limit" type="number" />
        </div>
        <div>
            <label>Limit per User</label>
            <input name="per_user_limit" type="number" />
        </div>
        <div>
            <label>Aktif</label>
            <select name="is_active">
                <option value="true">Ya</option>
                <option value="false">Tidak</option>
            </select>
        </div>
        <button class="primary" type="submit">Tambah Kupon</button>
    </CrudInlineForm>

    <div class="mt-6">
        <SectionHeader title="Daftar Kupon" muted="Klik sel untuk edit" />
    </div>
    <AdminDataTable>
        <thead>
            <tr>
                <th>Kode</th>
                <th>Tipe</th>
                <th>Nilai</th>
                <th>Min Order</th>
                <th>Max Diskon</th>
                <th>Mulai</th>
                <th>Berakhir</th>
                <th>Limit</th>
                <th>Per User</th>
                <th>Status</th>
                <th>Aksi</th>
            </tr>
        </thead>
        <tbody>
            {
                coupons.rows.map((coupon: any) => (
                    <tr data-id={coupon.id}>
                        <td contenteditable="true" data-field="code">
                            {coupon.code}
                        </td>
                        <td contenteditable="true" data-field="type">
                            {coupon.type}
                        </td>
                        <td contenteditable="true" data-field="value">
                            {coupon.value}
                        </td>
                        <td contenteditable="true" data-field="min_order">
                            {coupon.min_order ?? ""}
                        </td>
                        <td contenteditable="true" data-field="max_discount">
                            {coupon.max_discount ?? ""}
                        </td>
                        <td contenteditable="true" data-field="start_at">
                            {coupon.start_at ?? ""}
                        </td>
                        <td contenteditable="true" data-field="end_at">
                            {coupon.end_at ?? ""}
                        </td>
                        <td contenteditable="true" data-field="usage_limit">
                            {coupon.usage_limit ?? ""}
                        </td>
                        <td contenteditable="true" data-field="per_user_limit">
                            {coupon.per_user_limit ?? ""}
                        </td>
                        <td>
                            <select data-field="is_active">
                                <option
                                    value="true"
                                    selected={coupon.is_active}
                                >
                                    Aktif
                                </option>
                                <option
                                    value="false"
                                    selected={!coupon.is_active}
                                >
                                    Nonaktif
                                </option>
                            </select>
                        </td>
                        <td>
                            <RowActions />
                        </td>
                    </tr>
                ))
            }
        </tbody>
    </AdminDataTable>

    <script>
        import { bindCreateForm, bindCrudTable } from "../../lib/admin-client";

        bindCreateForm({
            formSelector: "#coupon-form",
            endpoint: "/api/admin/coupons",
        });

        bindCrudTable({
            basePath: "/api/admin/coupons",
            deleteConfirm: "Hapus kupon ini?",
            reloadOnSave: true,
        });
    </script>
</AdminLayout>
