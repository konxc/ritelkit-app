---
import AdminLayout from "../../layouts/AdminLayout.astro";
import CouponsManager from "../../components/admin/pages/CouponsManager.svelte";
import { requireAdmin } from "../../lib/auth";
import { initDb, getDb } from "../../lib/db";

await initDb(Astro);
const admin = await requireAdmin(Astro);
if (!admin) {
    return Astro.redirect("/admin/login");
}
const db = getDb(Astro);
const coupons = await db.execute(
    "SELECT id, code, type, value, min_order, max_discount, start_at, end_at, usage_limit, per_user_limit, is_active FROM coupons ORDER BY created_at DESC",
);
---

<AdminLayout title="Kupon">
    <CouponsManager rows={coupons.rows as any[]} client:load />
</AdminLayout>
