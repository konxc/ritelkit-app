---
import HeroInteractions from "@components/HeroInteractions.svelte";
import Layout from "@layouts/Layout.astro";

const galleryImages = [
  "sholawat bakery (1).jpeg",
  "sholawat bakery (2).jpeg",
  "sholawat bakery (3).jpeg",
  "sholawat bakery (4).jpeg",
  "sholawat bakery (5).jpeg",
  "sholawat bakery (6).jpeg",
  "sholawat bakery (7).jpeg",
  "sholawat bakery (9).jpeg",
  "sholawat bakery (10).jpeg",
  "bakery bantul.jpeg",
  "bakery jogja.jpeg",
  "bakery pasar bantul.jpeg",
];
const galleryRatioClasses = [
  "aspect-[4/5]",
  "aspect-[3/4]",
  "aspect-square",
  "aspect-[5/4]",
  "aspect-[4/3]",
  "aspect-[3/5]",
];

const waLink =
  "https://wa.me/6281314537475?text=Halo%20Roti%20Sholawat%2C%20saya%20mau%20konsultasi%20paket%20snack%20box%20untuk%20acara.";
---

<Layout
  title="Roti Sholawat — Semesta Bersholawat"
  description="Roti dan snack box komunitas di Yogyakarta untuk pengajian, hajatan, sekolah, dan acara keluarga. Pesan online atau gabung kemitraan."
  hideFooter={true}
>
  <main class="home-page">
    <!-- Hero -->
    <section class="relative overflow-hidden pt-20 pb-40 lg:pb-32">
      <!-- Dot grid background -->
      <div
        class="pointer-events-none absolute inset-0 z-0 bg-[radial-gradient(rgba(37,190,196,0.1)_1px,transparent_1px)] bg-[size:22px_22px] opacity-35"
      >
      </div>

      <!-- Animated Blobs & Gradient -->
      <div class="absolute inset-0 z-0">
        <img
          src="/images/bakery/sholawat bakery (5).jpeg"
          alt=""
          class="pointer-events-none absolute inset-0 z-0 h-full w-full object-cover opacity-50"
          loading="lazy"
        />
        <div class="pointer-events-none absolute inset-0 z-0 bg-[#f6fffd]/72"></div>
        <span
          class="animate-blob-float absolute -top-[120px] -left-[80px] h-[420px] w-[420px] rounded-full bg-[radial-gradient(circle,var(--color-secondary-light),var(--color-secondary))] opacity-60 duration-[20s]"
        ></span>
        <span
          class="animate-blob-float absolute -right-[60px] -bottom-[120px] h-[300px] w-[300px] rounded-full bg-[radial-gradient(circle,var(--color-primary-light),var(--color-primary))] opacity-60 duration-[16s]"
        ></span>
        <span
          class="animate-blob-float absolute top-[30%] right-[20%] h-[180px] w-[180px] rounded-full bg-[radial-gradient(circle,rgba(37,190,196,0.35),rgba(37,190,196,0))] opacity-60 duration-[22s]"
        ></span>
        <div
          class="pointer-events-none absolute inset-[auto_0_0_0] z-0 h-[120px] bg-[linear-gradient(180deg,rgba(246,255,253,0)_0%,rgba(238,250,247,0.95)_100%)]"
        >
        </div>
      </div>
      <div
        class="relative z-[1] container flex flex-col items-center gap-y-16 lg:grid lg:grid-cols-2 lg:gap-x-12 lg:gap-y-0"
      >
        <div class="hero-copy order-1 lg:col-start-1 lg:row-start-1 lg:self-end lg:pb-6">
          <div
            class="bg-primary/18 text-primary-dark mb-4 inline-flex rounded-full px-[14px] py-[6px] font-semibold tracking-[0.4px] shadow-[0_8px_18px_rgba(37,190,196,0.15)]"
          >
            Semesta Bersholawat
          </div>
          <h1 class="font-fraunces text-primary-dark mb-3 grid gap-1.5 text-[clamp(2.6rem,5vw,4.2rem)] leading-[1.2]">
            <span class="block text-[clamp(2.1rem,4.2vw,3.3rem)] tracking-[0.2px]"> Roti untuk setiap </span>
            <span
              class="text-text inline-flex flex-nowrap items-baseline gap-2.5 text-[clamp(1.9rem,3.8vw,3rem)] max-[520px]:flex-wrap"
            >
              <span
                class="font-fraunces text-primary-dark after:animate-underline-pulse relative inline-block px-1.5 text-[clamp(2.8rem,6.2vw,4.6rem)] leading-[1.05] italic after:absolute after:right-0 after:bottom-1.5 after:left-0 after:-z-1 after:h-2.5 after:-rotate-2 after:rounded-full after:bg-[#fdef5a]/55 after:content-['']"
              >
                momen
              </span>
              <span class="text-[clamp(1.8rem,3.4vw,2.8rem)]">kebersamaan.</span>
            </span>
          </h1>
          <p class="text-text-muted mb-5.5 text-[1.05rem]">
            Snack box & roti event untuk pengajian, hajatan, sekolah, kampus, dan komunitas di Yogyakarta. Rasa
            konsisten, paket rapi, dan penuh keberkahan.
          </p>
          <div class="mt-6 mb-4 flex flex-wrap gap-3">
            <a class="btn btn-primary" href="/order">Pesan Online</a>
            <a class="btn btn-secondary" href="#mitra">Jadi Mitra</a>
            <a class="btn btn-ghost" href={waLink} target="_blank">Konsultasi Paket</a>
          </div>
        </div>

        <div class="hidden w-full max-w-[620px] self-start lg:order-3 lg:col-start-1 lg:row-start-2 lg:block lg:pt-2">
          <div class="mb-4 grid grid-cols-[repeat(auto-fit,minmax(140px,1fr))] gap-2.5">
            {
              [
                {
                  title: "Fokus Yogyakarta",
                  desc: "Komunitas & event",
                },
                {
                  title: "Respons Cepat",
                  desc: "Koordinasi ringan",
                },
                {
                  title: "Paket Rapi",
                  desc: "Siap untuk acara",
                },
              ].map((feature) => (
                <div class="border-primary/18 flex flex-col gap-0.5 rounded-[14px] border bg-white/70 p-2">
                  <strong class="text-primary-dark text-[0.95rem]">{feature.title}</strong>
                  <span class="text-text-muted text-[0.82rem]">{feature.desc}</span>
                </div>
              ))
            }
          </div>
          <div class="flex flex-wrap gap-2">
            {
              ["Pengajian", "Hajatan", "Sekolah", "Komunitas", "DIY"].map((tag) => (
                <span class="bg-surface border-primary/18 rounded-full border px-3 py-1.5 text-[0.85rem] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-sm">
                  {tag}
                </span>
              ))
            }
          </div>
        </div>
        <div
          class="relative order-2 flex flex-col items-center justify-center self-center lg:col-start-2 lg:row-span-2 lg:row-start-1 lg:flex-row"
        >
          <div
            class="bg-surface animate-card-float max-w-[340px] -rotate-2 overflow-hidden rounded-3xl shadow-[0_30px_60px_rgba(0,0,0,0.12)] transition-all duration-300 hover:-translate-y-2 hover:-rotate-0 hover:shadow-[0_40px_80px_rgba(0,0,0,0.25)]"
          >
            <img
              src="/images/bakery/sholawat bakery (9).jpeg"
              alt="Paket snack box Roti Sholawat"
              class="h-[260px] w-full object-cover"
            />
            <div class="p-4">
              <strong class="text-primary-dark block">Paket Snack Box Komunitas</strong>
              <p class="text-text-muted mt-1 text-sm">Rapi, terjangkau, siap untuk acara.</p>
            </div>
          </div>
          <div
            class="bg-secondary text-primary-dark animate-sticker-wiggle mt-4 mr-2 rotate-6 self-end rounded-[18px] px-4 py-2.5 font-semibold shadow-[0_12px_24px_rgba(0,0,0,0.12)] lg:absolute lg:top-6 lg:right-[-8px] lg:mt-0 lg:mr-0 lg:rotate-3"
          >
            Rasa • Rapi • Berkah
          </div>
        </div>
        <div class="order-4 mt-6 w-full max-w-[620px] self-center lg:hidden">
          <div class="border-primary/15 rounded-[20px] border bg-white/90 p-4 shadow-[0_16px_40px_rgba(0,0,0,0.12)]">
            <div class="mb-3 grid grid-cols-1 gap-2.5">
              {
                [
                  {
                    title: "Fokus Yogyakarta",
                    desc: "Komunitas & event",
                  },
                  {
                    title: "Respons Cepat",
                    desc: "Koordinasi ringan",
                  },
                  {
                    title: "Paket Rapi",
                    desc: "Siap untuk acara",
                  },
                ].map((feature) => (
                  <div class="border-primary/10 rounded-[12px] border px-3 py-2">
                    <strong class="text-primary-dark text-sm">{feature.title}</strong>
                    <p class="text-text-muted text-[0.8rem]">{feature.desc}</p>
                  </div>
                ))
              }
            </div>
            <div class="flex flex-wrap gap-2">
              {
                ["Pengajian", "Hajatan", "Sekolah", "Komunitas", "DIY"].map((tag) => (
                  <span class="bg-surface border-primary/18 rounded-full border px-3 py-1.5 text-[0.85rem] shadow-sm">
                    {tag}
                  </span>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section relative -mt-20 overflow-hidden bg-white/50 pt-32 pb-24 backdrop-blur-sm">
      <div class="container flex flex-col items-center gap-12 md:grid md:grid-cols-2 md:gap-16">
        <div class="reveal order-2 mt-4 md:order-1 md:mt-0">
          <span class="sub-title">Keunggulan Kami</span>
          <h2 class="mb-6">
            Rasa yang <span class="text-primary italic">Konsisten</span>, Berkah yang <span class="text-primary italic"
              >Nyata</span
            >.
          </h2>
          <div class="grid gap-6">
            <div class="flex gap-4">
              <div
                class="bg-primary/10 text-primary flex h-12 w-12 flex-none items-center justify-center rounded-2xl text-xl"
              >
                ✨
              </div>
              <div>
                <h4 class="mb-1 text-lg font-bold">Kualitas Premium</h4>
                <p class="text-text-muted">
                  Bahan pilihan dengan standar kebersihan tinggi untuk rasa yang memanjakan lidah.
                </p>
              </div>
            </div>
            <div class="flex gap-4">
              <div
                class="bg-primary/10 text-primary flex h-12 w-12 flex-none items-center justify-center rounded-2xl text-xl"
              >
                📦
              </div>
              <div>
                <h4 class="mb-1 text-lg font-bold">Packaging Rapi</h4>
                <p class="text-text-muted">Siap dibagikan langsung di acara Anda tanpa perlu repot menata ulang.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div
                class="bg-primary/10 text-primary flex h-12 w-12 flex-none items-center justify-center rounded-2xl text-xl"
              >
                🙏
              </div>
              <div>
                <h4 class="mb-1 text-lg font-bold">Penuh Keberkahan</h4>
                <p class="text-text-muted">
                  Dibuat dengan semangat berbagi dan doa untuk setiap momen kebersamaan Anda.
                </p>
              </div>
            </div>
          </div>
        </div>
        <div class="reveal relative order-1 delay-200 md:order-2">
          <div
            class="from-primary/20 to-secondary/20 animate-blob-float absolute inset-0 aspect-square rounded-full bg-gradient-to-tr opacity-30 blur-3xl"
          >
          </div>
          <img
            src="/images/bakery/sholawat bakery (1).jpeg"
            alt="Roti Sholawat Segar"
            class="relative z-10 rotate-3 rounded-3xl shadow-2xl transition-transform duration-500 hover:rotate-0"
          />
        </div>
      </div>
    </section>

    <!-- Community -->
    <section id="komunitas" class="section reveal">
      <div class="community-grid container flex flex-col items-center gap-8 md:grid md:grid-cols-2 md:gap-12">
        <div class="order-1 md:order-none">
          <h2>Dipercaya untuk Pendukung Berbagai Acara</h2>
          <p class="lead">
            Pengajian, kampus, sekolah, UMKM, hingga event organizer. Roti Sholawat hadir sebagai penguat momen
            kebersamaan.
          </p>
          <div class="community-tags my-4 flex flex-wrap gap-2">
            <span class="bg-primary/12 rounded-full px-3 py-1.5 text-[0.85rem]">Pengajian & Majelis</span>
            <span class="bg-primary/12 rounded-full px-3 py-1.5 text-[0.85rem]">Kampus & Sekolah</span>
            <span class="bg-primary/12 rounded-full px-3 py-1.5 text-[0.85rem]">UMKM Lokal</span>
            <span class="bg-primary/12 rounded-full px-3 py-1.5 text-[0.85rem]">Penyelenggara Acara</span>
          </div>
          <a class="btn btn-secondary hidden md:inline-flex" href={waLink} target="_blank">Konsultasi Paket Komunitas</a
          >
        </div>
        <div class="community-media order-2 grid grid-cols-2 gap-3.5 md:order-none">
          <img
            src="/images/bakery/bakery bantul.jpeg"
            alt="Aktivasi komunitas"
            class="h-[220px] rounded-[18px] object-cover shadow-[0_16px_36px_rgba(0,0,0,0.12)] transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_20px_42px_rgba(0,0,0,0.16)]"
          />
          <img
            src="/images/bakery/sholawat bakery (3).jpeg"
            alt="Proses produksi"
            class="text-primary-dark h-[220px] rounded-[18px] object-cover shadow-[0_16px_36px_rgba(0,0,0,0.12)] transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_20px_42px_rgba(0,0,0,0.16)]"
          />
        </div>
        <div class="order-3 mt-2 flex w-full justify-center md:hidden">
          <a class="btn btn-secondary w-full justify-center py-3.5 text-base" href={waLink} target="_blank"
            >Konsultasi Paket Komunitas</a
          >
        </div>
      </div>
    </section>

    <!-- Products -->
    <section id="paket" class="section section-alt reveal">
      <div class="container">
        <div class="section-head">
          <h2>Paket & Produk Unggulan</h2>
          <p>Portofolio 3 tier untuk kebutuhan harian, event, hingga paket premium.</p>
        </div>
        <div class="tier-grid carousel-mobile grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-[18px] pb-6">
          <div class="tier-card group">
            <span class="tier-badge">Core</span>
            <h3>Roti Harian</h3>
            <p>Roti manis & roti tawar untuk kebutuhan harian.</p>
          </div>
          <div class="tier-card highlight">
            <span class="tier-badge">Value</span>
            <h3>Snack Box Komunitas</h3>
            <p>Paket paling banyak dipilih untuk pengajian, sekolah, dan hajatan.</p>
          </div>
          <div class="tier-card">
            <span class="tier-badge">Unggulan</span>
            <h3>Paket Premium</h3>
            <p>Produk hero dengan rasa unik, packaging eksklusif, dan storytelling kuat.</p>
          </div>
        </div>
        <div class="mt-10 flex flex-wrap justify-center gap-4">
          <a class="btn btn-primary" href="/order">Lihat Paket</a>
          <a class="btn btn-ghost" href={waLink} target="_blank">Diskusi Kebutuhan Acara</a>
        </div>
      </div>
    </section>

    <!-- Partnership -->
    <section id="mitra" class="section section-alt reveal">
      <div class="container">
        <div class="section-head">
          <h2>Tumbuh Bersama Roti Sholawat</h2>
          <p>Program kemitraan untuk reseller, agen komunitas, dan kolaborasi UMKM.</p>
        </div>
        <div class="partner-layout grid grid-cols-[1.2fr_0.8fr] items-start gap-8 max-[900px]:grid-cols-1">
          <div class="flex flex-col gap-6" id="partner-tabs-container">
            <div class="no-scrollbar border-primary/10 -mb-2 flex gap-2.5 overflow-x-auto border-b pb-1 md:hidden">
              <button
                id="tab-benefit"
                class="tab-btn bg-primary rounded-full border border-transparent px-4 py-2 text-sm font-bold whitespace-nowrap text-white shadow-sm transition-all"
                >Benefit Kemitraan</button
              >
              <button
                id="tab-cara"
                class="tab-btn text-text-muted border-primary/10 rounded-full border bg-white/60 px-4 py-2 text-sm font-bold whitespace-nowrap transition-all hover:bg-white"
                >Cara Gabung?</button
              >
            </div>
            <div class="partner-card benefit-card transition-all max-md:block max-md:[&_ul]:pl-0" id="content-benefit">
              <div
                class="border-primary/10 mb-4 flex items-center justify-between border-b pb-4 max-[500px]:flex-col max-[500px]:items-start max-[500px]:gap-3"
              >
                <h3>Benefit Kemitraan</h3>
                <div class="flex gap-2">
                  <span class="bg-primary/10 text-primary-dark rounded-full px-3 py-1 text-xs font-bold">Reseller</span>
                  <span class="bg-primary/10 text-primary-dark rounded-full px-3 py-1 text-xs font-bold">Komunitas</span
                  >
                </div>
              </div>
              <ul class="text-text-muted mt-0 list-none space-y-4 p-0">
                <li class="flex items-start gap-4">
                  <span
                    class="bg-primary/10 text-primary flex h-10 w-10 flex-none items-center justify-center rounded-xl text-lg font-bold"
                    >%</span
                  >
                  <div>
                    <strong class="text-primary-dark mb-1 block">Skema Margin Jelas</strong>
                    <p>Margin menguntungkan dengan sistem yang transparan dan mudah dipantau.</p>
                  </div>
                </li>
                <li class="flex items-start gap-4">
                  <span
                    class="bg-primary/10 text-primary flex h-10 w-10 flex-none items-center justify-center rounded-xl text-lg font-bold"
                    >★</span
                  >
                  <div>
                    <strong class="text-primary-dark mb-1 block">Dukungan Branding Penuh</strong>
                    <p>Akses ke materi promosi, konten media sosial, dan bimbingan marketing.</p>
                  </div>
                </li>
                <li class="flex items-start gap-4">
                  <span
                    class="bg-primary/10 text-primary flex h-10 w-10 flex-none items-center justify-center rounded-xl text-lg font-bold"
                    >✓</span
                  >
                  <div>
                    <strong class="text-primary-dark mb-1 block">Kualitas Produk Stabil</strong>
                    <p>Standar kualitas premium dengan rantai pasok yang aman dan terjadwal.</p>
                  </div>
                </li>
                <li class="flex items-start gap-4">
                  <span
                    class="bg-primary/10 text-primary flex h-10 w-10 flex-none items-center justify-center rounded-xl text-lg font-bold"
                    >🎁</span
                  >
                  <div>
                    <strong class="text-primary-dark mb-1 block">Akses Promo & Musiman</strong>
                    <p>Prioritas untuk paket musiman dan program loyalti khusus mitra.</p>
                  </div>
                </li>
              </ul>
            </div>

            <div
              class="partner-card steps-card partnership-steps transition-all max-md:hidden max-md:[&_ul]:pl-0"
              id="content-cara"
            >
              <div class="border-primary/10 mb-5 flex items-center justify-between border-b pb-4">
                <h3>Cara Bergabung?</h3>
                <span
                  class="bg-secondary/20 text-primary-dark border-secondary/50 rounded-full border px-3 py-1 text-xs font-bold"
                  >Cepat & Mudah</span
                >
              </div>
              <ul class="text-text-muted mt-0 list-none space-y-6 p-0">
                <li class="relative flex items-start gap-5">
                  <div class="bg-primary/20 absolute top-10 -bottom-6 left-5 w-px"></div>
                  <span
                    class="border-primary text-primary relative z-10 flex h-10 w-10 flex-none items-center justify-center rounded-full border-2 bg-white font-bold shadow-sm"
                    >01</span
                  >
                  <div>
                    <strong class="text-primary-dark mb-1 block">Konsultasi WA</strong>
                    <p class="text-sm">Tentukan area dan target layanan Anda.</p>
                  </div>
                </li>
                <li class="relative flex items-start gap-5">
                  <div class="bg-primary/20 absolute top-10 -bottom-6 left-5 w-px"></div>
                  <span
                    class="border-primary text-primary relative z-10 flex h-10 w-10 flex-none items-center justify-center rounded-full border-2 bg-white font-bold shadow-sm"
                    >02</span
                  >
                  <div>
                    <strong class="text-primary-dark mb-1 block">Pilih Paket</strong>
                    <p class="text-sm">Pilih stok awal sesuai modal & kapasitas.</p>
                  </div>
                </li>
                <li class="relative flex items-start gap-5">
                  <span
                    class="border-primary text-primary relative z-10 flex h-10 w-10 flex-none items-center justify-center rounded-full border-2 bg-white font-bold shadow-sm"
                    >03</span
                  >
                  <div>
                    <strong class="text-primary-dark mb-1 block">Mulai Jualan</strong>
                    <p class="text-sm">Dapatkan materi promo & aktivasi mitra.</p>
                  </div>
                </li>
              </ul>
              <div class="border-primary/10 mt-8 flex justify-center border-t pt-6">
                <a class="btn btn-primary btn-shine w-full justify-center" href={waLink} target="_blank">
                  Gabung Mitra Sekarang
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
                  >
                </a>
              </div>
            </div>
          </div>

          <div class="relative z-20 flex flex-col gap-6 pt-0 max-lg:z-10 max-lg:mt-0 lg:-mt-64">
            <a
              class="partner-feature bg-primary flex flex-col items-center justify-center text-center"
              href="https://fb.com/b.shoprem/posts/752539010437233"
              target="_blank"
              rel="noopener"
            >
              <img src="/images/sosmed/grand-opening.jpg" alt="Pembukaan Cabang Roti Sholawat" loading="lazy" />
              <div class="feature-overlay">
                <span class="overlay-tag">Pembukaan Cabang</span>
                <div class="overlay-content">
                  <span>Cabang Imogiri</span>
                  <strong>Keluarga Roti Sholawat Terus Tumbuh</strong>
                </div>
              </div>
            </a>

            <div
              class="group flex flex-col gap-4 rounded-[20px] border border-white/60 bg-white/85 p-6 shadow-[0_10px_30px_rgba(0,0,0,0.04)] backdrop-blur-xl transition-all duration-400 hover:translate-y-[-8px] hover:bg-white hover:shadow-[0_20px_48px_rgba(0,0,0,0.08)]"
            >
              <div class="mb-3 flex items-start justify-between gap-3">
                <div>
                  <h3 class="font-fraunces text-primary-dark text-xl leading-tight">Cerita Mereka</h3>
                  <p class="text-text-muted text-[0.85rem] leading-relaxed">Penggalan kisah para mitra & pelanggan.</p>
                </div>
                <div class="testimonial-dots mt-3 flex items-center justify-center gap-1.5">
                  <div class="flex gap-1.5">
                    <span
                      class="bg-primary h-2 w-2 scale-125 transform rounded-full opacity-100 transition-all duration-200"
                    ></span>
                    <span class="bg-primary/40 h-2 w-2 rounded-full transition-all duration-200"></span>
                    <span class="bg-primary/40 h-2 w-2 rounded-full transition-all duration-200"></span>
                  </div>
                </div>
