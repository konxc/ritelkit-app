---
import Layout from "../layouts/Layout.astro";

const galleryImages = [
    "sholawat bakery (1).jpeg",
    "sholawat bakery (2).jpeg",
    "sholawat bakery (3).jpeg",
    "sholawat bakery (4).jpeg",
    "sholawat bakery (5).jpeg",
    "sholawat bakery (6).jpeg",
    "sholawat bakery (7).jpeg",
    "sholawat bakery (9).jpeg",
    "sholawat bakery (10).jpeg",
    "bakery bantul.jpeg",
    "bakery jogja.jpeg",
    "bakery pasar bantul.jpeg",
];
const galleryRatioClasses = [
    "aspect-[4/5]",
    "aspect-[3/4]",
    "aspect-square",
    "aspect-[5/4]",
    "aspect-[4/3]",
    "aspect-[3/5]",
];

const waLink =
    "https://wa.me/6281314537475?text=Halo%20Roti%20Sholawat%2C%20saya%20mau%20konsultasi%20paket%20snack%20box%20untuk%20acara.";
---

<Layout
    title="Roti Sholawat — Semesta Bersholawat"
    description="Roti dan snack box komunitas di Yogyakarta untuk pengajian, hajatan, sekolah, and acara keluarga. Order online atau gabung kemitraan."
    hideFooter={true}
>
    <main class="home-page">
        <!-- Hero -->
        <section class="relative overflow-hidden pt-20 pb-40 lg:pb-32">
            <!-- Dot grid background -->
            <div
                class="absolute inset-0 z-0 bg-[radial-gradient(rgba(37,190,196,0.1)_1px,transparent_1px)] bg-[size:22px_22px] opacity-35 pointer-events-none"
            >
            </div>

            <!-- Animated Blobs & Gradient -->
            <div class="absolute inset-0 z-0">
                <img
                    src="/images/bakery/sholawat bakery (5).jpeg"
                    alt=""
                    class="absolute inset-0 w-full h-full object-cover opacity-50 pointer-events-none z-0"
                    loading="lazy"
                />
                <div
                    class="absolute inset-0 bg-[#f6fffd]/72 pointer-events-none z-0"
                >
                </div>
                <span
                    class="absolute rounded-full opacity-60 animate-blob-float w-[420px] h-[420px] bg-[radial-gradient(circle,var(--color-secondary-light),var(--color-secondary))] -top-[120px] -left-[80px] duration-[20s]"
                ></span>
                <span
                    class="absolute rounded-full opacity-60 animate-blob-float w-[300px] h-[300px] bg-[radial-gradient(circle,var(--color-primary-light),var(--color-primary))] -bottom-[120px] -right-[60px] duration-[16s]"
                ></span>
                <span
                    class="absolute rounded-full opacity-60 animate-blob-float w-[180px] h-[180px] bg-[radial-gradient(circle,rgba(37,190,196,0.35),rgba(37,190,196,0))] top-[30%] right-[20%] duration-[22s]"
                ></span>
                <div
                    class="absolute inset-[auto_0_0_0] h-[120px] bg-[linear-gradient(180deg,rgba(246,255,253,0)_0%,rgba(238,250,247,0.95)_100%)] pointer-events-none z-0"
                >
                </div>
            </div>
            <div
                class="container relative z-[1] flex flex-col lg:grid lg:grid-cols-2 gap-y-16 lg:gap-y-0 lg:gap-x-12 items-center"
            >
                <div
                    class="hero-copy order-1 lg:col-start-1 lg:row-start-1 lg:self-end lg:pb-6"
                >
                    <div
                        class="inline-flex bg-primary/18 text-primary-dark px-[14px] py-[6px] rounded-full font-semibold tracking-[0.4px] mb-4 shadow-[0_8px_18px_rgba(37,190,196,0.15)]"
                    >
                        Semesta Bersholawat
                    </div>
                    <h1
                        class="grid gap-1.5 mb-3 text-[clamp(2.6rem,5vw,4.2rem)] font-fraunces text-primary-dark leading-[1.2]"
                    >
                        <span
                            class="block text-[clamp(2.1rem,4.2vw,3.3rem)] tracking-[0.2px]"
                        >
                            Roti untuk setiap
                        </span>
                        <span
                            class="inline-flex items-baseline gap-2.5 flex-nowrap max-[520px]:flex-wrap text-[clamp(1.9rem,3.8vw,3rem)] text-text"
                        >
                            <span
                                class="font-fraunces italic text-primary-dark relative inline-block px-1.5 text-[clamp(2.8rem,6.2vw,4.6rem)] leading-[1.05] after:content-[''] after:absolute after:left-0 after:right-0 after:bottom-1.5 after:h-2.5 after:bg-[#fdef5a]/55 after:-z-1 after:rounded-full after:-rotate-2 after:animate-underline-pulse"
                            >
                                momen
                            </span>
                            <span class="text-[clamp(1.8rem,3.4vw,2.8rem)]"
                                >kebersamaan.</span
                            >
                        </span>
                    </h1>
                    <p class="text-[1.05rem] text-text-muted mb-5.5">
                        Snack box & roti event untuk pengajian, hajatan,
                        sekolah, kampus, dan komunitas di Yogyakarta. Rasa
                        konsisten, paket rapi, dan penuh keberkahan.
                    </p>
                    <div class="flex flex-wrap gap-3 mt-6 mb-4">
                        <a class="btn btn-primary" href="/order">Order Online</a
                        >
                        <a class="btn btn-secondary" href="#mitra">Jadi Mitra</a
                        >
                        <a class="btn btn-ghost" href={waLink} target="_blank"
                            >Konsultasi Paket</a
                        >
                    </div>
                </div>

                <div
                    class="order-3 lg:col-start-1 lg:row-start-2 max-w-[620px] w-full self-start lg:pt-2"
                >
                    <div
                        class="grid grid-cols-[repeat(auto-fit,minmax(140px,1fr))] gap-2.5 mb-4"
                    >
                        {
                            [
                                {
                                    title: "Fokus Yogyakarta",
                                    desc: "Komunitas & event",
                                },
                                {
                                    title: "Respons Cepat",
                                    desc: "Koordinasi ringan",
                                },
                                {
                                    title: "Paket Rapi",
                                    desc: "Siap untuk acara",
                                },
                            ].map((feature) => (
                                <div class="bg-white/70 border border-primary/18 rounded-[14px] p-2 flex flex-col gap-0.5">
                                    <strong class="text-primary-dark text-[0.95rem]">
                                        {feature.title}
                                    </strong>
                                    <span class="text-text-muted text-[0.82rem]">
                                        {feature.desc}
                                    </span>
                                </div>
                            ))
                        }
                    </div>
                    <div class="flex flex-wrap gap-2">
                        {
                            [
                                "Pengajian",
                                "Hajatan",
                                "Sekolah",
                                "Komunitas",
                                "DIY",
                            ].map((tag) => (
                                <span class="bg-surface border border-primary/18 px-3 py-1.5 rounded-full text-[0.85rem] transition-all duration-300 hover:-translate-y-0.5 hover:shadow-sm">
                                    {tag}
                                </span>
                            ))
                        }
                    </div>
                </div>
                <div
                    class="relative flex flex-col items-center justify-center order-2 lg:flex-row lg:col-start-2 lg:row-start-1 lg:row-span-2 self-center"
                >
                    <div
                        class="bg-surface rounded-3xl overflow-hidden shadow-[0_30px_60px_rgba(0,0,0,0.12)] -rotate-2 max-w-[340px] animate-card-float transition-all duration-300 hover:-translate-y-1.5 hover:-rotate-1 hover:shadow-[0_36px_70px_rgba(0,0,0,0.18)]"
                    >
                        <img
                            src="/images/bakery/sholawat bakery (9).jpeg"
                            alt="Paket snack box Roti Sholawat"
                            class="w-full h-[260px] object-cover"
                        />
                        <div class="p-4">
                            <strong class="block text-primary-dark"
                                >Paket Snack Box Komunitas</strong
                            >
                            <p class="text-text-muted text-sm mt-1">
                                Rapi, terjangkau, siap untuk acara.
                            </p>
                        </div>
                    </div>
                    <div
                        class="mt-4 self-end mr-2 bg-secondary text-primary-dark px-4 py-2.5 rounded-[18px] rotate-6 font-semibold shadow-[0_12px_24px_rgba(0,0,0,0.12)] animate-sticker-wiggle lg:absolute lg:right-0 lg:-bottom-5 lg:mt-0 lg:mr-0"
                    >
                        Rasa • Rapi • Berkah
                    </div>
                </div>
            </div>
        </section>

        <section
            class="section relative overflow-hidden bg-white/50 backdrop-blur-sm -mt-20 pt-32 pb-24"
        >
            <div
                class="container flex flex-col md:grid md:grid-cols-2 gap-12 md:gap-16 items-center"
            >
                <div class="reveal order-2 md:order-1 mt-4 md:mt-0">
                    <span class="sub-title">Keunggulan Kami</span>
                    <h2 class="mb-6">
                        Rasa yang <span class="italic text-primary"
                            >Konsisten</span
                        >, Berkah yang <span class="italic text-primary"
                            >Nyata</span
                        >.
                    </h2>
                    <div class="grid gap-6">
                        <div class="flex gap-4">
                            <div
                                class="w-12 h-12 flex-none bg-primary/10 rounded-2xl flex items-center justify-center text-primary text-xl"
                            >
                                ✨
                            </div>
                            <div>
                                <h4 class="text-lg font-bold mb-1">
                                    Kualitas Premium
                                </h4>
                                <p class="text-text-muted">
                                    Bahan pilihan dengan standar kebersihan
                                    tinggi untuk rasa yang memanjakan lidah.
                                </p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div
                                class="w-12 h-12 flex-none bg-primary/10 rounded-2xl flex items-center justify-center text-primary text-xl"
                            >
                                📦
                            </div>
                            <div>
                                <h4 class="text-lg font-bold mb-1">
                                    Packaging Rapi
                                </h4>
                                <p class="text-text-muted">
                                    Siap dibagikan langsung di acara Anda tanpa
                                    perlu repot menata ulang.
                                </p>
                            </div>
                        </div>
                        <div class="flex gap-4">
                            <div
                                class="w-12 h-12 flex-none bg-primary/10 rounded-2xl flex items-center justify-center text-primary text-xl"
                            >
                                🙏
                            </div>
                            <div>
                                <h4 class="text-lg font-bold mb-1">
                                    Penuh Keberkahan
                                </h4>
                                <p class="text-text-muted">
                                    Dibuat dengan semangat berbagi dan doa untuk
                                    setiap momen kebersamaan Anda.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="relative reveal delay-200 order-1 md:order-2">
                    <div
                        class="aspect-square bg-gradient-to-tr from-primary/20 to-secondary/20 rounded-full animate-blob-float absolute inset-0 blur-3xl opacity-30"
                    >
                    </div>
                    <img
                        src="/images/bakery/sholawat bakery (1).jpeg"
                        alt="Roti Sholawat Fresh"
                        class="rounded-3xl shadow-2xl relative z-10 rotate-3 hover:rotate-0 transition-transform duration-500"
                    />
                </div>
            </div>
        </section>

        <!-- Community -->
        <section id="komunitas" class="section reveal">
            <div
                class="container community-grid flex flex-col md:grid md:grid-cols-2 gap-8 md:gap-12 items-center"
            >
                <div class="order-1 md:order-none">
                    <h2>Dipercaya untuk Pendukung Berbagai Acara</h2>
                    <p class="lead">
                        Pengajian, kampus, sekolah, UMKM, hingga event
                        organizer. Roti Sholawat hadir sebagai penguat momen
                        kebersamaan.
                    </p>
                    <div class="community-tags flex flex-wrap gap-2 my-4">
                        <span
                            class="bg-primary/12 px-3 py-1.5 rounded-full text-[0.85rem]"
                            >Pengajian & Majelis</span
                        >
                        <span
                            class="bg-primary/12 px-3 py-1.5 rounded-full text-[0.85rem]"
                            >Kampus & Sekolah</span
                        >
                        <span
                            class="bg-primary/12 px-3 py-1.5 rounded-full text-[0.85rem]"
                            >UMKM Lokal</span
                        >
                        <span
                            class="bg-primary/12 px-3 py-1.5 rounded-full text-[0.85rem]"
                            >Event Organizer</span
                        >
                    </div>
                    <a
                        class="btn btn-secondary hidden md:inline-flex"
                        href={waLink}
                        target="_blank">Konsultasi Paket Komunitas</a
                    >
                </div>
                <div
                    class="community-media grid grid-cols-2 gap-3.5 order-2 md:order-none"
                >
                    <img
                        src="/images/bakery/bakery bantul.jpeg"
                        alt="Aktivasi komunitas"
                        class="rounded-[18px] h-[220px] object-cover shadow-[0_16px_36px_rgba(0,0,0,0.12)] transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_20px_42px_rgba(0,0,0,0.16)]"
                    />
                    <img
                        src="/images/bakery/sholawat bakery (3).jpeg"
                        alt="Proses produksi"
                        class="rounded-[18px] h-[220px] object-cover shadow-[0_16px_36px_rgba(0,0,0,0.12)] transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_20px_42px_rgba(0,0,0,0.16)] text-primary-dark"
                    />
                </div>
                <div class="order-3 md:hidden w-full flex justify-center mt-2">
                    <a
                        class="btn btn-secondary w-full justify-center py-3.5 text-base"
                        href={waLink}
                        target="_blank">Konsultasi Paket Komunitas</a
                    >
                </div>
            </div>
        </section>

        <!-- Products -->
        <section id="paket" class="section section-alt reveal">
            <div class="container">
                <div class="section-head">
                    <h2>Paket & Produk Unggulan</h2>
                    <p>
                        Portofolio 3 tier untuk kebutuhan harian, event, hingga
                        paket premium.
                    </p>
                </div>
                <div
                    class="tier-grid grid grid-cols-[repeat(auto-fit,minmax(220px,1fr))] gap-[18px] carousel-mobile pb-6"
                >
                    <div class="tier-card group">
                        <span class="tier-badge">Core</span>
                        <h3>Roti Harian</h3>
                        <p>Roti manis & roti tawar untuk kebutuhan harian.</p>
                    </div>
                    <div class="tier-card highlight">
                        <span class="tier-badge">Value</span>
                        <h3>Snack Box Komunitas</h3>
                        <p>
                            Paket paling banyak dipilih untuk pengajian,
                            sekolah, dan hajatan.
                        </p>
                    </div>
                    <div class="tier-card">
                        <span class="tier-badge">Signature</span>
                        <h3>Paket Premium</h3>
                        <p>
                            Produk hero dengan rasa unik, packaging eksklusif,
                            dan storytelling kuat.
                        </p>
                    </div>
                </div>
                <div class="flex flex-wrap justify-center gap-4 mt-10">
                    <a class="btn btn-primary" href="/order">Lihat Paket</a>
                    <a class="btn btn-ghost" href={waLink} target="_blank"
                        >Diskusi Kebutuhan Acara</a
                    >
                </div>
            </div>
        </section>

        <!-- Partnership -->
        <section id="mitra" class="section section-alt reveal">
            <div class="container">
                <div class="section-head">
                    <h2>Tumbuh Bersama Roti Sholawat</h2>
                    <p>
                        Program kemitraan untuk reseller, agen komunitas, dan
                        kolaborasi UMKM.
                    </p>
                </div>
                <div
                    class="partner-layout grid grid-cols-[1.2fr_0.8fr] gap-8 items-start max-[900px]:grid-cols-1"
                >
                    <div
                        class="flex flex-col gap-6"
                        id="partner-tabs-container"
                    >
                        <div
                            class="flex gap-2.5 md:hidden -mb-2 pb-1 overflow-x-auto no-scrollbar border-b border-primary/10"
                        >
                            <button
                                id="tab-benefit"
                                class="tab-btn px-4 py-2 font-bold text-sm bg-primary text-white rounded-full whitespace-nowrap shadow-sm border border-transparent transition-all"
                                >Benefit Kemitraan</button
                            >
                            <button
                                id="tab-cara"
                                class="tab-btn px-4 py-2 font-bold text-sm bg-white/60 text-text-muted hover:bg-white rounded-full whitespace-nowrap border border-primary/10 transition-all"
                                >Cara Gabung?</button
                            >
                        </div>
                        <div
                            class="partner-card benefit-card max-md:block max-md:[&_ul]:pl-0 transition-all"
                            id="content-benefit"
                        >
                            <div
                                class="flex items-center justify-between mb-4 border-b border-primary/10 pb-4 max-[500px]:flex-col max-[500px]:items-start max-[500px]:gap-3"
                            >
                                <h3>Benefit Kemitraan</h3>
                                <div class="flex gap-2">
                                    <span
                                        class="bg-primary/10 text-primary-dark text-xs font-bold px-3 py-1 rounded-full"
                                        >Reseller</span
                                    >
                                    <span
                                        class="bg-primary/10 text-primary-dark text-xs font-bold px-3 py-1 rounded-full"
                                        >Komunitas</span
                                    >
                                </div>
                            </div>
                            <ul
                                class="space-y-4 text-text-muted mt-0 p-0 list-none"
                            >
                                <li class="flex items-start gap-4">
                                    <span
                                        class="w-10 h-10 flex items-center justify-center rounded-xl bg-primary/10 text-primary font-bold text-lg flex-none"
                                        >%</span
                                    >
                                    <div>
                                        <strong
                                            class="block mb-1 text-primary-dark"
                                            >Skema Margin Jelas</strong
                                        >
                                        <p>
                                            Margin menguntungkan dengan sistem
                                            yang transparan dan mudah dipantau.
                                        </p>
                                    </div>
                                </li>
                                <li class="flex items-start gap-4">
                                    <span
                                        class="w-10 h-10 flex items-center justify-center rounded-xl bg-primary/10 text-primary font-bold text-lg flex-none"
                                        >★</span
                                    >
                                    <div>
                                        <strong
                                            class="block mb-1 text-primary-dark"
                                            >Full Branding Support</strong
                                        >
                                        <p>
                                            Akses ke materi promosi, konten
                                            media sosial, dan bimbingan
                                            marketing.
                                        </p>
                                    </div>
                                </li>
                                <li class="flex items-start gap-4">
                                    <span
                                        class="w-10 h-10 flex items-center justify-center rounded-xl bg-primary/10 text-primary font-bold text-lg flex-none"
                                        >✓</span
                                    >
                                    <div>
                                        <strong
                                            class="block mb-1 text-primary-dark"
                                            >Kualitas Produk Stabil</strong
                                        >
                                        <p>
                                            Standar kualitas premium dengan
                                            rantai pasok yang aman dan
                                            terjadwal.
                                        </p>
                                    </div>
                                </li>
                                <li class="flex items-start gap-4">
                                    <span
                                        class="w-10 h-10 flex items-center justify-center rounded-xl bg-primary/10 text-primary font-bold text-lg flex-none"
                                        >🎁</span
                                    >
                                    <div>
                                        <strong
                                            class="block mb-1 text-primary-dark"
                                            >Akses Promo & Seasonal</strong
                                        >
                                        <p>
                                            Prioritas untuk paket musiman dan
                                            program loyalti khusus mitra.
                                        </p>
                                    </div>
                                </li>
                            </ul>
                        </div>

                        <div
                            class="partner-card steps-card partnership-steps max-md:hidden max-md:[&_ul]:pl-0 transition-all"
                            id="content-cara"
                        >
                            <div
                                class="flex items-center justify-between mb-5 border-b border-primary/10 pb-4"
                            >
                                <h3>Cara Bergabung?</h3>
                                <span
                                    class="bg-secondary/20 text-primary-dark text-xs font-bold px-3 py-1 rounded-full border border-secondary/50"
                                    >Cepat & Mudah</span
                                >
                            </div>
                            <ul
                                class="space-y-6 text-text-muted mt-0 p-0 list-none"
                            >
                                <li class="relative flex items-start gap-5">
                                    <div
                                        class="absolute left-5 top-10 -bottom-6 w-px bg-primary/20"
                                    >
                                    </div>
                                    <span
                                        class="w-10 h-10 rounded-full bg-white border-2 border-primary text-primary font-bold flex items-center justify-center flex-none relative z-10 shadow-sm"
                                        >01</span
                                    >
                                    <div>
                                        <strong
                                            class="block mb-1 text-primary-dark"
                                            >Konsultasi WA</strong
                                        >
                                        <p class="text-sm">
                                            Tentukan area dan target layanan
                                            Anda.
                                        </p>
                                    </div>
                                </li>
                                <li class="relative flex items-start gap-5">
                                    <div
                                        class="absolute left-5 top-10 -bottom-6 w-px bg-primary/20"
                                    >
                                    </div>
                                    <span
                                        class="w-10 h-10 rounded-full bg-white border-2 border-primary text-primary font-bold flex items-center justify-center flex-none relative z-10 shadow-sm"
                                        >02</span
                                    >
                                    <div>
                                        <strong
                                            class="block mb-1 text-primary-dark"
                                            >Pilih Paket</strong
                                        >
                                        <p class="text-sm">
                                            Pilih stok awal sesuai modal &
                                            kapasitas.
                                        </p>
                                    </div>
                                </li>
                                <li class="relative flex items-start gap-5">
                                    <span
                                        class="w-10 h-10 rounded-full bg-white border-2 border-primary text-primary font-bold flex items-center justify-center flex-none relative z-10 shadow-sm"
                                        >03</span
                                    >
                                    <div>
                                        <strong
                                            class="block mb-1 text-primary-dark"
                                            >Mulai Jualan</strong
                                        >
                                        <p class="text-sm">
                                            Dapatkan materi promo & aktivasi
                                            mitra.
                                        </p>
                                    </div>
                                </li>
                            </ul>
                            <div
                                class="mt-8 pt-6 border-t border-primary/10 flex justify-center"
                            >
                                <a
                                    class="btn btn-primary btn-shine w-full justify-center"
                                    href={waLink}
                                    target="_blank"
                                >
                                    Gabung Mitra Sekarang
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="18"
                                        height="18"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        ><path d="M5 12h14"></path><path
                                            d="m12 5 7 7-7 7"></path></svg
                                    >
                                </a>
                            </div>
                        </div>
                    </div>

                    <div
                        class="pt-0 lg:-mt-64 relative z-20 max-lg:mt-0 max-lg:z-10 flex flex-col gap-6"
                    >
                        <a
                            class="partner-feature flex flex-col items-center justify-center text-center bg-primary"
                            href="https://fb.com/b.shoprem/posts/752539010437233"
                            target="_blank"
                            rel="noopener"
                        >
                            <img
                                src="/images/sosmed/grand-opening.jpg"
                                alt="Grand Opening Roti Sholawat"
                                loading="lazy"
                            />
                            <div class="feature-overlay">
                                <span class="overlay-tag">Grand Opening</span>
                                <div class="overlay-content">
                                    <span>Cabang Imogiri</span>
                                    <strong
                                        >Keluarga Roti Sholawat Terus Tumbuh</strong
                                    >
                                </div>
                            </div>
