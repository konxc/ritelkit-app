---
import Layout from "../layouts/Layout.astro";

const galleryImages = [
	"sholawat bakery (1).jpeg",
	"sholawat bakery (2).jpeg",
	"sholawat bakery (3).jpeg",
	"sholawat bakery (4).jpeg",
	"sholawat bakery (5).jpeg",
	"sholawat bakery (6).jpeg",
	"sholawat bakery (7).jpeg",
	"sholawat bakery (9).jpeg",
	"sholawat bakery (10).jpeg",
	"bakery bantul.jpeg",
	"bakery jogja.jpeg",
	"bakery pasar bantul.jpeg",
];
---

<Layout>
	<main>
		<!-- Hero Section -->
		<section class="hero text-center">
			<div class="hero-overlay"></div>
			<div class="container hero-content">
				<h1 class="hero-title">Roti Sholawat</h1>
				<p class="hero-subtitle">
					Kelezatan yang Memberkahi setiap Gigitan
				</p>
				<div class="hero-actions mt-l">
					<a
						href="https://wa.me/6287825228548"
						target="_blank"
						class="btn btn-primary">Pesan via WhatsApp</a
					>
					<a href="#produk" class="btn btn-outline">Lihat Menu</a>
				</div>
			</div>
		</section>

		<!-- About Section -->
		<section class="section" data-reveal>
			<div class="container">
				<div class="grid-2">
					<div class="fade-in">
						<h2 class="section-title">
							Cita Rasa Silaturahmi: Bakery Tradisional dengan
							Kualitas Premium
						</h2>
						<p class="mt-m">
							Beroperasi sejak tahun 2016 di bawah naungan CV
							Satria Sejahtera, <strong>Roti Sholawat</strong> hadir
							melampaui fungsi primernya sebagai penyedia nutrisi, menjadi
							representasi identitas sosial dan budaya di Kabupaten
							Bantul.
						</p>
						<p class="mt-s">
							Nama <strong>"Sholawat"</strong> bukan sekadar merek,
							melainkan doa dan penghormatan kepada Nabi Muhammad SAW
							yang diwujudkan dalam nilai-nilai <em
								>halalan thayyiban</em
							> (halal dan baik). Kami dipercaya dengan "kontrak psikologis"
							oleh konsumen karena dedikasi tinggi pada keberkahan proses
							produksi.
						</p>
						<p class="mt-s">
							Kini, kami telah berkembang dengan memiliki <strong
								>lebih dari 30 outlet</strong
							> yang tersebar di DIY dan Jawa Tengah. Dengan standar
							keamanan pangan yang ketat (<strong
								>DINKES P-IRT No. 2063402011625-20</strong
							>) dan komitmen higienitas, setiap gigitan produk
							kami adalah jaminan kualitas untuk menemani momen
							silaturahmi Anda.
						</p>
					</div>
					<div class="image-showcase">
						<img
							src="/images/bakery/sholawat bakery jogja.jpeg"
							alt="Toko Roti Sholawat Cabang Jogja"
							class="rounded shadow"
						/>
					</div>
				</div>
			</div>
		</section>

		<!-- Products Section -->
		<section
			id="produk"
			class="section"
			style="background-color: var(--color-bg-alt);"
			data-reveal
		>
			<div class="container">
				<h2 class="text-center section-title">Menu Favorit</h2>
				<div class="menu-grid mt-l">
					<div class="menu-category">
						<div class="category-header">
							<h3>Roti Manis</h3>
							<p>Varian roti lembut dengan beragam isian</p>
						</div>
						<ul class="product-list mt-m">
							<li>
								<div class="item-info">
									<strong>Roti Mesis</strong><small
										>Coklat butir melimpah</small
									>
								</div>
								<span class="price">Rp 4.000</span>
							</li>
							<li>
								<div class="item-info">
									<strong>Roti Mocca</strong><small
										>Aroma kopi yang khas</small
									>
								</div>
								<span class="price">Rp 4.500</span>
							</li>
							<li>
								<div class="item-info">
									<strong>Roti Blueberry</strong><small
										>Selai buah segar</small
									>
								</div>
								<span class="price">Rp 4.500</span>
							</li>
							<li>
								<div class="item-info">
									<strong>Roti Coklat Keju</strong><small
										>Perpaduan manis gurih</small
									>
								</div>
								<span class="price">Rp 5.000</span>
							</li>
							<li>
								<div class="item-info">
									<strong>Paket 10 Rasa</strong><small
										>Cocok untuk oleh-oleh</small
									>
								</div>
								<span class="price">Rp 34.000</span>
							</li>
						</ul>
					</div>
					<div class="menu-category">
						<div class="category-header">
							<h3>Aneka Cake</h3>
							<p>Kue premium untuk kebersamaan</p>
						</div>
						<ul class="product-list mt-m">
							<li>
								<div class="item-info">
									<strong>Mandarin Isi</strong><small
										>Lapis lembut istimewa</small
									>
								</div>
								<span class="price">Rp 38.000</span>
							</li>
							<li>
								<div class="item-info">
									<strong>Mandarin Keju</strong><small
										>Full topping keju</small
									>
								</div>
								<span class="price">Rp 35.000</span>
							</li>
							<li>
								<div class="item-info">
									<strong>Roll Cake</strong><small
										>Gulungan rasa klasik</small
									>
								</div>
								<span class="price">Rp 30.000</span>
							</li>
							<li>
								<div class="item-info">
									<strong>Mandarin Mesis</strong><small
										>Klasik favorit anak-anak</small
									>
								</div>
								<span class="price">Rp 32.000</span>
							</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<!-- Gallery Section -->
		<section class="section" data-reveal>
			<div class="container">
				<h2 class="text-center section-title">Galeri Produk & Toko</h2>
				<div class="gallery-grid mt-l">
					{
						galleryImages.map((img) => (
							<div class="gallery-wrapper">
								<img
									src={`/images/bakery/${img}`}
									alt="Produk Roti Sholawat"
									class="gallery-item"
									loading="lazy"
								/>
							</div>
						))
					}
				</div>
			</div>
		</section>

		<!-- Location Section -->
		<section
			class="section"
			style="background-color: var(--color-primary-dark); color: white;"
			data-reveal
		>
			<div class="container text-center">
				<h2 style="color: white;" class="section-title">
					Kunjungi Kami
				</h2>
				<div class="mt-l">
					<p style="font-size: 1.2rem;">
						<strong>Alamat:</strong> Jl. Supratman, Kurahan, Bantul, Kec.
						Bantul, Kabupaten Bantul
					</p>
					<p style="font-size: 1.1rem;" class="mt-s">
						<strong>Jam Operasional:</strong> Senin - Sabtu (08:00 - 16:00)
					</p>
					<div class="mt-l">
						<a
							href="https://maps.app.goo.gl/search/Roti+Sholawat+Bantul"
							target="_blank"
							class="btn btn-secondary">Buka Google Maps</a
						>
					</div>
				</div>
			</div>
		</section>

		<!-- Floating WhatsApp Button -->
		<a
			href="https://wa.me/6287825228548"
			target="_blank"
			class="float-wa"
			aria-label="Chat via WhatsApp"
		>
			<svg viewBox="0 0 24 24" width="32" height="32" fill="currentColor">
				<path
					d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.659 1.432 5.617 1.433h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
				></path>
			</svg>
		</a>
	</main>
</Layout>

<script>
	const observerOptions = {
		threshold: 0.1,
	};

	const observer = new IntersectionObserver((entries) => {
		entries.forEach((entry) => {
			if (entry.isIntersecting) {
				entry.target.classList.add("revealed");
			}
		});
	}, observerOptions);

	document.querySelectorAll("[data-reveal]").forEach((el) => {
		observer.observe(el);
	});
</script>

<style>
	.hero {
		position: relative;
		height: 90vh;
		display: flex;
		align-items: center;
		justify-content: center;
		background-image: url("/images/bakery/hero-premium.png");
		background-size: cover;
		background-position: center;
		color: white;
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		background: linear-gradient(
			to bottom,
			rgba(0, 0, 0, 0.3),
			rgba(0, 0, 0, 0.6)
		);
	}

	.hero-content {
		position: relative;
		z-index: 1;
	}

	.hero-title {
		font-size: clamp(3.5rem, 12vw, 6rem);
		color: white;
		margin-bottom: 0.5rem;
		text-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
	}

	.hero-subtitle {
		font-size: 1.8rem;
		font-weight: 300;
		letter-spacing: 2px;
	}

	.section-title {
		font-size: 2.5rem;
		margin-bottom: var(--space-m);
		position: relative;
		display: inline-block;
	}

	.btn {
		display: inline-block;
		padding: 1.2rem 2.5rem;
		border-radius: 50px;
		font-weight: 600;
		margin: 0.5rem;
		cursor: pointer;
		transition: all 0.3s ease;
		text-transform: uppercase;
		letter-spacing: 1px;
	}

	.btn-primary {
		background-color: var(--color-secondary);
		color: var(--color-text);
		border: none;
	}

	.btn-primary:hover {
		background-color: var(--color-secondary-dark);
		transform: translateY(-3px);
		box-shadow: 0 10px 20px rgba(0, 0, 0, 0.2);
	}

	.btn-secondary {
		background-color: white;
		color: var(--color-primary-dark);
		border: none;
	}

	.btn-outline {
		border: 2px solid white;
		color: white;
	}

	.btn-outline:hover {
		background: white;
		color: var(--color-primary-dark);
	}

	.grid-2 {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: var(--space-xl);
		align-items: center;
	}

	.rounded {
		border-radius: 24px;
	}
	.shadow {
		box-shadow: 0 30px 60px rgba(0, 0, 0, 0.12);
	}

	.menu-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
		gap: var(--space-l);
	}

	.menu-category {
		background: white;
		padding: var(--space-l);
		border-radius: 20px;
		box-shadow: 0 15px 40px rgba(0, 0, 0, 0.04);
		transition: transform 0.3s ease;
	}

	.menu-category:hover {
		transform: translateY(-10px);
	}

	.category-header h3 {
		font-size: 1.8rem;
		color: var(--color-primary);
	}

	.product-list {
		list-style: none;
	}

	.product-list li {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 1.2rem 0;
		border-bottom: 1px solid var(--color-bg-alt);
	}

	.item-info strong {
		display: block;
		font-size: 1.1rem;
	}

	.item-info small {
		color: var(--color-text-muted);
	}

	.price {
		font-weight: 700;
		color: var(--color-secondary-dark);
	}

	.gallery-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 1.5rem;
	}

	.gallery-wrapper {
		overflow: hidden;
		border-radius: 16px;
		aspect-ratio: 1;
	}

	.gallery-item {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s cubic-bezier(0.165, 0.84, 0.44, 1);
	}

	.gallery-wrapper:hover .gallery-item {
		transform: scale(1.1);
	}

	@media (max-width: 768px) {
		.hero {
			height: 70vh;
		}
		.section-title {
			font-size: 2rem;
		}
	}

	.float-wa {
		position: fixed;
		bottom: 30px;
		right: 30px;
		background-color: #25d366;
		color: white;
		width: 60px;
		height: 60px;
		border-radius: 50%;
		display: flex;
		align-items: center;
		justify-content: center;
		box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
		z-index: 1000;
		transition:
			transform 0.3s ease,
			background-color 0.3s ease;
	}

	.float-wa:hover {
		transform: scale(1.1);
		background-color: #128c7e;
	}
</style>
