---
import Layout from "../layouts/Layout.astro";

const waLink =
  "https://wa.me/6281314537475?text=Halo%20Roti%20Sholawat%2C%20saya%20mau%20konsultasi%20paket%20snack%20box%20untuk%20acara.";

const faqs = [
  {
    q: "Minimal order snack box?",
    a: "Menyesuaikan paket dan acara. Hubungi kami untuk rekomendasi terbaik.",
  },
  {
    q: "Area pengiriman?",
    a: "Fokus wilayah Yogyakarta (DIY dan sekitarnya). Area lain dapat dikonsultasikan.",
  },
  {
    q: "Berapa lama produksi?",
    a: "Lead time menyesuaikan jumlah pesanan. Semakin awal konfirmasi, semakin optimal jadwal produksi.",
  },
  {
    q: "Apakah bisa custom paket?",
    a: "Bisa. Kami menyesuaikan kebutuhan acara dan budget komunitas Anda.",
  },
  {
    q: "Bagaimana jadi reseller?",
    a: "Hubungi kami via WhatsApp untuk konsultasi wilayah dan paket awal kemitraan.",
  },
];
---

<Layout
    title="Tentang Kami — Roti Sholawat"
    description="Pelajari lebih lanjut tentang nilai-nilai kami dan jawaban atas pertanyaan yang sering diajukan."
>
    <main class="pt-0 pb-20">
        <!-- Why Roti Sholawat? -->
        <section class="section pt-6 lg:pt-8 pb-8 reveal">
            <div class="container">
                <div class="section-head">
                    <span class="sub-title">Keunggulan Kami</span>
                    <h1
                        class="text-3xl md:text-4xl font-fraunces text-primary-dark mb-4 mt-2"
                    >
                        Mengapa Roti Sholawat?
                    </h1>
                    <p>
                        Brand roti yang lahir dari nilai silaturahmi dan
                        keberkahan — fokus pada kebutuhan komunitas di
                        Yogyakarta.
                    </p>
                </div>

                <div class="mt-8">
                    <div
                        class="flex items-center gap-8 mb-12 p-8 bg-white/50 rounded-3xl border border-white/80 backdrop-blur-md max-md:flex-col max-md:text-center max-md:items-center max-md:gap-4"
                    >
                        <div
                            class="px-4 py-2 bg-primary text-white rounded-xl font-extrabold text-[0.9rem] h-min shadow-[0_8px_16px_rgba(37,190,196,0.2)] whitespace-nowrap"
                        >
                            Visi Kami
                        </div>
                        <div class="intro-text">
                            <strong
                                class="block text-2xl text-primary-dark mb-1 leading-[1.2]"
                                >Rasa terjaga, layanan terasa.</strong
                            >
                            <p
                                class="text-text-muted text-[1.1rem] max-w-[600px]"
                            >
                                Kami hadir sebagai partner acara yang bisa
                                diandalkan, dari keluarga hingga komunitas
                                besar.
                            </p>
                        </div>
                    </div>

                    <div
                        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 carousel-mobile"
                    >
                        <!-- Card 1 -->
                        <article
                            class="group relative flex flex-col gap-4 p-8 bg-white rounded-3xl border border-primary/10 shadow-[0_10px_30px_rgba(0,0,0,0.03)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_30px_60px_rgba(0,0,0,0.08)]"
                        >
                            <div
                                class="absolute -bottom-5 -right-[15px] w-[130px] h-[130px] opacity-4 -rotate-15 pointer-events-none transition-all duration-500 z-1 group-hover:opacity-8 group-hover:rotate-0 group-hover:scale-110 group-hover:-bottom-[10px] text-primary"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="100%"
                                    height="100%"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="lucide lucide-shovels"
                                    ><path d="M2 22v-5l5-5 5 5v5z"></path><path
                                        d="M9.5 14.5L16 8"></path><path
                                        d="m17 2 5 5-.5.5a3.53 3.53 0 0 1-5 0l-1-1a3.53 3.53 0 0 1 0-5Z"
                                    ></path></svg
                                >
                            </div>
                            <div
                                class="flex items-center justify-between mb-2 relative z-2"
                            >
                                <div
                                    class="w-12 h-12 rounded-2xl flex items-center justify-center text-white bg-primary"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="lucide lucide-shovels"
                                        ><path d="M2 22v-5l5-5 5 5v5z"
                                        ></path><path d="M9.5 14.5L16 8"
                                        ></path><path
                                            d="m17 2 5 5-.5.5a3.53 3.53 0 0 1-5 0l-1-1a3.53 3.53 0 0 1 0-5Z"
                                        ></path></svg
                                    >
                                </div>
                                <div
                                    class="w-10 h-1 rounded-full bg-primary/20"
                                >
                                </div>
                            </div>
                            <h3
                                class="text-xl font-bold text-primary-dark mt-2"
                            >
                                Rasa Konsisten
                            </h3>
                            <p class="text-text-muted leading-relaxed">
                                Standar produksi & higienitas terjaga agar
                                setiap acara selalu berkesan.
                            </p>
                        </article>

                        <!-- Card 2 -->
                        <article
                            class="group relative flex flex-col gap-4 p-8 bg-white rounded-3xl border border-primary/10 shadow-[0_10px_30px_rgba(0,0,0,0.03)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_30px_60px_rgba(0,0,0,0.08)]"
                        >
                            <div
                                class="absolute -bottom-5 -right-[15px] w-[130px] h-[130px] opacity-4 -rotate-15 pointer-events-none transition-all duration-500 z-1 group-hover:opacity-8 group-hover:rotate-0 group-hover:scale-110 group-hover:-bottom-[10px] text-primary-dark"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="100%"
                                    height="100%"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="lucide lucide-package-check"
                                    ><path d="m16 16 2 2 4-4"></path><path
                                        d="M21 10V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l2-1.14"
                                    ></path><path
                                        d="m7.5 4.27 4.5 2.59 4.5-2.59"
                                    ></path><path d="M12 22.27V12"></path><path
                                        d="m3.3 7 8.7 5 8.7-5"></path></svg
                                >
                            </div>
                            <div
                                class="flex items-center justify-between mb-2 relative z-2"
                            >
                                <div
                                    class="w-12 h-12 rounded-2xl flex items-center justify-center text-white bg-primary-dark"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="lucide lucide-package-check"
                                        ><path d="m16 16 2 2 4-4"></path><path
                                            d="M21 10V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l2-1.14"
                                        ></path><path
                                            d="m7.5 4.27 4.5 2.59 4.5-2.59"
                                        ></path><path d="M12 22.27V12"
                                        ></path><path d="m3.3 7 8.7 5 8.7-5"
                                        ></path></svg
                                    >
                                </div>
                                <div
                                    class="w-10 h-1 rounded-full bg-primary-dark/20"
                                >
                                </div>
                            </div>
                            <h3
                                class="text-xl font-bold text-primary-dark mt-2"
                            >
                                Paket Rapi
                            </h3>
                            <p class="text-text-muted leading-relaxed">
                                Snack box tertata rapi untuk pengajian, sekolah,
                                hajatan, dan event komunitas.
                            </p>
                        </article>

                        <!-- Card 3 -->
                        <article
                            class="group relative flex flex-col gap-4 p-8 bg-white rounded-3xl border border-primary/10 shadow-[0_10px_30px_rgba(0,0,0,0.03)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_30px_60px_rgba(0,0,0,0.08)]"
                        >
                            <div
                                class="absolute -bottom-5 -right-[15px] w-[130px] h-[130px] opacity-4 -rotate-15 pointer-events-none transition-all duration-500 z-1 group-hover:opacity-8 group-hover:rotate-0 group-hover:scale-110 group-hover:-bottom-[10px] text-[#fcda5b]"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="100%"
                                    height="100%"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="lucide lucide-heart-handshake"
                                    ><path
                                        d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"
                                    ></path><path
                                        d="M12 5 9.04 7.96a2.17 2.17 0 0 0 0 3.08v0c.82.82 2.13.82 2.96 0l2.96-2.96"
                                    ></path><path d="m18 15-2-2"></path><path
                                        d="m15 18-2-2"></path></svg
                                >
                            </div>
                            <div
                                class="flex items-center justify-between mb-2 relative z-2"
                            >
                                <div
                                    class="w-12 h-12 rounded-2xl flex items-center justify-center bg-[#fcda5b] text-primary-dark"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="lucide lucide-heart-handshake"
                                        ><path
                                            d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"
                                        ></path><path
                                            d="M12 5 9.04 7.96a2.17 2.17 0 0 0 0 3.08v0c.82.82 2.13.82 2.96 0l2.96-2.96"
                                        ></path><path d="m18 15-2-2"
                                        ></path><path d="m15 18-2-2"
                                        ></path></svg
                                    >
                                </div>
                                <div
                                    class="w-10 h-1 rounded-full bg-[#fdef5a]/50"
                                >
                                </div>
                            </div>
                            <h3
                                class="text-xl font-bold text-primary-dark mt-2"
                            >
                                Harga Terjangkau
                            </h3>
                            <p class="text-text-muted leading-relaxed">
                                Cocok untuk volume besar tanpa mengorbankan
                                kualitas rasa.
                            </p>
                        </article>

                        <!-- Card 4 -->
                        <article
                            class="group relative flex flex-col gap-4 p-8 bg-white rounded-3xl border border-primary/10 shadow-[0_10px_30px_rgba(0,0,0,0.03)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_30px_60px_rgba(0,0,0,0.08)]"
                        >
                            <div
                                class="absolute -bottom-5 -right-[15px] w-[130px] h-[130px] opacity-4 -rotate-15 pointer-events-none transition-all duration-500 z-1 group-hover:opacity-8 group-hover:rotate-0 group-hover:scale-110 group-hover:-bottom-[10px] text-primary"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="100%"
                                    height="100%"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="1"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    class="lucide lucide-map-pin"
                                    ><path
                                        d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"
                                    ></path><circle cx="12" cy="10" r="3"
                                    ></circle></svg
                                >
                            </div>
                            <div
                                class="flex items-center justify-between mb-2 relative z-2"
                            >
                                <div
                                    class="w-12 h-12 rounded-2xl flex items-center justify-center text-white bg-primary"
                                >
                                    <svg
                                        xmlns="http://www.w3.org/2000/svg"
                                        width="24"
                                        height="24"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        class="lucide lucide-map-pin"
                                        ><path
                                            d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"
                                        ></path><circle cx="12" cy="10" r="3"
                                        ></circle></svg
                                    >
                                </div>
                                <div
                                    class="w-10 h-1 rounded-full bg-primary/30"
                                >
                                </div>
                            </div>
                            <h3
                                class="text-xl font-bold text-primary-dark mt-2"
                            >
                                Dukungan Lokal
                            </h3>
                            <p class="text-text-muted leading-relaxed">
                                Memajukan UMKM Jogja dengan sistem produksi yang
                                memberdayakan warga sekitar.
                            </p>
                        </article>
                    </div>
                </div>
            </div>
        </section>

        <!-- Kisah Kami / Profil Singkat -->
        <section class="section pt-12 reveal">
            <div class="container">
                <div class="section-head">
                    <span class="sub-title">Kisah Kami</span>
                    <h2>
                        Lebih dari Sekadar Roti, Ini Tentang <span
                            class="text-primary italic">Keberkahan</span
                        >
                    </h2>
                    <p>
                        Mendedikasikan diri pada proses dan kualitas produksi
                        untuk warga Yogyakarta sejak 2016.
                    </p>
                </div>

                <div
                    class="bg-white/60 backdrop-blur-sm border border-border/80 rounded-2xl p-8 lg:p-14 shadow-sm relative overflow-hidden mt-8"
                >
                    <!-- Subtle brand accent -->
                    <div class="absolute top-0 left-0 w-2 h-full bg-primary/20">
                    </div>

                    <div
                        class="text-text-muted leading-loose text-lg space-y-6 md:space-y-8 pl-4 lg:pl-6"
                    >
                        <p
                            class="text-xl md:text-2xl text-primary-dark font-fraunces leading-relaxed"
                        >
                            Beroperasi sejak tahun 2016 di bawah naungan <strong
                                class="font-bold">CV Satria Sejahtera</strong
                            >, Roti Sholawat hadir melampaui fungsi primernya
                            sebagai penyedia nutrisi, menjadi representasi
                            identitas sosial dan budaya di Kabupaten Bantul.
                        </p>
                        <div
                            class="grid md:grid-cols-2 gap-8 md:gap-12 pt-4 border-t border-border/40"
                        >
                            <p>
                                Nama <strong
                                    class="text-primary-dark font-fraunces italic"
                                    >"Sholawat"</strong
                                > bukan sekadar merek, melainkan doa dan penghormatan
                                kepada Nabi Muhammad SAW yang diwujudkan dalam nilai-nilai
                                <span class="italic">halalan thayyiban</span> (halal
                                dan baik). Kami dipercaya dengan "kontrak psikologis"
                                oleh konsumen karena dedikasi tinggi pada keberkahan
                                proses produksi.
                            </p>
                            <p>
                                Kini, kami telah berkembang dengan memiliki <strong
                                    class="text-primary-dark"
                                    >lebih dari 30 outlet</strong
                                >
                                yang tersebar di DIY dan Jawa Tengah. Dengan standar
                                keamanan pangan yang ketat (DINKES P-IRT No. 2063402011625-20)
                                dan komitmen higienitas, setiap gigitan produk kami
                                adalah jaminan kualitas untuk menemani momen silaturahmi
                                Anda.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- FAQ with Tailwind v4 utilities -->
        <section id="faq" class="section reveal bg-bg-alt/40">
            <div
                class="container grid grid-cols-1 lg:grid-cols-[0.9fr,1.1fr] gap-10 items-start"
            >
                <div class="faq-aside">
                    <div class="section-head">
                        <h2>FAQ</h2>
                        <p>
                            Jawaban ringkas untuk pertanyaan yang sering
                            ditanyakan.
                        </p>
                    </div>
                    <div
                        class="bg-gradient-to-br from-primary/5 to-secondary/10 rounded-[24px] p-8 mt-8 border border-primary/10 shadow-[0_8px_30px_rgba(0,0,0,0.03)] relative overflow-hidden group"
                    >
                        <!-- Decorative element behind -->
                        <div
                            class="absolute -right-6 -top-6 w-32 h-32 bg-primary/10 rounded-full blur-2xl group-hover:bg-primary/20 transition-all duration-700 pointer-events-none"
                        >
                        </div>
                        <div class="relative z-10">
                            <h3
                                class="font-fraunces text-2xl text-primary-dark mb-3 leading-tight block"
                            >
                                Butuh Jawaban Cepat?
                            </h3>
                            <p
                                class="text-text-muted mb-7 leading-relaxed text-[1.05rem]"
                            >
                                Kami siap membantu Anda memilih paket dan
                                kustomisasi terbaik yang sesuai dengan anggaran
                                acara.
                            </p>
                            <a
                                class="btn btn-primary w-full justify-center shadow-md hover:shadow-[0_12px_30px_rgba(37,190,196,0.3)] transition-all duration-300 gap-2"
                                href={waLink}
                                target="_blank"
                            >
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    width="18"
                                    height="18"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2.5"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    ><path
                                        d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                                    ></path></svg
                                >
                                Tanya via WhatsApp
                            </a>
                        </div>
                    </div>
                </div>
                <div class="flex flex-col gap-4 mt-2">
                    {
                        faqs.map((faq) => (
                            <details class="group bg-white/70 backdrop-blur-sm border border-border/80 rounded-[20px] p-5 lg:p-6 transition-all duration-300 open:border-primary/40 open:shadow-[0_12px_30px_rgba(0,0,0,0.04)] open:bg-white cursor-pointer hover:border-primary/30">
                                <summary class="font-bold list-none flex justify-between items-center group-open:text-primary-dark">
                                    <span class="text-lg md:text-xl font-fraunces leading-tight pr-6">
                                        {faq.q}
                                    </span>
                                    <span class="w-8 h-8 md:w-10 md:h-10 shrink-0 rounded-full bg-primary/10 flex items-center justify-center text-primary transition-all duration-300 group-open:rotate-45 group-open:bg-primary group-open:text-white group-open:shadow-sm">
                                        <svg
                                            xmlns="http://www.w3.org/2000/svg"
                                            width="20"
                                            height="20"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2.5"
                                            stroke-linecap="round"
                                            stroke-linejoin="round"
                                        >
                                            <>
                                                <path d="M5 12h14" />
                                                <path d="M12 5v14" />
                                            </>
                                        </svg>
                                    </span>
                                </summary>
                                <div class="overflow-hidden">
                                    <p class="text-text-muted mt-5 leading-relaxed border-t border-border/60 pt-5 text-[1.05rem]">
                                        {faq.a}
                                    </p>
                                </div>
                            </details>
                        ))
                    }
                </div>
            </div>
        </section>
    </main>
</Layout>
