---
import Layout from "@layouts/Layout.astro";

const waLink =
  "https://wa.me/6281314537475?text=Halo%20Roti%20Sholawat%2C%20saya%20mau%20konsultasi%20paket%20snack%20box%20untuk%20acara.";

const faqs = [
  {
    q: "Minimal order snack box?",
    a: "Menyesuaikan paket dan acara. Hubungi kami untuk rekomendasi terbaik.",
  },
  {
    q: "Area pengiriman?",
    a: "Fokus wilayah Yogyakarta (DIY dan sekitarnya). Area lain dapat dikonsultasikan.",
  },
  {
    q: "Berapa lama produksi?",
    a: "Lead time menyesuaikan jumlah pesanan. Semakin awal konfirmasi, semakin optimal jadwal produksi.",
  },
  {
    q: "Apakah bisa custom paket?",
    a: "Bisa. Kami menyesuaikan kebutuhan acara dan budget komunitas Anda.",
  },
  {
    q: "Bagaimana jadi reseller?",
    a: "Hubungi kami via WhatsApp untuk konsultasi wilayah dan paket awal kemitraan.",
  },
];
---

<Layout
  title="Tentang Kami — Roti Sholawat"
  description="Pelajari lebih lanjut tentang nilai-nilai kami dan jawaban atas pertanyaan yang sering diajukan."
>
  <main class="pt-0 pb-20">
    <!-- Why Roti Sholawat? -->
    <section class="section reveal pt-6 pb-8 lg:pt-8">
      <div class="container">
        <div class="section-head">
          <span class="sub-title">Keunggulan Kami</span>
          <h1 class="font-fraunces text-primary-dark mt-2 mb-4 text-3xl md:text-4xl">Mengapa Roti Sholawat?</h1>
          <p>
            Brand roti yang lahir dari nilai silaturahmi dan keberkahan — fokus pada kebutuhan komunitas di Yogyakarta.
          </p>
        </div>

        <div class="mt-8">
          <div
            class="mb-12 flex items-center gap-8 rounded-3xl border border-white/80 bg-white/50 p-8 backdrop-blur-md max-md:flex-col max-md:items-center max-md:gap-4 max-md:text-center"
          >
            <div
              class="bg-primary h-min rounded-xl px-4 py-2 text-[0.9rem] font-extrabold whitespace-nowrap text-white shadow-[0_8px_16px_rgba(37,190,196,0.2)]"
            >
              Visi Kami
            </div>
            <div class="intro-text">
              <strong class="text-primary-dark mb-1 block text-2xl leading-[1.2]">Rasa terjaga, layanan terasa.</strong>
              <p class="text-text-muted max-w-[600px] text-[1.1rem]">
                Kami hadir sebagai partner acara yang bisa diandalkan, dari keluarga hingga komunitas besar.
              </p>
            </div>
          </div>

          <div class="carousel-mobile grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-4">
            <!-- Card 1 -->
            <article
              class="group border-primary/10 relative flex flex-col gap-4 rounded-3xl border bg-white p-8 shadow-[0_10px_30px_rgba(0,0,0,0.03)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_30px_60px_rgba(0,0,0,0.08)]"
            >
              <div
                class="text-primary pointer-events-none absolute -right-[15px] -bottom-5 z-1 h-[130px] w-[130px] -rotate-15 opacity-4 transition-all duration-500 group-hover:-bottom-[10px] group-hover:scale-110 group-hover:rotate-0 group-hover:opacity-8"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="100%"
                  height="100%"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="lucide lucide-shovels"
                  ><path d="M2 22v-5l5-5 5 5v5z"></path><path d="M9.5 14.5L16 8"></path><path
                    d="m17 2 5 5-.5.5a3.53 3.53 0 0 1-5 0l-1-1a3.53 3.53 0 0 1 0-5Z"></path></svg
                >
              </div>
              <div class="relative z-2 mb-2 flex items-center justify-between">
                <div class="bg-primary flex h-12 w-12 items-center justify-center rounded-2xl text-white">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-shovels"
                    ><path d="M2 22v-5l5-5 5 5v5z"></path><path d="M9.5 14.5L16 8"></path><path
                      d="m17 2 5 5-.5.5a3.53 3.53 0 0 1-5 0l-1-1a3.53 3.53 0 0 1 0-5Z"></path></svg
                  >
                </div>
                <div class="bg-primary/20 h-1 w-10 rounded-full"></div>
              </div>
              <h3 class="text-primary-dark mt-2 text-xl font-bold">Rasa Konsisten</h3>
              <p class="text-text-muted leading-relaxed">
                Standar produksi & higienitas terjaga agar setiap acara selalu berkesan.
              </p>
            </article>

            <!-- Card 2 -->
            <article
              class="group border-primary/10 relative flex flex-col gap-4 rounded-3xl border bg-white p-8 shadow-[0_10px_30px_rgba(0,0,0,0.03)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_30px_60px_rgba(0,0,0,0.08)]"
            >
              <div
                class="text-primary-dark pointer-events-none absolute -right-[15px] -bottom-5 z-1 h-[130px] w-[130px] -rotate-15 opacity-4 transition-all duration-500 group-hover:-bottom-[10px] group-hover:scale-110 group-hover:rotate-0 group-hover:opacity-8"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="100%"
                  height="100%"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="lucide lucide-package-check"
                  ><path d="m16 16 2 2 4-4"></path><path
                    d="M21 10V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l2-1.14"
                  ></path><path d="m7.5 4.27 4.5 2.59 4.5-2.59"></path><path d="M12 22.27V12"></path><path
                    d="m3.3 7 8.7 5 8.7-5"></path></svg
                >
              </div>
              <div class="relative z-2 mb-2 flex items-center justify-between">
                <div class="bg-primary-dark flex h-12 w-12 items-center justify-center rounded-2xl text-white">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-package-check"
                    ><path d="m16 16 2 2 4-4"></path><path
                      d="M21 10V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l2-1.14"
                    ></path><path d="m7.5 4.27 4.5 2.59 4.5-2.59"></path><path d="M12 22.27V12"></path><path
                      d="m3.3 7 8.7 5 8.7-5"></path></svg
                  >
                </div>
                <div class="bg-primary-dark/20 h-1 w-10 rounded-full"></div>
              </div>
              <h3 class="text-primary-dark mt-2 text-xl font-bold">Paket Rapi</h3>
              <p class="text-text-muted leading-relaxed">
                Snack box tertata rapi untuk pengajian, sekolah, hajatan, dan event komunitas.
              </p>
            </article>

            <!-- Card 3 -->
            <article
              class="group border-primary/10 relative flex flex-col gap-4 rounded-3xl border bg-white p-8 shadow-[0_10px_30px_rgba(0,0,0,0.03)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_30px_60px_rgba(0,0,0,0.08)]"
            >
              <div
                class="pointer-events-none absolute -right-[15px] -bottom-5 z-1 h-[130px] w-[130px] -rotate-15 text-[#fcda5b] opacity-4 transition-all duration-500 group-hover:-bottom-[10px] group-hover:scale-110 group-hover:rotate-0 group-hover:opacity-8"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="100%"
                  height="100%"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="lucide lucide-heart-handshake"
                  ><path
                    d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"
                  ></path><path d="M12 5 9.04 7.96a2.17 2.17 0 0 0 0 3.08v0c.82.82 2.13.82 2.96 0l2.96-2.96"
                  ></path><path d="m18 15-2-2"></path><path d="m15 18-2-2"></path></svg
                >
              </div>
              <div class="relative z-2 mb-2 flex items-center justify-between">
                <div class="text-primary-dark flex h-12 w-12 items-center justify-center rounded-2xl bg-[#fcda5b]">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-heart-handshake"
                    ><path
                      d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"
                    ></path><path d="M12 5 9.04 7.96a2.17 2.17 0 0 0 0 3.08v0c.82.82 2.13.82 2.96 0l2.96-2.96"
                    ></path><path d="m18 15-2-2"></path><path d="m15 18-2-2"></path></svg
                  >
                </div>
                <div class="h-1 w-10 rounded-full bg-[#fdef5a]/50"></div>
              </div>
              <h3 class="text-primary-dark mt-2 text-xl font-bold">Harga Terjangkau</h3>
              <p class="text-text-muted leading-relaxed">Cocok untuk volume besar tanpa mengorbankan kualitas rasa.</p>
            </article>

            <!-- Card 4 -->
            <article
              class="group border-primary/10 relative flex flex-col gap-4 rounded-3xl border bg-white p-8 shadow-[0_10px_30px_rgba(0,0,0,0.03)] transition-all duration-500 hover:-translate-y-2 hover:shadow-[0_30px_60px_rgba(0,0,0,0.08)]"
            >
              <div
                class="text-primary pointer-events-none absolute -right-[15px] -bottom-5 z-1 h-[130px] w-[130px] -rotate-15 opacity-4 transition-all duration-500 group-hover:-bottom-[10px] group-hover:scale-110 group-hover:rotate-0 group-hover:opacity-8"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="100%"
                  height="100%"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="1"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="lucide lucide-map-pin"
                  ><path
                    d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"
                  ></path><circle cx="12" cy="10" r="3"></circle></svg
                >
              </div>
              <div class="relative z-2 mb-2 flex items-center justify-between">
                <div class="bg-primary flex h-12 w-12 items-center justify-center rounded-2xl text-white">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="lucide lucide-map-pin"
                    ><path
                      d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"
                    ></path><circle cx="12" cy="10" r="3"></circle></svg
                  >
                </div>
                <div class="bg-primary/30 h-1 w-10 rounded-full"></div>
              </div>
              <h3 class="text-primary-dark mt-2 text-xl font-bold">Dukungan Lokal</h3>
              <p class="text-text-muted leading-relaxed">
                Memajukan UMKM Jogja dengan sistem produksi yang memberdayakan warga sekitar.
              </p>
            </article>
          </div>
        </div>
      </div>
    </section>

    <!-- Kisah Kami / Profil Singkat -->
    <section class="section reveal pt-12">
      <div class="container">
        <div class="section-head">
          <span class="sub-title">Kisah Kami</span>
          <h2>
            Lebih dari Sekadar Roti, Ini Tentang <span class="text-primary italic">Keberkahan</span>
          </h2>
          <p>Mendedikasikan diri pada proses dan kualitas produksi untuk warga Yogyakarta sejak 2016.</p>
        </div>

        <div
          class="border-border/80 relative mt-8 overflow-hidden rounded-2xl border bg-white/60 p-8 shadow-sm backdrop-blur-sm lg:p-14"
        >
          <!-- Subtle brand accent -->
          <div class="bg-primary/20 absolute top-0 left-0 h-full w-2"></div>

          <div class="text-text-muted space-y-6 pl-4 text-lg leading-loose md:space-y-8 lg:pl-6">
            <p class="text-primary-dark font-fraunces text-xl leading-relaxed md:text-2xl">
              Beroperasi sejak tahun 2016 di bawah naungan <strong class="font-bold">CV Satria Sejahtera</strong>, Roti
              Sholawat hadir melampaui fungsi primernya sebagai penyedia nutrisi, menjadi representasi identitas sosial
              dan budaya di Kabupaten Bantul.
            </p>
            <div class="border-border/40 grid gap-8 border-t pt-4 md:grid-cols-2 md:gap-12">
              <p>
                Nama <strong class="text-primary-dark font-fraunces italic">"Sholawat"</strong> bukan sekadar merek, melainkan
                doa dan penghormatan kepada Nabi Muhammad SAW yang diwujudkan dalam nilai-nilai
                <span class="italic">halalan thayyiban</span> (halal dan baik). Kami dipercaya dengan "kontrak psikologis"
                oleh konsumen karena dedikasi tinggi pada keberkahan proses produksi.
              </p>
              <p>
                Kini, kami telah berkembang dengan memiliki <strong class="text-primary-dark"
                  >lebih dari 30 outlet</strong
                >
                yang tersebar di DIY dan Jawa Tengah. Dengan standar keamanan pangan yang ketat (DINKES P-IRT No. 2063402011625-20)
                dan komitmen higienitas, setiap gigitan produk kami adalah jaminan kualitas untuk menemani momen silaturahmi
                Anda.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ with Tailwind v4 utilities -->
    <section id="faq" class="section reveal bg-bg-alt/40">
      <div class="container grid grid-cols-1 items-start gap-10 lg:grid-cols-[0.9fr,1.1fr]">
        <div class="faq-aside">
          <div class="section-head">
            <h2>FAQ</h2>
            <p>Jawaban ringkas untuk pertanyaan yang sering ditanyakan.</p>
          </div>
          <div
            class="from-primary/5 to-secondary/10 border-primary/10 group relative mt-8 overflow-hidden rounded-[24px] border bg-gradient-to-br p-8 shadow-[0_8px_30px_rgba(0,0,0,0.03)]"
          >
            <!-- Decorative element behind -->
            <div
              class="bg-primary/10 group-hover:bg-primary/20 pointer-events-none absolute -top-6 -right-6 h-32 w-32 rounded-full blur-2xl transition-all duration-700"
            >
            </div>
            <div class="relative z-10">
              <h3 class="font-fraunces text-primary-dark mb-3 block text-2xl leading-tight">Butuh Jawaban Cepat?</h3>
              <p class="text-text-muted mb-7 text-[1.05rem] leading-relaxed">
                Kami siap membantu Anda memilih paket dan kustomisasi terbaik yang sesuai dengan anggaran acara.
              </p>
              <a
                class="btn btn-primary w-full justify-center gap-2 shadow-md transition-all duration-300 hover:shadow-[0_12px_30px_rgba(37,190,196,0.3)]"
                href={waLink}
                target="_blank"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
                  ></path></svg
                >
                Tanya via WhatsApp
              </a>
            </div>
          </div>
        </div>
        <div class="mt-2 flex flex-col gap-4">
          {
            faqs.map((faq) => (
              <details class="group border-border/80 open:border-primary/40 hover:border-primary/30 cursor-pointer rounded-[20px] border bg-white/70 p-5 backdrop-blur-sm transition-all duration-300 open:bg-white open:shadow-[0_12px_30px_rgba(0,0,0,0.04)] lg:p-6">
                <summary class="group-open:text-primary-dark flex list-none items-center justify-between font-bold">
                  <span class="font-fraunces pr-6 text-lg leading-tight md:text-xl">{faq.q}</span>
                  <span class="bg-primary/10 text-primary group-open:bg-primary flex h-8 w-8 shrink-0 items-center justify-center rounded-full transition-all duration-300 group-open:rotate-45 group-open:text-white group-open:shadow-sm md:h-10 md:w-10">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <>
                        <path d="M5 12h14" />
                        <path d="M12 5v14" />
                      </>
                    </svg>
                  </span>
                </summary>
                <div class="overflow-hidden">
                  <p class="text-text-muted border-border/60 mt-5 border-t pt-5 text-[1.05rem] leading-relaxed">
                    {faq.a}
                  </p>
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </section>
  </main>
</Layout>
