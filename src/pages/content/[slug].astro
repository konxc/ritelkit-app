---
import Layout from "../../layouts/Layout.astro";
import { getDb, initDb } from "../../lib/db";
import { renderMarkdown } from "../../lib/markdown";

await initDb(Astro);
const db = getDb(Astro);
const slug = Astro.params.slug || "";
const pageRes = await db.execute({
  sql: "SELECT title, content_md FROM cms_pages WHERE slug = ? AND is_active = 1",
  args: [slug],
});
const page = pageRes.rows[0] as any;
if (!page) {
  return Astro.redirect("/");
}
const content = renderMarkdown(String(page.content_md || ""));
---

<Layout title={page.title} description={page.title}>
  <main class="section">
    <div class="container">
      <h1 class="section-title">{page.title}</h1>
      <article class="cms-content" set:html={content} />
    </div>
  </main>
</Layout>
