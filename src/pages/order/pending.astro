---
import Layout from "../../layouts/Layout.astro";

const orderNo = Astro.url.searchParams.get("order") || "";
---

<Layout title="Pembayaran Pending">
  <main class="section">
    <div class="container text-center">
      <h1>Pembayaran Pending</h1>
      <p>Silakan selesaikan pembayaran agar pesanan dapat diproses.</p>
      {
        orderNo && (
          <p>
            Order: <strong>{orderNo}</strong>
          </p>
        )
      }
      <a class="btn btn-primary" href="/order">Kembali ke Order</a>
    </div>
  </main>
</Layout>
