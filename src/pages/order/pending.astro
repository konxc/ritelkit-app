---
import Layout from "../../layouts/Layout.astro";

const orderNo = Astro.url.searchParams.get("order") || "";
---

<Layout title="Pembayaran Menunggu">
  <main class="section">
    <div class="container text-center">
      <h1>Pembayaran Menunggu</h1>
      <p>Silakan selesaikan pembayaran agar pesanan dapat diproses.</p>
      {
        orderNo && (
          <p>
            Pesanan: <strong>{orderNo}</strong>
          </p>
        )
      }
      <a class="btn btn-primary" href="/order">Kembali ke Pesanan</a>
    </div>
  </main>
</Layout>
