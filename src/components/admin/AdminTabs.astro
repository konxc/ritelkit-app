---
interface Props {
  tabs: {
    id: string;
    label: string;
    icon?: string;
  }[];
  activeTab: string;
}

const { tabs, activeTab } = Astro.props;
const baseUrl = Astro.url.pathname;

// Clean up pagination/search params when switching main tabs if needed,
// but usually we want to keep them if they are common.
// For now, let's keep it simple and just change the 'tab' param.
---

<div class="no-scrollbar flex w-full items-center gap-1.5 overflow-x-auto rounded-2xl p-1 sm:w-max">
  {
    tabs.map((tab) => {
      const isActive = tab.id === activeTab;
      const url = new URL(Astro.url.origin + baseUrl);
      url.searchParams.set("tab", tab.id);

      return (
        <a
          href={url.search}
          class={`group relative flex items-center justify-center gap-2 rounded-xl px-4 py-2 text-[0.85rem] font-bold whitespace-nowrap no-underline transition-all duration-300 active:scale-95 ${
            isActive
              ? "bg-[#c48a3a] text-white shadow-[0_4px_16px_rgba(196,138,58,0.25)]"
              : "text-stone-500 hover:bg-stone-50 hover:text-stone-900"
          }`}
        >
          {tab.icon && (
            <span
              class={`${isActive ? "text-white" : "text-stone-400 group-hover:text-stone-600"} transition-colors`}
              set:html={tab.icon}
            />
          )}
          {tab.label}
        </a>
      );
    })
  }
</div>

<style>
  .no-scrollbar::-webkit-scrollbar {
    display: none;
  }
  .no-scrollbar {
    -ms-overflow-style: none; /* IE and Edge */
    scrollbar-width: none; /* Firefox */
  }
</style>
