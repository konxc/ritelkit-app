---
import "../styles/global.css";
import RevealObserver from "@components/RevealObserver.svelte";

interface Props {
  title?: string;
  description?: string;
  hideFooter?: boolean;
}

const {
  title = "Roti Sholawat - Bakery Terbaik di Bantul & Jogja",
  description = "Menyediakan Roti Manis, Aneka Cake, dan Paket Roti 10 Rasa dengan kualitas premium. Kunjungi kami di Bantul, Yogyakarta.",
  hideFooter = false,
} = Astro.props;

const waLink = "https://wa.me/6281314537475?text=Halo%20Roti%20Sholawat%2C%20saya%20mau%20konsultasi%20pemesanan.";
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- CSP meta tag for Midtrans and Assets -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://app.sandbox.midtrans.com https://app.midtrans.com https://fonts.googleapis.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https:; connect-src 'self' https://app.sandbox.midtrans.com https://app.midtrans.com; frame-src 'self' https://app.sandbox.midtrans.com https://app.midtrans.com;"
    />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Roti Sholawat" />
    <meta name="keywords" content="Roti Sholawat, Bakery Bantul, Toko Roti Jogja, Roti Manis, Kue Mandarin" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/images/bakery/sholawat.jpeg" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="/images/bakery/sholawat.jpeg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:wght@400;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <style is:global>
      /* Failsafe to prevent font flicker */
      body {
        font-family: "Plus Jakarta Sans", sans-serif;
      }
      h1,
      h2,
      h3,
      h4,
      h5,
      h6,
      .font-fraunces {
        font-family: "Fraunces", serif;
      }
    </style>
  </head>
  <body class="flex min-h-screen flex-col overflow-x-hidden bg-[var(--color-bg)] pb-[70px] lg:pb-0">
    <header class="border-primary/10 sticky top-0 z-50 border-b bg-[#f6fffd]/95 py-1.5 backdrop-blur-xl">
      <div class="container flex items-center justify-between">
        <a href="/" class="relative z-[60] transition-transform hover:scale-[1.02]" aria-label="Roti Sholawat">
          <img
            src="/images/brand/logo-teks-sholawat.png"
            alt="Roti Sholawat"
            class="h-12 w-auto drop-shadow-sm sm:h-16"
          />
        </a>

        <!-- Desktop Nav -->
        <nav class="bg-primary/5 border-primary/10 hidden items-center gap-1.5 rounded-full border p-1 lg:flex">
          <a
            href="/"
            class="hover:text-primary-dark rounded-full px-4 py-2 text-sm font-semibold transition-all hover:bg-white"
            >Beranda</a
          >
          <a
            href="/about"
            class="hover:text-primary-dark rounded-full px-4 py-2 text-sm font-semibold transition-all hover:bg-white"
            >Tentang Kami</a
          >
          <a
            href="/products"
            class="hover:text-primary-dark rounded-full px-4 py-2 text-sm font-semibold transition-all hover:bg-white"
            >Produk</a
          >
          <a
            href="/premium"
            class="rounded-full bg-[linear-gradient(135deg,#9c6b43,#f2b24d)] px-4 py-2 text-sm font-semibold text-white shadow-sm hover:brightness-110"
            >Premium</a
          >
          <div class="bg-primary/20 mx-1 h-4 w-px"></div>
          <a
            href="/order"
            class="bg-primary hover:bg-primary-dark rounded-full px-6 py-2 text-sm font-bold text-white shadow-md transition-all hover:shadow-lg"
            >Pesan Online</a
          >
        </nav>

        <div class="flex items-center gap-2 lg:hidden">
          <a
            href="https://www.instagram.com/rotisholawat/"
            target="_blank"
            aria-label="Instagram"
            class="border-primary/20 text-primary-dark hover:bg-primary/10 flex h-8.5 w-8.5 items-center justify-center rounded-full border bg-white/80 transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="15"
              height="15"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.1"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect><path
                d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"
              ></line></svg
            >
          </a>
          <a
            href="https://www.tiktok.com/@rotisholawat"
            target="_blank"
            aria-label="TikTok"
            class="border-primary/20 text-primary-dark hover:bg-primary/10 flex h-8.5 w-8.5 items-center justify-center rounded-full border bg-white/80 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.74h-3.4v13.44a2.9 2.9 0 1 1-2.9-2.9c.2 0 .39.02.58.06V9.1c-.19-.03-.38-.05-.58-.05A6.3 6.3 0 1 0 15.82 15V8.26a8.2 8.2 0 0 0 4.78 1.54V6.69z"
              ></path></svg
            >
          </a>
          <a
            href={waLink}
            class="flex items-center justify-center gap-1.5 rounded-full bg-[#25d366] px-3.5 py-1.5 text-[0.85rem] font-bold text-white shadow-sm transition-all hover:scale-105 active:scale-95"
            target="_blank"
            aria-label="Chat WhatsApp"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"
              ></path></svg
            >
            <span>Chat</span>
          </a>
        </div>
      </div>
    </header>

    <!-- Bottom Navigation Mobile -->
    <nav
      class="border-primary/10 pb-safe fixed inset-x-0 bottom-0 z-[60] flex h-[68px] items-center justify-around border-t bg-[#f6fffd]/95 shadow-[0_-4px_24px_rgba(37,190,196,0.06)] backdrop-blur-xl lg:hidden"
    >
      <a
        href="/"
        class="text-text-muted hover:text-primary flex h-full w-full flex-col items-center justify-center gap-1 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          class="shrink-0"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"
          ></polyline></svg
        >
        <span class="mt-0.5 text-[0.65rem] font-bold">Beranda</span>
      </a>
      <a
        href="/products"
        class="text-text-muted hover:text-primary flex h-full w-full flex-col items-center justify-center gap-1 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="m7.5 4.27 9 5.15"></path><path
            d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"
          ></path><path d="m3.3 7 8.7 5 8.7-5"></path><path d="M12 22V12"></path></svg
        >
        <span class="mt-0.5 text-[0.65rem] font-bold">Produk</span>
      </a>
      <a
        href="/about"
        class="text-text-muted hover:text-primary flex h-full w-full flex-col items-center justify-center gap-1 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg
        >
        <span class="mt-0.5 text-[0.65rem] font-bold">Tentang</span>
      </a>
      <a
        href="/premium"
        class="flex h-full w-full flex-col items-center justify-center gap-1 text-amber-700/80 transition-colors hover:text-amber-800"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><polygon
            points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"
          ></polygon></svg
        >
        <span class="mt-0.5 text-[0.65rem] font-bold">Premium</span>
      </a>
      <a
        href="/order"
        class="text-text-muted hover:text-primary relative flex h-full w-full flex-col items-center justify-center gap-1 transition-colors"
      >
        <div
          class="bg-primary outline-primary/5 absolute -top-[16px] flex h-[52px] w-[52px] items-center justify-center rounded-2xl border-[5px] border-[#f6fffd] text-white shadow-[0_8px_20px_rgba(37,190,196,0.25)] outline outline-1 transition-all active:scale-95"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="22"
            height="22"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="-ml-0.5"
            ><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path
              d="M16 10a4 4 0 0 1-8 0"></path></svg
          >
        </div>
      </a>
    </nav>

    <slot />

    {
      !hideFooter && (
        <footer class="bg-primary-dark mt-auto py-12 text-white/90 md:py-16">
          <div class="container grid grid-cols-1 gap-10 text-center md:grid-cols-2 md:gap-8 md:text-left lg:grid-cols-4">
            {/* Brand */}
            <div class="space-y-4">
              <h3 class="font-fraunces text-2xl tracking-wide text-white">Roti Sholawat</h3>
              <p class="mx-auto max-w-xs text-[0.95rem] leading-relaxed text-white/70 md:mx-0">
                Menyebarkan nilai budaya, kehangatan, dan keberkahan lewat roti sajian premium sejak 2016.
              </p>
            </div>

            {/* Navigasi */}
            <div>
              <h4 class="text-secondary mb-5 text-sm font-bold tracking-wider uppercase">Navigasi Pilihan</h4>
              <ul class="space-y-3 text-[0.95rem] text-white/80">
                <li>
                  <a
                    href="/"
                    class="decoration-primary inline-block underline-offset-4 transition-all hover:text-white hover:underline"
                  >
                    Beranda
                  </a>
                </li>
                <li>
                  <a
                    href="/about"
                    class="decoration-primary inline-block underline-offset-4 transition-all hover:text-white hover:underline"
                  >
                    Tentang Kami
                  </a>
                </li>
                <li>
                  <a
                    href="/products"
                    class="decoration-primary inline-block underline-offset-4 transition-all hover:text-white hover:underline"
                  >
                    Katalog Produk
                  </a>
                </li>
                <li>
                  <a
                    href="/order"
                    class="decoration-primary inline-block underline-offset-4 transition-all hover:text-white hover:underline"
                  >
                    Konsultasi Pesanan
                  </a>
                </li>
              </ul>
            </div>

            {/* Kontak */}
            <div>
              <h4 class="text-secondary mb-5 text-sm font-bold tracking-wider uppercase">Pusat Bantuan</h4>
              <ul class="flex flex-col items-center space-y-3 text-[0.95rem] text-white/80 md:items-start">
                <li class="flex items-start gap-3 text-left">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="text-primary mt-1 shrink-0"
                  >
                    <>
                      <path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0" />
                      <circle cx="12" cy="10" r="3" />
                    </>
                  </svg>
                  <span>
                    Kabupaten Bantul,
                    <br />
                    Yogyakarta, Indonesia
                  </span>
                </li>
                <li class="w-full">
                  <a
                    href="https://wa.me/6281314537475"
                    target="_blank"
                    class="hover:bg-primary/20 hover:border-primary/30 mt-2 inline-flex w-full items-center justify-center gap-2 rounded-xl border border-white/5 bg-white/5 px-4 py-2.5 transition-all duration-300 hover:text-white md:w-auto md:justify-start"
                  >
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="16"
                      height="16"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2.5"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="text-secondary"
                    >
                      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z" />
                    </svg>
                    <span class="text-sm font-medium tracking-wide">+62 813-1453-7475</span>
                  </a>
                </li>
              </ul>
            </div>

            {/* Sosial Media */}
            <div>
              <h4 class="text-secondary mb-5 text-sm font-bold tracking-wider uppercase">Terhubung Sosial</h4>
              <div class="flex items-center justify-center gap-3 md:justify-start">
                <a
                  href="https://instagram.com/rotishoprem"
                  target="_blank"
                  aria-label="Instagram"
                  class="flex h-10 w-10 items-center justify-center rounded-full border border-white/5 bg-white/5 shadow-sm transition-all duration-300 hover:bg-gradient-to-tr hover:from-amber-500 hover:via-red-500 hover:to-purple-600 hover:text-white"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <rect width="20" height="20" x="2" y="2" rx="5" ry="5" />
                      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                      <line x1="17.5" x2="17.51" y1="6.5" y2="6.5" />
                    </>
                  </svg>
                </a>
                <a
                  href="https://facebook.com/b.shoprem"
                  target="_blank"
                  aria-label="Facebook"
                  class="flex h-10 w-10 items-center justify-center rounded-full border border-white/5 bg-white/5 shadow-sm transition-all duration-300 hover:bg-blue-600 hover:text-white"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" />
                  </svg>
                </a>
                <a
                  href="https://linkedin.com/company/cv-satria-sejahtera"
                  target="_blank"
                  aria-label="LinkedIn"
                  class="flex h-10 w-10 items-center justify-center rounded-full border border-white/5 bg-white/5 shadow-sm transition-all duration-300 hover:bg-blue-700 hover:text-white"
                >
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <>
                      <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z" />
                      <rect width="4" height="12" x="2" y="9" />
                      <circle cx="4" cy="4" r="2" />
                    </>
                  </svg>
                </a>
              </div>
            </div>
          </div>

          <div class="container mt-12 flex flex-col items-center justify-between gap-4 border-t border-white/10 pt-8 text-sm text-white/50 md:flex-row">
            <p>&copy; {new Date().getFullYear()} CV Satria Sejahtera. Seluruh hak cipta dilindungi.</p>
            <p class="flex items-center gap-1.5">
              Made with{" "}
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="currentColor"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-secondary"
              >
                <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
              </svg>{" "}
              in Yogyakarta.
            </p>
          </div>
        </footer>
      )
    }

    <RevealObserver client:load />
  </body>
</html>
