{
  "name": "roti-sholawat",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "XDG_CONFIG_HOME=/tmp/wrangler wrangler types && astro dev",
    "start": "XDG_CONFIG_HOME=/tmp/wrangler wrangler types && astro dev",
    "build": "XDG_CONFIG_HOME=/tmp/wrangler wrangler types && astro check && astro build",
    "build:cf": "ASTRO_ADAPTER=cloudflare XDG_CONFIG_HOME=/tmp/wrangler wrangler types && astro check && astro build",
    "build:node": "ASTRO_ADAPTER=node NODE_RUNTIME=1 sh -c 'astro check && astro build'",
    "preview": "XDG_CONFIG_HOME=/tmp/wrangler wrangler types && astro preview",
    "generate-types": "XDG_CONFIG_HOME=/tmp/wrangler wrangler types",
    "validate": "pnpm run validate:all",
    "validate:all": "pnpm run validate:astro && pnpm run validate:cf && pnpm run validate:svelte",
    "validate:cf": "pnpm run generate-types && tsc",
    "validate:astro": "pnpm run astro check",
    "validate:svelte": "svelte-check",
    "smoke:api": "bash scripts/smoke-api.sh",
    "astro": "astro",
    "seed": "tsx scripts/seed-admin.ts",
    "capture:research": "node scripts/capture-research.mjs"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.6",
    "@astrojs/cloudflare": "^12.6.12",
    "@astrojs/node": "^9.0.0",
    "@astrojs/partytown": "^2.1.4",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/svelte": "^7.2.5",
    "@aws-sdk/client-s3": "^3.888.0",
    "@libsql/client": "^0.15.7",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/svelte-query": "^6.0.18",
    "@trpc/client": "^11.10.0",
    "@trpc/server": "^11.10.0",
    "astro": "^5.17.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "pdfkit": "^0.17.2",
    "playwright": "^1.58.2",
    "sharp": "^0.34.4",
    "svelte": "^5.53.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "@types/pdfkit": "^0.17.5",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "svelte-check": "^4.4.3",
    "svelte-check-rs": "^0.9.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "wrangler": "^4.67.0"
  }
}